    {
      "type": "range",
      "id": "padding_side",
      "min": 0,
      "max": 80,
      "step": 4,
      "label": "Padding sides",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "case_study",
      "name": "Case Study",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Project title",
          "default": "Project Title"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "City, Country"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Solar Installation"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brief description of the project and results achieved."
        },
        {
          "type": "text",
          "id": "link_text",
