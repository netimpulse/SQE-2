{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns
  assign bg_color = section.settings.background_color
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color
-%}

<section
  id="sqe-case-studies-{{ section.id }}"
  class="sqe-case-studies"
  style="--sqe-bg-color: {{ bg_color }}; --sqe-h-font: {{ h_font }}; --sqe-h-size: {{ h_size }}px; --sqe-h-color: {{ h_color }}; --sqe-h-weight: {{ h_weight }}; --sqe-sh-font: {{ sh_font }}; --sqe-sh-size: {{ sh_size }}px; --sqe-sh-color: {{ sh_color }};"
>
  <div class="sqe-case-studies-container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if heading != blank %}
      <h2 class="sqe-case-studies-heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="sqe-case-studies-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="sqe-case-studies-grid" data-columns="{{ columns }}">
      {% for block in section.blocks %}
        {% if block.type == 'case_study' %}
          <div class="sqe-case-study-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="sqe-case-study-image">
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                  width="600"
                  height="250"
                >
              </div>
            {% else %}
              <div class="sqe-case-study-image sqe-case-study-image--placeholder">
                <svg aria-hidden="true" viewBox="0 0 600 250" xmlns="http://www.w3.org/2000/svg">
                  <rect fill="#F2F4F7" width="600" height="250"/>
                  <text x="50%" y="50%" text-anchor="middle" dy="0.3em" fill="#999" font-family="sans-serif" font-size="16">No image available</text>
                </svg>
              </div>
            {% endif %}

            <div class="sqe-case-study-content">
              {% if block.settings.category != blank %}
                <span class="sqe-case-study-category">{{ block.settings.category }}</span>
              {% endif %}

              {% if block.settings.title != blank %}
                <h3 class="sqe-case-study-title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.location != blank %}
                <p class="sqe-case-study-location">{{ block.settings.location }}</p>
              {% endif %}

              {% if block.settings.description != blank %}
                <p class="sqe-case-study-description">{{ block.settings.description }}</p>
              {% endif %}

              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="sqe-case-study-link">Read More</a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}

      {% if section.blocks.size == 0 %}
        <div class="sqe-case-study-empty-state" style="grid-column: 1 / -1; text-align: center; padding: 40px 20px; color: #999;">
          <p>No case studies added yet. Add a case study block to get started.</p>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #sqe-case-studies-{{ section.id }} {
    background-color: var(--sqe-bg-color);
    padding: 60px 20px;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-case-studies-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #C75B12;
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-heading {
    font-family: var(--sqe-h-font);
    font-size: var(--sqe-h-size);
    font-weight: var(--sqe-h-weight);
    color: var(--sqe-h-color);
    margin-bottom: 10px;
    text-align: center;
    overflow-wrap: break-word;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-subheading {
    font-family: var(--sqe-sh-font);
    font-size: var(--sqe-sh-size);
    color: var(--sqe-sh-color);
    text-align: center;
    margin-bottom: 40px;
    overflow-wrap: break-word;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid {
    display: grid;
    gap: 30px;
    margin-top: 40px;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid[data-columns="2"] {
    grid-template-columns: repeat(2, 1fr);
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid[data-columns="3"] {
    grid-template-columns: repeat(3, 1fr);
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid[data-columns="4"] {
    grid-template-columns: repeat(4, 1fr);
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-image {
    width: 100%;
    height: 250px;
    overflow: hidden;
    background-color: #F2F4F7;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-image--placeholder svg {
    width: 100%;
    height: 100%;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-content {
    padding: 25px;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-category {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: #C75B12;
    text-transform: uppercase;
    margin-bottom: 10px;
    overflow-wrap: break-word;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-title {
    font-size: 20px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 8px;
    overflow-wrap: break-word;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-location {
    font-size: 14px;
    color: #999;
    margin-bottom: 12px;
    overflow-wrap: break-word;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-description {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 15px;
    overflow-wrap: break-word;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-link {
    color: #1F3A5F;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    transition: color 0.3s ease;
  }

  #sqe-case-studies-{{ section.id }} .sqe-case-study-link:hover {
    color: #C75B12;
  }

  @media (max-width: 768px) {
    #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid[data-columns="3"],
    #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid[data-columns="4"] {
      grid-template-columns: repeat(2, 1fr);
    }

    #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid[data-columns="2"] {
      grid-template-columns: 1fr;
    }

    #sqe-case-studies-{{ section.id }} .sqe-case-studies-heading {
      font-size: clamp(22px, 5vw, 28px);
    }
  }

  @media (max-width: 480px) {
    #sqe-case-studies-{{ section.id }} .sqe-case-studies-grid {
      grid-template-columns: 1fr !important;
    }

    #sqe-case-studies-{{ section.id }} .sqe-case-studies-heading {
      font-size: 22px;
    }

    #sqe-case-studies-{{ section.id }} .sqe-case-studies-subheading {
      font-size: 14px;
    }

    #sqe-case-studies-{{ section.id }} .sqe-case-study-image {
      height: 200px;
    }
  }
</style>


{% schema %}
{
  "name": "SQE Cases Studies",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Case Studies"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Case Studies"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real results from real clients"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#666666"
    }
  ],
  "blocks": [
    {
      "type": "case_study",
      "name": "Case Study",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Project Title"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "City, Country"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brief description"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Case Studies",
      "blocks": [
        { "type": "case_study" },
        { "type": "case_study" },
        { "type": "case_study" }
      ]
    }
  ]
}
{% endschema %}
