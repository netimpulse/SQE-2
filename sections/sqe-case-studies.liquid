{% comment %}
SQE Case Studies Section
Displays case study/project showcase cards with customizable layout options
{% endcomment %}

<section class="sqe-case-studies" id="sqe-case-studies-{{ section.id }}">
  <div class="case-studies-container">
    {% if section.settings.show_heading %}
      <div class="case-studies-header">
        {% if section.settings.heading %}
          <h2 class="case-studies-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading %}
          <p class="case-studies-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.show_filter and section.blocks.size > 0 %}
      <div class="case-studies-filters">
        <button class="filter-btn active" data-filter="all">All Projects</button>
        {% assign categories = '' | split: ',' %}
        {% for block in section.blocks %}
          {% if block.settings.category != '' and categories contains block.settings.category == false %}
            {% assign categories = categories | push: block.settings.category %}
          {% endif %}
        {% endfor %}
        {% for category in categories %}
          {% if category != '' %}
            <button class="filter-btn" data-filter="{{ category | slugify }}">{{ category }}</button>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}

    {% if section.settings.layout == 'slider' %}
      <div class="case-studies-slider">
        <div class="slider-wrapper">
          {% for block in section.blocks %}
            <div class="case-study-card slider-slide" data-category="{{ block.settings.category | slugify }}">
              {% if block.settings.image %}
                <div class="case-study-image">
                  {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.title }}
                </div>
              {% endif %}
              <div class="case-study-content">
                {% if block.settings.category %}
                  <span class="case-study-category">{{ block.settings.category }}</span>
                {% endif %}
                <h3 class="case-study-title">{{ block.settings.title }}</h3>
                {% if block.settings.location %}
                  <p class="case-study-location">📍 {{ block.settings.location }}</p>
                {% endif %}
                {% if block.settings.description %}
                  <p class="case-study-description">{{ block.settings.description }}</p>
                {% endif %}
                {% if block.settings.link_text and block.settings.link_url %}
                  <a href="{{ block.settings.link_url }}" class="case-study-link">{{ block.settings.link_text }}</a>
                {% endif %}
              </div>
            </div>
          {% endfor %}
        </div>
        <button class="slider-prev" aria-label="Previous">‹</button>
        <button class="slider-next" aria-label="Next">›</button>
      </div>
    {% else %}
      <div class="case-studies-grid" style="grid-template-columns: repeat({{ section.settings.columns }}, 1fr);">
        {% for block in section.blocks %}
          <div class="case-study-card" data-category="{{ block.settings.category | slugify }}">
            {% if block.settings.image %}
              <div class="case-study-image">
                {{ block.settings.image | image_url: width: 600 | image_tag: alt: block.settings.title }}
              </div>
            {% endif %}
            <div class="case-study-content">
              {% if block.settings.category %}
                <span class="case-study-category">{{ block.settings.category }}</span>
              {% endif %}
              <h3 class="case-study-title">{{ block.settings.title }}</h3>
              {% if block.settings.location %}
                <p class="case-study-location">📍 {{ block.settings.location }}</p>
              {% endif %}
              {% if block.settings.description %}
                <p class="case-study-description">{{ block.settings.description }}</p>
              {% endif %}
              {% if block.settings.link_text and block.settings.link_url %}
                <a href="{{ block.settings.link_url }}" class="case-study-link">{{ block.settings.link_text }}</a>
              {% endif %}
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .sqe-case-studies {
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_side }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_side }}px;
    background-color: {{ section.settings.background_color }};
  }

  .case-studies-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .case-studies-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .case-studies-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 16px 0;
  }

  .case-studies-subheading {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .case-studies-filters {
    display: flex;
    gap: 12px;
    justify-content: center;
    margin-bottom: 40px;
    flex-wrap: wrap;
  }

  .filter-btn {
    padding: 10px 20px;
    border: 2px solid {{ section.settings.primary_color }};
    background: white;
    color: {{ section.settings.primary_color }};
    border-radius: 4px;
    font-family: 'Inter', sans-serif;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .filter-btn:hover,
  .filter-btn.active {
    background: {{ section.settings.primary_color }};
    color: white;
  }

  .case-studies-grid {
    display: grid;
    gap: 32px;
    margin-bottom: 32px;
  }

  .case-studies-slider {
    position: relative;
    margin-bottom: 32px;
  }

  .slider-wrapper {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 16px 0;
  }

  .slider-slide {
    flex: 0 0 calc(100% / {{ section.settings.slider_items_per_view }});
    min-width: 0;
  }

  .slider-prev,
  .slider-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ section.settings.primary_color }};
    color: white;
    border: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .slider-prev:hover,
  .slider-next:hover {
    background: {{ section.settings.accent_color }};
  }

  .slider-prev {
    left: -22px;
  }

  .slider-next {
    right: -22px;
  }

  .case-study-card {
    background: white;
    border-radius: {{ section.settings.card_border_radius }}px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    display: flex;
    flex-direction: column;
    height: 100%;
  }

  .case-study-card:hover {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
    transform: translateY(-4px);
  }

  .case-study-card[style*="display: none"] {
    display: none;
  }

  .case-study-image {
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: #f0f0f0;
  }

  .case-study-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.3s ease;
  }

  .case-study-card:hover .case-study-image img {
    transform: scale(1.05);
  }

  .case-study-content {
    padding: 24px;
    flex-grow: 1;
    display: flex;
    flex-direction: column;
  }

  .case-study-category {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 8px;
    letter-spacing: 0.5px;
  }

  .case-study-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 24px;
    font-weight: 600;
    color: {{ section.settings.primary_color }};
    margin: 0 0 12px 0;
  }

  .case-study-location {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #999;
    margin: 0 0 12px 0;
  }

  .case-study-description {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #666;
    margin: 0 0 16px 0;
    flex-grow: 1;
  }

  .case-study-link {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: {{ section.settings.primary_color }};
    text-decoration: none;
    display: inline-block;
    padding: 10px 0;
    border-bottom: 2px solid {{ section.settings.accent_color }};
    transition: all 0.3s ease;
  }

  .case-study-link:hover {
    border-bottom-color: {{ section.settings.primary_color }};
  }

  @media (max-width: 768px) {
    .case-studies-grid {
      grid-template-columns: 1fr;
    }

    .case-studies-title {
      font-size: 32px;
    }

    .case-study-image {
      height: 220px;
    }

    .slider-prev,
    .slider-next {
      width: 36px;
      height: 36px;
      font-size: 20px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('sqe-case-studies-{{ section.id }}');
    if (!section) return;

    const filterBtns = section.querySelectorAll('.filter-btn');
    const cards = section.querySelectorAll('.case-study-card');

    if (filterBtns.length > 0) {
      filterBtns.forEach(btn => {
        btn.addEventListener('click', function() {
          const filter = this.getAttribute('data-filter');
          filterBtns.forEach(b => b.classList.remove('active'));
          this.classList.add('active');

          cards.forEach(card => {
            const category = card.getAttribute('data-category');
            if (filter === 'all' || category === filter) {
              card.style.display = '';
            } else {
              card.style.display = 'none';
            }
          });
        });
      });
    }

    const sliderPrev = section.querySelector('.slider-prev');
    const sliderNext = section.querySelector('.slider-next');
    const sliderWrapper = section.querySelector('.slider-wrapper');

    if (sliderPrev && sliderNext && sliderWrapper) {
      const scrollAmount = 320;

      sliderPrev.addEventListener('click', function() {
        sliderWrapper.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
      });

      sliderNext.addEventListener('click', function() {
        sliderWrapper.scrollBy({ left: scrollAmount, behavior: 'smooth' });
      });
    }
  });
</script>

{% schema %}
{
  "name": "Case Studies",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Case Studies"
    },
    {
      "type": "text",
