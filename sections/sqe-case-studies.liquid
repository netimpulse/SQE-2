      "max": 120,
      "step": 4,
      "label": "Padding top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 120,
      "step": 4,
      "label": "Padding bottom",
      "default": 60
