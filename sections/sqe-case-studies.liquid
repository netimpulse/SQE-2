{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns
  assign bg_color = section.settings.background_color
-%}

<section id="sqe-case-studies-{{ section.id }}" class="sqe-case-studies" style="background-color: {{ bg_color }};">
  <div class="sqe-case-studies-container">
    {% if heading != blank %}
      <h2 class="sqe-case-studies-heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="sqe-case-studies-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="sqe-case-studies-grid" data-columns="{{ columns }}">
      {% for block in section.blocks %}
        {% if block.type == 'case_study' %}
          <div class="sqe-case-study-card" {{ block.shopify_attributes }}>
            {% if block.settings.image != blank %}
              <div class="sqe-case-study-image">
                <img
                  src="{{ block.settings.image | image_url: width: 600 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                >
              </div>
            {% endif %}

            <div class="sqe-case-study-content">
              {% if block.settings.category != blank %}
                <span class="sqe-case-study-category">{{ block.settings.category }}</span>
              {% endif %}

              {% if block.settings.title != blank %}
                <h3 class="sqe-case-study-title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.location != blank %}
                <p class="sqe-case-study-location">{{ block.settings.location }}</p>
              {% endif %}

              {% if block.settings.description != blank %}
                <p class="sqe-case-study-description">{{ block.settings.description }}</p>
              {% endif %}

              {% if block.settings.link != blank %}
                <a href="{{ block.settings.link }}" class="sqe-case-study-link">Read More</a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #sqe-case-studies-{{ section.id }} {
    padding: 60px 20px;
  }

  .sqe-case-studies-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sqe-case-studies-heading {
    font-size: 36px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
    text-align: center;
  }

  .sqe-case-studies-subheading {
    font-size: 16px;
    color: #666;
    text-align: center;
    margin-bottom: 40px;
  }

  .sqe-case-studies-grid {
    display: grid;
    gap: 30px;
    margin-top: 40px;
  }

  .sqe-case-studies-grid[data-columns="2"] {
    grid-template-columns: repeat(2, 1fr);
  }

  .sqe-case-studies-grid[data-columns="3"] {
    grid-template-columns: repeat(3, 1fr);
  }

  .sqe-case-studies-grid[data-columns="4"] {
    grid-template-columns: repeat(4, 1fr);
  }

  .sqe-case-study-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sqe-case-study-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .sqe-case-study-image {
    width: 100%;
    height: 250px;
    overflow: hidden;
    background-color: #F2F4F7;
  }

  .sqe-case-study-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .sqe-case-study-content {
    padding: 25px;
  }

  .sqe-case-study-category {
    display: inline-block;
    font-size: 12px;
    font-weight: 600;
    color: #C75B12;
    text-transform: uppercase;
    margin-bottom: 10px;
  }

  .sqe-case-study-title {
    font-size: 20px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 8px;
  }

  .sqe-case-study-location {
    font-size: 14px;
    color: #999;
    margin-bottom: 12px;
  }

  .sqe-case-study-description {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 15px;
  }

  .sqe-case-study-link {
    color: #1F3A5F;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
  }

  .sqe-case-study-link:hover {
    color: #C75B12;
  }

  @media (max-width: 768px) {
    .sqe-case-studies-grid[data-columns="3"],
    .sqe-case-studies-grid[data-columns="4"] {
      grid-template-columns: repeat(2, 1fr);
    }

    .sqe-case-studies-grid[data-columns="2"] {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .sqe-case-studies-grid {
      grid-template-columns: 1fr !important;
    }

    .sqe-case-studies-heading {
      font-size: 24px;
    }
  }
</style>

<script>
  var caseStudiesSection = document.getElementById('sqe-case-studies-' + '{{ section.id }}');
  if (caseStudiesSection) {
    var cards = caseStudiesSection.querySelectorAll('.sqe-case-study-card');
    cards.forEach(function(card) {
      card.addEventListener('mouseenter', function() {
        this.style.boxShadow = '0 8px 16px rgba(0, 0, 0, 0.15)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.boxShadow = '0 2px 8px rgba(0, 0, 0, 0.1)';
      });
    });
  }
</script>

{% schema %}
{
  "name": "SQE Case Studies",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Case Studies"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Real results from real clients"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "case_study",
      "name": "Case Study",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Project Title"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location",
          "default": "City, Country"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brief description"
        },
        {
          "type": "text",
          "id": "category",
          "label": "Category",
          "default": "Category"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Case Studies",
      "blocks": [
        { "type": "case_study" },
        { "type": "case_study" },
        { "type": "case_study" }
      ]
    }
  ]
}
{% endschema %}