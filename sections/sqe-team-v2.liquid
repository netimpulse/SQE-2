{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns | default: 4
-%}

<section id="section-{{ section.id }}" class="sqe-team-v2">
  <div class="team-container">
    {% if heading %}
      <h2 class="team-heading">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="team-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="team-cards" style="grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));">
      {% for block in section.blocks %}
        <div class="team-card" data-member-id="{{ block.id }}" data-member-name="{{ block.settings.name | escape }}" data-member-title="{{ block.settings.title | escape }}" data-member-bio="{{ block.settings.bio | escape }}" data-member-expertise="{{ block.settings.expertise | escape }}" data-member-linkedin="{{ block.settings.linkedin_url | escape }}" data-member-email="{{ block.settings.email_address | escape }}" data-member-years="{{ block.settings.years_experience }}" {% if block.settings.photo %}data-member-photo="{{ block.settings.photo | img_url: '400x400' }}"{% endif %}>
          <div class="card-image-wrapper">
            {% if block.settings.photo %}
              <img src="{{ block.settings.photo | img_url: '400x400' }}" alt="{{ block.settings.name }}" class="card-image">
            {% else %}
              <div class="card-image-placeholder">No image</div>
            {% endif %}
          </div>
          <div class="card-content">
            <h3 class="member-name">{{ block.settings.name }}</h3>
            <p class="member-title">{{ block.settings.title }}</p>
            <button class="card-expand-btn" data-member-id="{{ block.id }}">View Profile</button>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<div id="member-modal-{{ section.id }}" class="member-modal" style="display: none;">
  <div class="modal-overlay"></div>
  <div class="modal-content">
    <button class="modal-close">Close</button>
    <div class="modal-body">
      <img src="" alt="" class="modal-image">
      <div class="modal-info">
        <h2 class="modal-name"></h2>
        <p class="modal-title"></p>
        <p class="modal-bio"></p>
        <div class="modal-meta">
          <p><strong>Expertise:</strong> <span class="modal-expertise"></span></p>
          <p><strong>Experience:</strong> <span class="modal-years"></span> years</p>
        </div>
        <div class="modal-links">
          <a href="" class="modal-linkedin" target="_blank" style="display: none;">LinkedIn</a>
          <a href="" class="modal-email" style="display: none;">Email</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  #section-{{ section.id }} {
    padding: 60px 20px;
    background-color: #FFFFFF;
  }

  .team-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .team-heading {
    font-size: 48px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
    text-align: center;
  }

  .team-subheading {
    font-size: 18px;
    color: #333333;
    text-align: center;
    margin-bottom: 50px;
  }

  .team-cards {
    display: grid;
    gap: 30px;
    margin-bottom: 40px;
  }

  .team-card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  .team-card:hover {
    box-shadow: 0 8px 24px rgba(31, 58, 95, 0.15);
    transform: translateY(-5px);
  }

  .card-image-wrapper {
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: #F2F4F7;
  }

  .card-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .card-image-placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #F2F4F7;
    color: #999;
    font-size: 14px;
  }

  .card-content {
    padding: 25px;
  }

  .member-name {
    font-size: 20px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 5px;
  }

  .member-title {
    font-size: 14px;
    color: #C75B12;
    margin-bottom: 15px;
    font-weight: 600;
  }

  .card-expand-btn {
    width: 100%;
    padding: 12px;
    background-color: #1F3A5F;
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  .card-expand-btn:hover {
    background-color: #142a45;
  }

  .member-modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
  }

  .modal-overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
  }

  .modal-content {
    position: relative;
    width: 90%;
    max-width: 700px;
    height: auto;
    max-height: 90vh;
    background: white;
    border-radius: 8px;
    margin: 5vh auto;
    padding: 40px;
    overflow-y: auto;
    z-index: 1001;
  }

  .modal-close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: #F2F4F7;
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-weight: 600;
    color: #333333;
  }

  .modal-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 20px;
  }

  .modal-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 8px;
  }

  .modal-info {
    padding: 20px 0;
  }

  .modal-name {
    font-size: 32px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
  }

  .modal-title {
    font-size: 18px;
    color: #C75B12;
    font-weight: 600;
    margin-bottom: 20px;
  }

  .modal-bio {
    font-size: 16px;
    color: #333333;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .modal-meta {
    background: #F2F4F7;
    padding: 20px;
    border-radius: 6px;
    margin-bottom: 20px;
  }

  .modal-meta p {
    font-size: 14px;
    color: #333333;
    margin-bottom: 8px;
  }

  .modal-links {
    display: flex;
    gap: 15px;
  }

  .modal-linkedin,
  .modal-email {
    flex: 1;
    padding: 12px;
    text-align: center;
    background-color: #1F3A5F;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
  }

  .modal-linkedin:hover,
  .modal-email:hover {
    background-color: #142a45;
  }

  @media (max-width: 768px) {
    .team-cards {
      grid-template-columns: 1fr;
    }
    .modal-body {
      grid-template-columns: 1fr;
    }
    .modal-content {
      width: 95%;
      padding: 25px;
    }
    .team-heading {
      font-size: 32px;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var modal = document.getElementById('member-modal-' + sectionId);
    var modalOverlay = modal.querySelector('.modal-overlay');
    var modalClose = modal.querySelector('.modal-close');
    var cards = document.querySelectorAll('#section-' + sectionId + ' .team-card');

    cards.forEach(function(card) {
      var btn = card.querySelector('.card-expand-btn');
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        var name = card.getAttribute('data-member-name');
        var title = card.getAttribute('data-member-title');
        var bio = card.getAttribute('data-member-bio');
        var expertise = card.getAttribute('data-member-expertise');
        var years = card.getAttribute('data-member-years');
        var linkedin = card.getAttribute('data-member-linkedin');
        var email = card.getAttribute('data-member-email');
        var photo = card.getAttribute('data-member-photo');

        modal.querySelector('.modal-name').textContent = name;
        modal.querySelector('.modal-title').textContent = title;
        modal.querySelector('.modal-bio').textContent = bio;
        modal.querySelector('.modal-expertise').textContent = expertise;
        modal.querySelector('.modal-years').textContent = years;

        if (photo) {
          modal.querySelector('.modal-image').src = photo;
        }

        var linkedinLink = modal.querySelector('.modal-linkedin');
        var emailLink = modal.querySelector('.modal-email');

        if (linkedin) {
          linkedinLink.href = linkedin;
          linkedinLink.style.display = 'block';
        } else {
          linkedinLink.style.display = 'none';
        }

        if (email) {
          emailLink.href = 'mailto:' + email;
          emailLink.style.display = 'block';
        } else {
          emailLink.style.display = 'none';
        }

        modal.style.display = 'block';
      });
    });

    modalClose.addEventListener('click', function() {
      modal.style.display = 'none';
    });

    modalOverlay.addEventListener('click', function() {
      modal.style.display = 'none';
    });
  })();
</script>

{% schema %}
{
  "name": "Team Members v2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Team"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Meet the experts"
    },
    {
      "type": "number",
      "id": "columns",
      "label": "Columns",
      "default": 4,
      "min": 1,
      "max": 6
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Job Title"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Biography"
        },
        {
          "type": "text",
          "id": "expertise",
          "label": "Expertise"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn URL"
        },
        {
          "type": "text",
          "id": "email_address",
          "label": "Email"
        },
        {
          "type": "number",
          "id": "years_experience",
          "label": "Years of Experience",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Members v2"
    }
  ]
}
{% endschema %}
