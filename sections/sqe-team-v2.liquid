{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns | default: 4
-%}

<section id="sqe-team-v2-{{ section.id }}" class="sqe-team-v2">
  <div class="sqe-team-v2__container">
    {% if heading %}
      <h2 class="sqe-team-v2__label">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="sqe-team-v2__subheading">{{ subheading }}</p>
    {% endif %}

    <div class="sqe-team-v2__grid">
      {% for block in section.blocks %}
        <div class="sqe-team-v2__card" data-member-id="{{ block.id }}" data-member-name="{{ block.settings.name | escape }}" data-member-title="{{ block.settings.title | escape }}" data-member-bio="{{ block.settings.bio | escape }}" data-member-expertise="{{ block.settings.expertise | escape }}" data-member-linkedin="{{ block.settings.linkedin_url | escape }}" data-member-email="{{ block.settings.email_address | escape }}" data-member-years="{{ block.settings.years_experience }}" {% if block.settings.photo %}data-member-photo="{{ block.settings.photo | image_url: width: 400 }}"{% endif %}>
          <div class="sqe-team-v2__image-wrapper">
            {% if block.settings.photo %}
              <img src="{{ block.settings.photo | image_url: width: 400 }}" alt="{{ block.settings.name }}" class="sqe-team-v2__image">
            {% else %}
              <div class="sqe-team-v2__placeholder">No image</div>
            {% endif %}
          </div>
          <div class="sqe-team-v2__content">
            <h3 class="sqe-team-v2__name">{{ block.settings.name }}</h3>
            <p class="sqe-team-v2__title">{{ block.settings.title }}</p>
            <button class="sqe-team-v2__btn" type="button" data-member-id="{{ block.id }}">View Profile</button>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<div id="sqe-team-v2-modal-{{ section.id }}" class="sqe-team-v2__modal" hidden>
  <div class="sqe-team-v2__overlay"></div>
  <div class="sqe-team-v2__modal-content">
    <button class="sqe-team-v2__modal-close" type="button" aria-label="Close">Close</button>
    <div class="sqe-team-v2__modal-body">
      <img src="" alt="" class="sqe-team-v2__modal-image">
      <div class="sqe-team-v2__modal-info">
        <h2 class="sqe-team-v2__modal-name"></h2>
        <p class="sqe-team-v2__modal-title"></p>
        <p class="sqe-team-v2__modal-bio"></p>
        <div class="sqe-team-v2__modal-meta">
          <p><strong>Expertise:</strong> <span class="sqe-team-v2__modal-expertise"></span></p>
          <p><strong>Experience:</strong> <span class="sqe-team-v2__modal-years"></span> years</p>
        </div>
        <div class="sqe-team-v2__modal-links">
          <a href="" class="sqe-team-v2__modal-link sqe-team-v2__modal-linkedin" target="_blank" rel="noopener noreferrer" hidden>LinkedIn</a>
          <a href="" class="sqe-team-v2__modal-link sqe-team-v2__modal-email" hidden>Email</a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  :root {
    --sqe-v2-primary: #1F3A5F;
    --sqe-v2-primary-dark: #142a45;
    --sqe-v2-accent: #C75B12;
    --sqe-v2-bg-light: #F2F4F7;
    --sqe-v2-text: #333333;
    --sqe-v2-text-muted: #999;
  }

  #sqe-team-v2-{{ section.id }} {
    padding: 60px 20px;
    background-color: #FFFFFF;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__label {
    font-size: 48px;
    font-weight: 700;
    color: var(--sqe-v2-primary);
    margin-bottom: 10px;
    text-align: center;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__subheading {
    font-size: 18px;
    color: var(--sqe-v2-text);
    text-align: center;
    margin-bottom: 50px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__grid {
    display: grid;
    gap: 30px;
    margin-bottom: 40px;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__card {
    background: white;
    border-radius: 8px;
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: all 0.3s ease;
    cursor: pointer;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__card:hover {
    box-shadow: 0 8px 24px rgba(31, 58, 95, 0.15);
    transform: translateY(-5px);
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__image-wrapper {
    width: 100%;
    height: 280px;
    overflow: hidden;
    background: var(--sqe-v2-bg-light);
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--sqe-v2-bg-light);
    color: var(--sqe-v2-text-muted);
    font-size: 14px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__content {
    padding: 25px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__name {
    font-size: 20px;
    font-weight: 700;
    color: var(--sqe-v2-primary);
    margin-bottom: 5px;
    overflow-wrap: break-word;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__title {
    font-size: 14px;
    color: var(--sqe-v2-accent);
    margin-bottom: 15px;
    font-weight: 600;
    overflow-wrap: break-word;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__btn {
    width: 100%;
    padding: 12px;
    background-color: var(--sqe-v2-primary);
    color: white;
    border: none;
    border-radius: 6px;
    font-weight: 600;
    cursor: pointer;
    transition: background-color 0.3s ease;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__btn:hover {
    background-color: var(--sqe-v2-primary-dark);
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1000;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.5);
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-content {
    position: relative;
    width: 90%;
    max-width: 700px;
    height: auto;
    max-height: 90vh;
    background: white;
    border-radius: 8px;
    margin: 5vh auto;
    padding: 40px;
    overflow-y: auto;
    z-index: 1001;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-close {
    position: absolute;
    top: 15px;
    right: 15px;
    background: var(--sqe-v2-bg-light);
    border: none;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    cursor: pointer;
    font-weight: 600;
    color: var(--sqe-v2-text);
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 30px;
    margin-top: 20px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-image {
    width: 100%;
    height: 400px;
    object-fit: cover;
    border-radius: 8px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-info {
    padding: 20px 0;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-name {
    font-size: 32px;
    font-weight: 700;
    color: var(--sqe-v2-primary);
    margin-bottom: 10px;
    overflow-wrap: break-word;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-title {
    font-size: 18px;
    color: var(--sqe-v2-accent);
    font-weight: 600;
    margin-bottom: 20px;
    overflow-wrap: break-word;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-bio {
    font-size: 16px;
    color: var(--sqe-v2-text);
    line-height: 1.6;
    margin-bottom: 20px;
    overflow-wrap: break-word;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-meta {
    background: var(--sqe-v2-bg-light);
    padding: 20px;
    border-radius: 6px;
    margin-bottom: 20px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-meta p {
    font-size: 14px;
    color: var(--sqe-v2-text);
    margin-bottom: 8px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-links {
    display: flex;
    gap: 15px;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-link {
    flex: 1;
    padding: 12px;
    text-align: center;
    background-color: var(--sqe-v2-primary);
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-link:hover {
    background-color: var(--sqe-v2-primary-dark);
  }

  @media (max-width: 768px) {
    #sqe-team-v2-{{ section.id }} .sqe-team-v2__grid {
      grid-template-columns: 1fr;
    }

    #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-body {
      grid-template-columns: 1fr;
    }

    #sqe-team-v2-{{ section.id }} .sqe-team-v2__modal-content {
      width: 95%;
      padding: 25px;
    }

    #sqe-team-v2-{{ section.id }} .sqe-team-v2__label {
      font-size: 32px;
    }
  }
</style>

<script>
  (function() {
    const sectionId = '{{ section.id }}';
    const sectionEl = document.getElementById('sqe-team-v2-' + sectionId);
    if (!sectionEl) return;

    const modal = document.getElementById('sqe-team-v2-modal-' + sectionId);
    const modalOverlay = modal.querySelector('.sqe-team-v2__overlay');
    const modalClose = modal.querySelector('.sqe-team-v2__modal-close');
    const cards = sectionEl.querySelectorAll('.sqe-team-v2__card');

    function closeModal() {
      modal.setAttribute('hidden', '');
    }

    function openModal(cardEl) {
      const name = cardEl.getAttribute('data-member-name');
      const title = cardEl.getAttribute('data-member-title');
      const bio = cardEl.getAttribute('data-member-bio');
      const expertise = cardEl.getAttribute('data-member-expertise');
      const years = cardEl.getAttribute('data-member-years');
      const linkedin = cardEl.getAttribute('data-member-linkedin');
      const email = cardEl.getAttribute('data-member-email');
      const photo = cardEl.getAttribute('data-member-photo');

      modal.querySelector('.sqe-team-v2__modal-name').textContent = name;
      modal.querySelector('.sqe-team-v2__modal-title').textContent = title;
      modal.querySelector('.sqe-team-v2__modal-bio').textContent = bio;
      modal.querySelector('.sqe-team-v2__modal-expertise').textContent = expertise;
      modal.querySelector('.sqe-team-v2__modal-years').textContent = years;

      const imgEl = modal.querySelector('.sqe-team-v2__modal-image');
      if (photo) {
        imgEl.src = photo;
        imgEl.alt = name;
      } else {
        imgEl.src = '';
        imgEl.alt = '';
      }

      const linkedinLink = modal.querySelector('.sqe-team-v2__modal-linkedin');
      const emailLink = modal.querySelector('.sqe-team-v2__modal-email');

      if (linkedin) {
        linkedinLink.href = linkedin;
        linkedinLink.removeAttribute('hidden');
      } else {
        linkedinLink.setAttribute('hidden', '');
      }

      if (email) {
        emailLink.href = 'mailto:' + email;
        emailLink.removeAttribute('hidden');
      } else {
        emailLink.setAttribute('hidden', '');
      }

      modal.removeAttribute('hidden');
    }

    cards.forEach(function(card) {
      const btn = card.querySelector('.sqe-team-v2__btn');
      btn.addEventListener('click', function(e) {
        e.stopPropagation();
        openModal(card);
      });
    });

    modalClose.addEventListener('click', closeModal);
    modalOverlay.addEventListener('click', closeModal);

    document.addEventListener('keydown', function(e) {
      if (e.key === 'Escape' && !modal.hasAttribute('hidden')) {
        closeModal();
      }
    });
  })();
</script>

{% schema %}
{
  "name": "Team Members v2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Team"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Meet the experts"
    },
    {
      "type": "number",
      "id": "columns",
      "label": "Columns",
      "default": 4,
      "min": 1,
      "max": 6
    }
  ],
  "blocks": [
    {
      "type": "team_member",
      "name": "Team Member",
      "settings": [
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Photo"
        },
        {
          "type": "text",
          "id": "name",
          "label": "Name"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Job Title"
        },
        {
          "type": "textarea",
          "id": "bio",
          "label": "Biography"
        },
        {
          "type": "text",
          "id": "expertise",
          "label": "Expertise"
        },
        {
          "type": "url",
          "id": "linkedin_url",
          "label": "LinkedIn URL"
        },
        {
          "type": "text",
          "id": "email_address",
          "label": "Email"
        },
        {
          "type": "number",
          "id": "years_experience",
          "label": "Years of Experience",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Team Members v2"
    }
  ]
}
{% endschema %}
