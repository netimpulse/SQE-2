{%- liquid
  assign menu = section.settings.menu
  assign logo_pos_x = section.settings.logo_pos_x
  assign logo_pos_y = section.settings.logo_pos_y
  assign nav_align = section.settings.nav_alignment
  assign menu_nudge_x = section.settings.menu_nudge_x
  assign menu_pos_y = section.settings.menu_pos_y
  assign show_search = section.settings.show_search
  assign show_account = section.settings.show_account
  assign show_cart = section.settings.show_cart
  assign show_cta = section.settings.show_cta
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign cta_color = section.settings.cta_color
  assign cta_bg = section.settings.cta_bg_color
  assign cta_font_size = section.settings.cta_font_size
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign sticky_type = section.settings.sticky_header_type
  assign header_height = section.settings.header_height
  assign show_border = section.settings.show_border
  assign menu_type = section.settings.menu_type_desktop
  assign hamburger_pos_x = section.settings.hamburger_pos_x
  assign hamburger_pos_y = section.settings.hamburger_pos_y
  assign actions_pos_x = section.settings.actions_pos_x
  assign actions_pos_y = section.settings.actions_pos_y
  assign mobile_logo_size = section.settings.mobile_logo_size
  assign mobile_icon_size = section.settings.mobile_icon_size
  assign menu_font_size = section.settings.menu_font_size
  assign menu_color = section.settings.menu_color
  assign menu_active_color = section.settings.menu_active_color
  assign menu_hover_color = section.settings.menu_hover_color
  assign menu_bold = section.settings.menu_bold
  assign search_pos_x = section.settings.search_pos_x
  assign search_pos_y = section.settings.search_pos_y
  assign account_pos_x = section.settings.account_pos_x
  assign account_pos_y = section.settings.account_pos_y
  assign cart_pos_x = section.settings.cart_pos_x
  assign cart_pos_y = section.settings.cart_pos_y
  assign cta_pos_x = section.settings.cta_pos_x
  assign cta_pos_y = section.settings.cta_pos_y

  assign menu_weight = '400'
  if menu_bold
    assign menu_weight = '700'
  endif
-%}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if menu_type == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

<style>
  /* ===== BASE (always present) ===== */
  #sqe-header-{{ section.id }} {
    background-color: {{ bg_color }};
    color: {{ text_color }};
    z-index: 1000;
  }

  /* ===== STICKY: controlled by data-sticky attribute (NO Liquid conditionals) ===== */
  #sqe-header-{{ section.id }}[data-sticky="none"] {
    position: relative !important;
  }
  #sqe-header-{{ section.id }}[data-sticky="always"],
  #sqe-header-{{ section.id }}[data-sticky="on-scroll-up"] {
    position: fixed !important;
    top: 0; left: 0; right: 0;
  }
  #sqe-header-{{ section.id }}.sqe-header-hidden {
    transform: translateY(-100%);
  }
  #sqe-header-{{ section.id }}.sqe-header-animate {
    transition: transform 0.35s ease;
  }

  /* Spacer: visible only when sticky */
  .sqe-header-spacer--{{ section.id }}[data-show="true"] { display: block; }
  .sqe-header-spacer--{{ section.id }}[data-show="false"] { display: none; }

  #sqe-header-{{ section.id }} .sqe-header__inner {
    display: flex;
    align-items: center;
    height: var(--sqe-h-height, 80px);
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }

  /* ===== LOGO ===== */
  #sqe-header-{{ section.id }} .sqe-header__logo-wrap {
    position: absolute;
    left: var(--sqe-logo-x, 2%);
    top: 50%;
    transform: translateY(-50%) translateY(var(--sqe-logo-y, 0px));
    z-index: 10;
  }

  #sqe-header-{{ section.id }} .sqe-header__logo-wrap a {
    display: flex; align-items: center; text-decoration: none; color: inherit;
  }

  #sqe-header-{{ section.id }} .sqe-header__logo-wrap img {
    max-height: calc(var(--sqe-h-height, 80px) - 20px);
    width: auto;
  }

  #sqe-header-{{ section.id }} .sqe-header__logo-wrap .h2 {
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 700; font-size: 1.4rem; margin: 0; color: inherit; white-space: nowrap;
  }

  /* ===== NAVIGATION: controlled by data-align attribute (NO Liquid conditionals) ===== */
  #sqe-header-{{ section.id }} .sqe-header__nav-wrap {
    position: absolute;
    top: 50%;
    z-index: 5;
    display: flex;
  }

  /* LEFT alignment */
  #sqe-header-{{ section.id }} .sqe-header__nav-wrap[data-align="left"] {
    left: 2rem !important;
    right: auto !important;
    transform: translateY(-50%) translateX(var(--sqe-nudge-x, 0px)) translateY(var(--sqe-nudge-y, 0px));
  }

  /* CENTER alignment */
  #sqe-header-{{ section.id }} .sqe-header__nav-wrap[data-align="center"] {
    left: 50% !important;
    right: auto !important;
    transform: translateX(-50%) translateY(-50%) translateX(var(--sqe-nudge-x, 0px)) translateY(var(--sqe-nudge-y, 0px));
  }

  /* RIGHT alignment */
  #sqe-header-{{ section.id }} .sqe-header__nav-wrap[data-align="right"] {
    left: auto !important;
    right: 2rem !important;
    transform: translateY(-50%) translateX(var(--sqe-nudge-x, 0px)) translateY(var(--sqe-nudge-y, 0px));
  }

  #sqe-header-{{ section.id }} .sqe-header__nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  #sqe-header-{{ section.id }} .sqe-header__nav-item a {
    text-decoration: none;
    color: {{ menu_color }};
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: {{ menu_weight }};
    font-size: {{ menu_font_size }}px;
    letter-spacing: 0.02em;
    padding: 0.5rem 0.85rem;
    transition: color 0.2s ease, background-color 0.2s ease;
    border-radius: 4px;
    display: block;
    white-space: nowrap;
  }

  #sqe-header-{{ section.id }} .sqe-header__nav-item a:hover {
    color: {{ menu_hover_color }};
    background-color: rgba(242, 183, 5, 0.08);
  }

  #sqe-header-{{ section.id }} .sqe-header__nav-item--active a {
    color: {{ menu_active_color }};
  }

  /* ===== DROPDOWN SUBMENU ===== */
  #sqe-header-{{ section.id }} .sqe-header__nav-item {
    position: relative;
  }

  #sqe-header-{{ section.id }} .sqe-header__dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    background-color: {{ bg_color }};
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 6px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    padding: 0.5rem 0;
    z-index: 100;
    list-style: none;
    margin: 0;
  }

  #sqe-header-{{ section.id }} .sqe-header__nav-item:hover .sqe-header__dropdown {
    display: block;
  }

  #sqe-header-{{ section.id }} .sqe-header__dropdown li a {
    display: block;
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: {{ menu_color }};
  }

  #sqe-header-{{ section.id }} .sqe-header__dropdown li a:hover {
    color: {{ menu_hover_color }};
  }

  /* ===== ACTIONS GROUP ===== */
  #sqe-header-{{ section.id }} .sqe-header__actions {
    position: absolute;
    right: {{ actions_pos_x }}%;
    top: 50%;
    transform: translateY(-50%) translateY({{ actions_pos_y }}px);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    z-index: 10;
  }

  #sqe-header-{{ section.id }} .sqe-header__icon-wrap {
    position: relative;
  }

  #sqe-header-{{ section.id }} .sqe-header__icon-wrap--search {
    top: {{ search_pos_y }}px;
    left: {{ search_pos_x }}px;
  }

  #sqe-header-{{ section.id }} .sqe-header__icon-wrap--account {
    top: {{ account_pos_y }}px;
    left: {{ account_pos_x }}px;
  }

  #sqe-header-{{ section.id }} .sqe-header__icon-wrap--cart {
    top: {{ cart_pos_y }}px;
    left: {{ cart_pos_x }}px;
  }

  #sqe-header-{{ section.id }} .sqe-header__cta-wrap {
    position: relative;
    top: {{ cta_pos_y }}px;
    left: {{ cta_pos_x }}px;
    margin-left: 0.5rem;
  }

  #sqe-header-{{ section.id }} .sqe-header__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: {{ cta_bg }};
    color: {{ cta_color }};
    text-decoration: none;
    padding: 0.6rem 1.4rem;
    border-radius: 4px;
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 700;
    font-size: {{ cta_font_size }}px;
    letter-spacing: 0.03em;
    transition: opacity 0.2s ease, transform 0.15s ease;
    white-space: nowrap;
  }

  #sqe-header-{{ section.id }} .sqe-header__cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* ===== ICONS ===== */
  #sqe-header-{{ section.id }} .header__icon {
    color: {{ text_color }};
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
    position: relative;
  }

  #sqe-header-{{ section.id }} .header__icon:hover {
    color: {{ menu_hover_color }};
  }

  #sqe-header-{{ section.id }} .header__icon svg,
  #sqe-header-{{ section.id }} .header__icon .svg-wrapper svg {
    width: 22px;
    height: 22px;
  }

  #sqe-header-{{ section.id }} .sqe-header__cart-icon-custom {
    width: 24px;
    height: 24px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #sqe-header-{{ section.id }} .cart-count-bubble {
    position: absolute;
    top: 4px;
    right: 0;
    background-color: {{ cta_bg }};
    color: {{ cta_color }};
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1;
  }

  /* ===== HAMBURGER ===== */
  #sqe-header-{{ section.id }} .sqe-header__hamburger-wrap {
    display: none;
    position: absolute;
    left: {{ hamburger_pos_x }}%;
    top: 50%;
    transform: translateY(-50%) translateY({{ hamburger_pos_y }}px);
    z-index: 10;
  }

  /* ===== SEARCH - INLINE HEADER BAR ===== */
  #sqe-header-{{ section.id }} .sqe-search-bar {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: {{ bg_color }};
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 0 2rem;
  }

  #sqe-header-{{ section.id }} .sqe-search-bar.sqe-search-open {
    display: flex;
  }

  #sqe-header-{{ section.id }} .sqe-search-bar form {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 600px;
    border: 2px solid {{ text_color }};
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
  }

  #sqe-header-{{ section.id }} .sqe-search-bar input[type="search"] {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.6rem 1rem;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    background: transparent;
    color: {{ text_color }};
  }

  #sqe-header-{{ section.id }} .sqe-search-bar button[type="submit"] {
    background: none;
    border: none;
    padding: 0.6rem 1rem;
    cursor: pointer;
    color: {{ text_color }};
    display: flex;
    align-items: center;
  }

  #sqe-header-{{ section.id }} .sqe-search-bar button[type="submit"] svg {
    width: 20px;
    height: 20px;
  }

  #sqe-header-{{ section.id }} .sqe-search-close {
    background: none;
    border: none;
    padding: 0.5rem;
    margin-left: 1rem;
    cursor: pointer;
    color: {{ text_color }};
    display: flex;
    align-items: center;
  }

  #sqe-header-{{ section.id }} .sqe-search-close svg {
    width: 24px;
    height: 24px;
  }

  /* ===== MOBILE DRAWER ===== */
  #sqe-header-{{ section.id }} header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }

  #sqe-header-{{ section.id }} .menu-drawer-container {
    display: flex;
  }

  #sqe-header-{{ section.id }} .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /* DRAWER MODE: controlled by data-menu-type attribute */
  #sqe-header-{{ section.id }}[data-menu-type="drawer"] .sqe-header__nav-wrap {
    display: none !important;
  }
  #sqe-header-{{ section.id }}[data-menu-type="drawer"] .sqe-header__hamburger-wrap {
    display: flex;
  }

  /* BORDER: controlled by data-border attribute */
  #sqe-header-{{ section.id }}[data-border="true"] {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  #sqe-header-{{ section.id }}[data-border="false"] {
    border-bottom: none;
  }

  /* ===== MOBILE (max-width: 989px) ===== */
  @media screen and (max-width: 989px) {
    #sqe-header-{{ section.id }} .sqe-header__inner {
      height: 60px;
      padding: 0 1rem;
    }

    #sqe-header-{{ section.id }} .sqe-header__nav-wrap {
      display: none;
    }

    #sqe-header-{{ section.id }} .sqe-header__hamburger-wrap {
      display: flex;
      left: 1%;
    }

    #sqe-header-{{ section.id }} .sqe-header__logo-wrap {
      left: 50%;
      transform: translateX(-50%) translateY(-50%);
    }

    #sqe-header-{{ section.id }} .sqe-header__logo-wrap img {
      max-height: {{ mobile_logo_size }}px;
    }

    #sqe-header-{{ section.id }} .sqe-header__logo-wrap .h2 {
      font-size: 1.1rem;
    }

    #sqe-header-{{ section.id }} .sqe-header__actions {
      right: 1%;
      transform: translateY(-50%);
      gap: 0;
    }

    #sqe-header-{{ section.id }} .sqe-header__cta-wrap {
      display: none;
    }

    #sqe-header-{{ section.id }} .header__icon {
      width: {{ mobile_icon_size }}px;
      height: {{ mobile_icon_size }}px;
    }

    #sqe-header-{{ section.id }} .header__icon svg,
    #sqe-header-{{ section.id }} .header__icon .svg-wrapper svg {
      width: {{ mobile_icon_size | minus: 8 }}px;
      height: {{ mobile_icon_size | minus: 8 }}px;
    }

    #sqe-header-{{ section.id }} .sqe-header__cart-icon-custom {
      width: {{ mobile_icon_size | minus: 6 }}px;
      height: {{ mobile_icon_size | minus: 6 }}px;
    }

    #sqe-header-{{ section.id }} .sqe-header__icon-wrap--search,
    #sqe-header-{{ section.id }} .sqe-header__icon-wrap--account,
    #sqe-header-{{ section.id }} .sqe-header__icon-wrap--cart {
      top: 0;
      left: 0;
    }

    #sqe-header-{{ section.id }} .cart-count-bubble {
      width: 16px;
      height: 16px;
      font-size: 0.6rem;
      top: 2px;
      right: -2px;
    }

    #sqe-header-{{ section.id }} .sqe-search-bar {
      padding: 0 1rem;
    }

    #sqe-header-{{ section.id }} .sqe-search-bar form {
      max-width: none;
    }
  }

  /* ===== SMALL MOBILE (max-width: 480px) ===== */
  @media screen and (max-width: 480px) {
    #sqe-header-{{ section.id }} .sqe-header__inner {
      height: 56px;
      padding: 0 0.75rem;
    }

    #sqe-header-{{ section.id }} .header__icon {
      width: 36px;
      height: 36px;
    }

    #sqe-header-{{ section.id }} .header__icon svg,
    #sqe-header-{{ section.id }} .header__icon .svg-wrapper svg {
      width: 18px;
      height: 18px;
    }

    #sqe-header-{{ section.id }} .sqe-header__cart-icon-custom {
      width: 20px;
      height: 20px;
    }

    #sqe-header-{{ section.id }} .sqe-header__logo-wrap img {
      max-height: 30px;
    }
  }

  /* ===== TABLET (990-1200px) ===== */
  @media screen and (min-width: 990px) and (max-width: 1200px) {
    #sqe-header-{{ section.id }} .sqe-header__nav-item a {
      font-size: {{ menu_font_size | minus: 2 }}px;
      padding: 0.4rem 0.5rem;
    }

    #sqe-header-{{ section.id }} .sqe-header__cta {
      padding: 0.5rem 1rem;
      font-size: {{ cta_font_size | minus: 1 }}px;
    }
  }
</style>

<section id="sqe-header-{{ section.id }}" class="sqe-header" data-sticky="{{ sticky_type }}" data-menu-type="{{ menu_type }}" data-border="{{ show_border }}" style="--sqe-h-height: {{ header_height }}px; --sqe-logo-x: {{ logo_pos_x }}%; --sqe-logo-y: {{ logo_pos_y }}px;">
  <div class="sqe-header__inner">

    {%- comment -%} Mobile hamburger / drawer {%- endcomment -%}
    <div class="sqe-header__hamburger-wrap">
      {%- if menu != blank -%}
        {%- render 'header-drawer' -%}
      {%- endif -%}
    </div>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="sqe-header__logo-wrap">
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading" style="margin:0">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo motion-reduce',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    </div>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="sqe-header__nav-wrap" data-align="{{ nav_align }}" aria-label="Main navigation" style="--sqe-nudge-x: {{ menu_nudge_x }}px; --sqe-nudge-y: {{ menu_pos_y }}px;">
      {%- if menu != blank -%}
        <ul class="sqe-header__nav-list" role="list">
          {%- for link in menu.links -%}
            <li class="sqe-header__nav-item{% if link.current %} sqe-header__nav-item--active{% endif %}">
              <a
                href="{{ link.url }}"
                {% if link.current %} aria-current="page"{% endif %}
              >
                {{ link.title | escape }}
              </a>
              {%- if link.links != blank -%}
                <ul class="sqe-header__dropdown">
                  {%- for childlink in link.links -%}
                    <li>
                      <a
                        href="{{ childlink.url }}"
                        {% if childlink.current %} aria-current="page"{% endif %}
                      >
                        {{ childlink.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    {%- comment -%} Actions: Search, Account, Cart, CTA {%- endcomment -%}
    <div class="sqe-header__actions">

      {%- if show_search -%}
        <div class="sqe-header__icon-wrap sqe-header__icon-wrap--search">
          <button class="header__icon header__icon--search link focus-inset" aria-label="Search" data-sqe-search-toggle type="button" style="background:none;border:none;cursor:pointer;">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- if show_account and shop.customer_accounts_enabled -%}
        <div class="sqe-header__icon-wrap sqe-header__icon-wrap--account">
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="header__icon header__icon--account link focus-inset"
            rel="nofollow"
          >
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
            <span class="visually-hidden">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo 'customer.log_in' | t
                endif
              -%}
            </span>
          </a>
        </div>
      {%- endif -%}

      {%- if show_cart -%}
        <div class="sqe-header__icon-wrap sqe-header__icon-wrap--cart">
          <a href="{{ routes.cart_url }}" class="header__icon header__icon--cart link focus-inset" id="cart-icon-bubble">
            <svg class="sqe-header__cart-icon-custom" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
            {%- if cart != empty -%}
              <div class="cart-count-bubble">
                {%- if cart.item_count < 100 -%}
                  <span aria-hidden="true">{{ cart.item_count }}</span>
                {%- endif -%}
                <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
              </div>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}

      {%- if show_cta and cta_text != blank -%}
        <div class="sqe-header__cta-wrap">
          <a href="{{ cta_link }}" class="sqe-header__cta">
            {{ cta_text | escape }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Inline Search Bar {%- endcomment -%}
    <div class="sqe-search-bar" data-sqe-search-bar>
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="options[prefix]" value="last">
        <input type="search" name="q" placeholder="{{ 'general.search.search' | t }}" autocomplete="off" autocorrect="off" autocapitalize="off">
        <button type="submit" aria-label="{{ 'general.search.search' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
      </form>
      <button class="sqe-search-close" data-sqe-search-close type="button" aria-label="Close search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

  </div>
</section>

{%- comment -%} Spacer compensates for fixed header height {%- endcomment -%}
<div class="sqe-header-spacer--{{ section.id }}" data-show="{% if sticky_type != 'none' %}true{% else %}false{% endif %}" style="height: {{ header_height }}px;" aria-hidden="true"></div>

{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: 'scheme-1',
    desktop_menu_type: menu_type
  -%}
{%- endif -%}

<script>
  (function() {
    var section = document.getElementById('sqe-header-{{ section.id }}');
    if (!section) return;

    /* === SEARCH TOGGLE === */
    var searchToggle = section.querySelector('[data-sqe-search-toggle]');
    var searchBar = section.querySelector('[data-sqe-search-bar]');
    var searchClose = section.querySelector('[data-sqe-search-close]');
    var searchInput = searchBar ? searchBar.querySelector('input[type="search"]') : null;

    if (searchToggle && searchBar) {
      searchToggle.addEventListener('click', function() {
        searchBar.classList.add('sqe-search-open');
        if (searchInput) searchInput.focus();
      });
    }
    if (searchClose && searchBar) {
      searchClose.addEventListener('click', function() {
        searchBar.classList.remove('sqe-search-open');
      });
    }

    /* === FIXED HEADER (scroll-up / always) === */
    var stickyType = section.getAttribute('data-sticky');
    if (!stickyType || stickyType === 'none') return;

    var isAlwaysSticky = (stickyType === 'always');
    var currentScroll = 0;
    var headerHeight = section.offsetHeight;

    document.documentElement.style.setProperty('--header-height', headerHeight + 'px');

    window.addEventListener('scroll', function() {
      var scrollTop = window.pageYOffset || document.documentElement.scrollTop;

      if (isAlwaysSticky) {
        currentScroll = scrollTop;
        return;
      }

      /* on-scroll-up: hide when scrolling down, show when scrolling up */
      if (scrollTop > currentScroll && scrollTop > headerHeight) {
        section.classList.add('sqe-header-animate', 'sqe-header-hidden');
      } else if (scrollTop < currentScroll && scrollTop > headerHeight) {
        section.classList.add('sqe-header-animate');
        section.classList.remove('sqe-header-hidden');
      } else if (scrollTop <= 10) {
        section.classList.remove('sqe-header-hidden', 'sqe-header-animate');
      }

      currentScroll = scrollTop;
    }, { passive: true });
  })();
</script>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

