{%- liquid
  assign menu = section.settings.menu
  assign logo_pos_x = section.settings.logo_pos_x
  assign logo_pos_y = section.settings.logo_pos_y
  assign nav_align = section.settings.nav_alignment
  assign menu_nudge_x = section.settings.menu_nudge_x
  assign menu_pos_y = section.settings.menu_pos_y
  assign show_search = section.settings.show_search
  assign show_account = section.settings.show_account
  assign show_cart = section.settings.show_cart
  assign show_cta = section.settings.show_cta
  assign cta_text = section.settings.cta_text
  assign cta_link = section.settings.cta_link
  assign cta_color = section.settings.cta_color
  assign cta_bg = section.settings.cta_bg_color
  assign cta_font_size = section.settings.cta_font_size
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign sticky_type = section.settings.sticky_header_type
  assign header_height = section.settings.header_height
  assign show_border = section.settings.show_border
  assign menu_type = section.settings.menu_type_desktop
  assign hamburger_pos_x = section.settings.hamburger_pos_x
  assign hamburger_pos_y = section.settings.hamburger_pos_y
  assign actions_pos_x = section.settings.actions_pos_x
  assign actions_pos_y = section.settings.actions_pos_y
  assign mobile_logo_size = section.settings.mobile_logo_size
  assign mobile_icon_size = section.settings.mobile_icon_size
  assign menu_font_size = section.settings.menu_font_size
  assign menu_color = section.settings.menu_color
  assign menu_active_color = section.settings.menu_active_color
  assign menu_hover_color = section.settings.menu_hover_color
  assign menu_bold = section.settings.menu_bold
  assign search_pos_x = section.settings.search_pos_x
  assign search_pos_y = section.settings.search_pos_y
  assign account_pos_x = section.settings.account_pos_x
  assign account_pos_y = section.settings.account_pos_y
  assign cart_pos_x = section.settings.cart_pos_x
  assign cart_pos_y = section.settings.cart_pos_y
  assign cta_pos_x = section.settings.cta_pos_x
  assign cta_pos_y = section.settings.cta_pos_y

  assign menu_weight = '400'
  if menu_bold
    assign menu_weight = '700'
  endif
-%}

<link rel="stylesheet" href="{{ 'component-list-menu.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-search.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-menu-drawer.css' | asset_url }}" media="print" onload="this.media='all'">
<link rel="stylesheet" href="{{ 'component-cart-notification.css' | asset_url }}" media="print" onload="this.media='all'">

{%- if settings.predictive_search_enabled -%}
  <link rel="stylesheet" href="{{ 'component-price.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

{%- if menu_type == 'mega' -%}
  <link rel="stylesheet" href="{{ 'component-mega-menu.css' | asset_url }}" media="print" onload="this.media='all'">
{%- endif -%}

<script src="{{ 'cart-notification.js' | asset_url }}" defer="defer"></script>

<style>
  /*
   * ============================================================
   *  SQE HEADER – v10
   *
   *  Fully compatible with Dawn's infrastructure:
   *  - Schema "class": "section-header" matches Dawn's header
   *  - .header-wrapper div for HeaderDrawer compatibility
   *  - Sticky uses Dawn's class system on the .section-header wrapper
   *  - base.css handles positioning via:
   *      .shopify-section-header-sticky { position: sticky; top: 0 }
   *      .shopify-section-header-hidden { top: calc(-1 * --header-height) }
   *      .section-header.animate { transition: top 0.15s ease-out }
   * ============================================================
   */

  /* --- SECTION ELEMENT: base styles --- */
  .sqe-hdr-{{ section.id }} {
    background-color: {{ bg_color }};
    color: {{ text_color }};
    width: 100%;
    box-sizing: border-box;
    position: relative;
    z-index: 3;
    /* padding-top intentionally omitted – breaks sticky positioning */
  }

  /* Ensure Shopify section wrapper (section-header) has background color */
  .section-header .sqe-hdr-{{ section.id }} {
    background-color: {{ bg_color }};
  }

  /*
   * Section wrapper z-index.
   * DO NOT set 'position' here – it would override Dawn's
   * .shopify-section-header-sticky { position: sticky } because
   * an ID selector (#shopify-section-…) beats a class selector.
   * Dawn's sticky class already provides the positioning context
   * that z-index needs.
   */
  .section-header#shopify-section-{{ section.id }} {
    z-index: 4;
  }
  /* When sticky is active, ensure z-index still applies */
  .shopify-section-header-sticky#shopify-section-{{ section.id }} {
    z-index: 4;
  }

  /* Override Dawn's .header-wrapper to use SQE background */
  .sqe-hdr-{{ section.id }} .header-wrapper {
    background-color: {{ bg_color }};
  }

  /* --- BORDER via data-border --- */
  .sqe-hdr-{{ section.id }}[data-border="true"] {
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
  }
  .sqe-hdr-{{ section.id }}[data-border="false"] {
    border-bottom: none;
  }

  /* --- INNER container --- */
  .sqe-hdr-{{ section.id }} .sqe-h-inner {
    display: flex;
    align-items: center;
    height: {{ header_height }}px;
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
    box-sizing: border-box;
  }

  /* --- LOGO --- */
  .sqe-hdr-{{ section.id }} .sqe-h-logo {
    position: absolute;
    left: {{ logo_pos_x }}%;
    top: 50%;
    transform: translateY(-50%) translateY({{ logo_pos_y }}px);
    z-index: 10;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-logo a {
    display: flex;
    align-items: center;
    text-decoration: none;
    color: inherit;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-logo img {
    max-height: {{ header_height | minus: 20 }}px;
    width: auto;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-logo .h2 {
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 700;
    font-size: 1.4rem;
    margin: 0;
    color: inherit;
    white-space: nowrap;
  }

  /* --- NAV ALIGNMENT via data-align (all rules always present) --- */
  .sqe-hdr-{{ section.id }} .sqe-h-nav {
    position: absolute;
    top: 50%;
    z-index: 5;
    display: flex;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-nav[data-align="left"] {
    left: 2rem !important;
    right: auto !important;
    transform: translateY(-50%) translate({{ menu_nudge_x }}px, {{ menu_pos_y }}px) !important;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-nav[data-align="center"] {
    left: 50% !important;
    right: auto !important;
    transform: translateX(-50%) translateY(-50%) translate({{ menu_nudge_x }}px, {{ menu_pos_y }}px) !important;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-nav[data-align="right"] {
    left: auto !important;
    right: 2rem !important;
    transform: translateY(-50%) translate({{ menu_nudge_x }}px, {{ menu_pos_y }}px) !important;
  }

  .sqe-hdr-{{ section.id }} .sqe-h-nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    gap: 0.25rem;
  }

  .sqe-hdr-{{ section.id }} .sqe-h-nav-item a {
    text-decoration: none;
    color: {{ menu_color }};
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: {{ menu_weight }};
    font-size: {{ menu_font_size }}px;
    letter-spacing: 0.02em;
    padding: 0.5rem 0.85rem;
    transition: color 0.2s ease, background-color 0.2s ease;
    border-radius: 4px;
    display: block;
    white-space: nowrap;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-nav-item a:hover {
    color: {{ menu_hover_color }};
    background-color: rgba(242, 183, 5, 0.08);
  }
  .sqe-hdr-{{ section.id }} .sqe-h-nav-item--active a {
    color: {{ menu_active_color }};
  }

  /* --- DROPDOWN SUBMENU --- */
  .sqe-hdr-{{ section.id }} .sqe-h-nav-item {
    position: relative;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-dropdown {
    display: none;
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 220px;
    background-color: {{ bg_color }};
    border: 1px solid rgba(0, 0, 0, 0.08);
    border-radius: 6px;
    box-shadow: 0 8px 30px rgba(0, 0, 0, 0.12);
    padding: 0.5rem 0;
    z-index: 100;
    list-style: none;
    margin: 0;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-nav-item:hover .sqe-h-dropdown {
    display: block;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-dropdown li a {
    display: block;
    padding: 0.5rem 1.2rem;
    font-size: 0.9rem;
    font-weight: 500;
    color: {{ menu_color }};
  }
  .sqe-hdr-{{ section.id }} .sqe-h-dropdown li a:hover {
    color: {{ menu_hover_color }};
  }

  /* --- DRAWER MODE via data-menu-type --- */
  .sqe-hdr-{{ section.id }}[data-menu-type="drawer"] .sqe-h-nav {
    display: none !important;
  }
  .sqe-hdr-{{ section.id }}[data-menu-type="drawer"] .sqe-h-hamburger {
    display: flex !important;
  }

  /* --- ACTIONS GROUP --- */
  .sqe-hdr-{{ section.id }} .sqe-h-actions {
    position: absolute;
    right: {{ actions_pos_x }}%;
    top: 50%;
    transform: translateY(-50%) translateY({{ actions_pos_y }}px);
    display: flex;
    align-items: center;
    gap: 0.25rem;
    z-index: 10;
  }

  .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap {
    position: relative;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap--search {
    top: {{ search_pos_y }}px;
    left: {{ search_pos_x }}px;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap--account {
    top: {{ account_pos_y }}px;
    left: {{ account_pos_x }}px;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap--cart {
    top: {{ cart_pos_y }}px;
    left: {{ cart_pos_x }}px;
  }

  .sqe-hdr-{{ section.id }} .sqe-h-cta-wrap {
    position: relative;
    top: {{ cta_pos_y }}px;
    left: {{ cta_pos_x }}px;
    margin-left: 0.5rem;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-cta {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background-color: {{ cta_bg }};
    color: {{ cta_color }};
    text-decoration: none;
    padding: 0.6rem 1.4rem;
    border-radius: 4px;
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 700;
    font-size: {{ cta_font_size }}px;
    letter-spacing: 0.03em;
    transition: opacity 0.2s ease, transform 0.15s ease;
    white-space: nowrap;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-cta:hover {
    opacity: 0.9;
    transform: translateY(-1px);
  }

  /* --- ICONS --- */
  .sqe-hdr-{{ section.id }} .sqe-h-icon {
    color: {{ text_color }};
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: color 0.2s ease;
    position: relative;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-icon:hover {
    color: {{ menu_hover_color }};
  }
  .sqe-hdr-{{ section.id }} .sqe-h-icon svg {
    width: 22px;
    height: 22px;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-cart-svg {
    width: 24px;
    height: 24px;
    stroke: currentColor;
    fill: none;
    stroke-width: 1.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-cart-bubble {
    position: absolute;
    top: 4px;
    right: 0;
    background-color: {{ cta_bg }};
    color: {{ cta_color }};
    border-radius: 50%;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 0.65rem;
    font-weight: 700;
    line-height: 1;
  }

  /* --- HAMBURGER (hidden by default, shown on mobile or drawer mode) --- */
  .sqe-hdr-{{ section.id }} .sqe-h-hamburger {
    display: none;
    position: absolute;
    left: {{ hamburger_pos_x }}%;
    top: 50%;
    transform: translateY(-50%) translateY({{ hamburger_pos_y }}px);
    z-index: 10;
  }

  /* --- INLINE SEARCH BAR --- */
  .sqe-hdr-{{ section.id }} .sqe-h-search-bar {
    display: none;
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: {{ bg_color }};
    z-index: 9999;
    align-items: center;
    justify-content: center;
    padding: 0 2rem;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-bar.sqe-search-open {
    display: flex;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-bar form {
    display: flex;
    align-items: center;
    width: 100%;
    max-width: 600px;
    border: 2px solid {{ text_color }};
    border-radius: 6px;
    overflow: hidden;
    background: #fff;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-bar input[type="search"] {
    flex: 1;
    border: none;
    outline: none;
    padding: 0.6rem 1rem;
    font-size: 1rem;
    font-family: 'Inter', sans-serif;
    background: transparent;
    color: {{ text_color }};
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-bar button[type="submit"] {
    background: none;
    border: none;
    padding: 0.6rem 1rem;
    cursor: pointer;
    color: {{ text_color }};
    display: flex;
    align-items: center;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-bar button[type="submit"] svg {
    width: 20px;
    height: 20px;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-close {
    background: none;
    border: none;
    padding: 0.5rem;
    margin-left: 1rem;
    cursor: pointer;
    color: {{ text_color }};
    display: flex;
    align-items: center;
  }
  .sqe-hdr-{{ section.id }} .sqe-h-search-close svg {
    width: 24px;
    height: 24px;
  }

  /* --- DAWN DRAWER COMPAT --- */
  .sqe-hdr-{{ section.id }} header-drawer {
    justify-self: start;
    margin-left: -1.2rem;
  }
  .sqe-hdr-{{ section.id }} .menu-drawer-container {
    display: flex;
  }
  .sqe-hdr-{{ section.id }} .list-menu {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  /*
   * --- DAWN DRAWER COMPAT (visual tweaks only) ---
   * DO NOT override position/transform/visibility – Dawn's
   * component-menu-drawer.css + header-drawer JS handle that.
   * We only style colours, fonts and add CTA here.
   */
  .sqe-hdr-{{ section.id }} .menu-drawer {
    background-color: #fff;
  }
  .sqe-hdr-{{ section.id }} .menu-drawer__menu-item {
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    color: {{ text_color }};
  }
  .sqe-hdr-{{ section.id }} .menu-drawer__menu-item:hover,
  .sqe-hdr-{{ section.id }} .menu-drawer__menu-item--active {
    color: {{ menu_hover_color }};
  }
  .sqe-hdr-{{ section.id }} .menu-drawer__close-button {
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    color: {{ text_color }};
  }
  /* CTA button inside drawer */
  .sqe-hdr-{{ section.id }} .sqe-drawer-cta {
    display: block;
    margin: 20px 3rem;
    padding: 14px 24px;
    background: {{ cta_bg }};
    color: {{ cta_color }};
    text-align: center;
    text-decoration: none;
    font-family: 'Source Sans 3', 'Source Sans Pro', sans-serif;
    font-weight: 700;
    font-size: 16px;
    border-radius: 6px;
    transition: opacity 0.2s ease;
  }
  .sqe-hdr-{{ section.id }} .sqe-drawer-cta:hover {
    opacity: 0.85;
  }

  /* ===== MOBILE (max-width: 989px) ===== */
  @media screen and (max-width: 989px) {
    .sqe-hdr-{{ section.id }} .sqe-h-inner {
      height: 60px;
      padding: 0 1rem;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-nav {
      display: none !important;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-hamburger {
      display: flex !important;
      left: 1%;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-logo {
      left: 50%;
      transform: translateX(-50%) translateY(-50%);
    }
    .sqe-hdr-{{ section.id }} .sqe-h-logo img {
      max-height: {{ mobile_logo_size }}px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-logo .h2 {
      font-size: 1.1rem;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-actions {
      right: 1%;
      transform: translateY(-50%);
      gap: 0;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-cta-wrap {
      display: none;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-icon {
      width: {{ mobile_icon_size }}px;
      height: {{ mobile_icon_size }}px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-icon svg {
      width: {{ mobile_icon_size | minus: 8 }}px;
      height: {{ mobile_icon_size | minus: 8 }}px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-cart-svg {
      width: {{ mobile_icon_size | minus: 6 }}px;
      height: {{ mobile_icon_size | minus: 6 }}px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap--search,
    .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap--account,
    .sqe-hdr-{{ section.id }} .sqe-h-icon-wrap--cart {
      top: 0;
      left: 0;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-cart-bubble {
      width: 16px;
      height: 16px;
      font-size: 0.6rem;
      top: 2px;
      right: -2px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-search-bar {
      padding: 0 1rem;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-search-bar form {
      max-width: none;
    }
  }

  /* ===== SMALL MOBILE (max-width: 480px) ===== */
  @media screen and (max-width: 480px) {
    .sqe-hdr-{{ section.id }} .sqe-h-inner {
      height: 56px;
      padding: 0 0.75rem;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-icon {
      width: 36px;
      height: 36px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-icon svg {
      width: 18px;
      height: 18px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-cart-svg {
      width: 20px;
      height: 20px;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-logo img {
      max-height: 30px;
    }
  }

  /* ===== TABLET (990-1200px) ===== */
  @media screen and (min-width: 990px) and (max-width: 1200px) {
    .sqe-hdr-{{ section.id }} .sqe-h-nav-item a {
      font-size: {{ menu_font_size | minus: 2 }}px;
      padding: 0.4rem 0.5rem;
    }
    .sqe-hdr-{{ section.id }} .sqe-h-cta {
      padding: 0.5rem 1rem;
      font-size: {{ cta_font_size | minus: 1 }}px;
    }
  }
</style>

{%- comment -%}
  ============================================================
  HTML – completely new class names (sqe-h-*) to avoid Dawn conflicts
  ============================================================
{%- endcomment -%}

<section
  class="sqe-hdr-{{ section.id }}"
  data-sticky="{{ sticky_type }}"
  data-menu-type="{{ menu_type }}"
  data-border="{{ show_border }}"
  data-sqe-header
>
  <div class="header-wrapper">
  <div class="sqe-h-inner">

    {%- comment -%} Mobile hamburger / drawer {%- endcomment -%}
    <div class="sqe-h-hamburger">
      {%- if menu != blank -%}
        {%- render 'header-drawer' -%}
      {%- endif -%}
    </div>

    {%- comment -%} Logo {%- endcomment -%}
    <div class="sqe-h-logo">
      {%- if request.page_type == 'index' -%}
        <h1 class="header__heading" style="margin:0">
      {%- endif -%}
      <a href="{{ routes.root_url }}" class="header__heading-link link link--text focus-inset">
        {%- if settings.logo != blank -%}
          <div class="header__heading-logo-wrapper">
            {%- assign logo_alt = settings.logo.alt | default: shop.name | escape -%}
            {%- assign logo_height = settings.logo_width | divided_by: settings.logo.aspect_ratio -%}
            {% capture sizes %}(max-width: {{ settings.logo_width | times: 2 }}px) 50vw, {{ settings.logo_width }}px{% endcapture %}
            {% capture widths %}{{ settings.logo_width }}, {{ settings.logo_width | times: 1.5 | round }}, {{ settings.logo_width | times: 2 }}{% endcapture %}
            {{
              settings.logo
              | image_url: width: 600
              | image_tag:
                class: 'header__heading-logo motion-reduce',
                widths: widths,
                height: logo_height,
                width: settings.logo_width,
                alt: logo_alt,
                sizes: sizes,
                preload: true
            }}
          </div>
        {%- else -%}
          <span class="h2">{{ shop.name }}</span>
        {%- endif -%}
      </a>
      {%- if request.page_type == 'index' -%}
        </h1>
      {%- endif -%}
    </div>

    {%- comment -%} Desktop Navigation {%- endcomment -%}
    <nav class="sqe-h-nav" data-align="{{ nav_align }}" aria-label="Main navigation">
      {%- if menu != blank -%}
        <ul class="sqe-h-nav-list" role="list">
          {%- for link in menu.links -%}
            <li class="sqe-h-nav-item{% if link.current %} sqe-h-nav-item--active{% endif %}">
              <a
                href="{{ link.url }}"
                {% if link.current %} aria-current="page"{% endif %}
              >
                {{ link.title | escape }}
              </a>
              {%- if link.links != blank -%}
                <ul class="sqe-h-dropdown">
                  {%- for childlink in link.links -%}
                    <li>
                      <a
                        href="{{ childlink.url }}"
                        {% if childlink.current %} aria-current="page"{% endif %}
                      >
                        {{ childlink.title | escape }}
                      </a>
                    </li>
                  {%- endfor -%}
                </ul>
              {%- endif -%}
            </li>
          {%- endfor -%}
        </ul>
      {%- endif -%}
    </nav>

    {%- comment -%} Actions: Search, Account, Cart, CTA {%- endcomment -%}
    <div class="sqe-h-actions">

      {%- if show_search -%}
        <div class="sqe-h-icon-wrap sqe-h-icon-wrap--search">
          <button class="sqe-h-icon" aria-label="Search" data-sqe-search-toggle type="button">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
          </button>
        </div>
      {%- endif -%}

      {%- if show_account and shop.customer_accounts_enabled -%}
        <div class="sqe-h-icon-wrap sqe-h-icon-wrap--account">
          <a
            href="{%- if customer -%}{{ routes.account_url }}{%- else -%}{{ routes.account_login_url }}{%- endif -%}"
            class="sqe-h-icon"
            rel="nofollow"
          >
            <span class="svg-wrapper">{{ 'icon-account.svg' | inline_asset_content }}</span>
            <span class="visually-hidden">
              {%- liquid
                if customer
                  echo 'customer.account_fallback' | t
                else
                  echo 'customer.log_in' | t
                endif
              -%}
            </span>
          </a>
        </div>
      {%- endif -%}

      {%- if show_cart -%}
        <div class="sqe-h-icon-wrap sqe-h-icon-wrap--cart">
          <a href="{{ routes.cart_url }}" class="sqe-h-icon" id="cart-icon-bubble">
            <svg class="sqe-h-cart-svg" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg">
              <path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/>
              <line x1="3" y1="6" x2="21" y2="6"/>
              <path d="M16 10a4 4 0 01-8 0"/>
            </svg>
            <span class="visually-hidden">{{ 'templates.cart.cart' | t }}</span>
            {%- if cart != empty -%}
              <div class="sqe-h-cart-bubble">
                {%- if cart.item_count < 100 -%}
                  <span aria-hidden="true">{{ cart.item_count }}</span>
                {%- endif -%}
                <span class="visually-hidden">{{ 'sections.header.cart_count' | t: count: cart.item_count }}</span>
              </div>
            {%- endif -%}
          </a>
        </div>
      {%- endif -%}

      {%- if show_cta and cta_text != blank -%}
        <div class="sqe-h-cta-wrap">
          <a href="{{ cta_link }}" class="sqe-h-cta">
            {{ cta_text | escape }}
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
        </div>
      {%- endif -%}

    </div>

    {%- comment -%} Inline Search Bar {%- endcomment -%}
    <div class="sqe-h-search-bar" data-sqe-search-bar>
      <form action="{{ routes.search_url }}" method="get" role="search">
        <input type="hidden" name="options[prefix]" value="last">
        <input type="search" name="q" placeholder="{{ 'general.search.search' | t }}" autocomplete="off" autocorrect="off" autocapitalize="off">
        <button type="submit" aria-label="{{ 'general.search.search' | t }}">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        </button>
      </form>
      <button class="sqe-h-search-close" data-sqe-search-close type="button" aria-label="Close search">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>
    </div>

  </div>
  </div>{%- comment -%} /.header-wrapper {%- endcomment -%}
</section>


{%- if settings.cart_type == 'notification' -%}
  {%- render 'cart-notification',
    color_scheme: 'scheme-1',
    desktop_menu_type: menu_type
  -%}
{%- endif -%}

<script>
  (function() {
    /*
     * SQE Header JS – v10
     *
     * Replicates Dawn's StickyHeader behavior exactly:
     * - Schema "class": "section-header" → wrapper gets .section-header
     * - JS targets the wrapper via document.querySelector('.section-header')
     * - Sticky classes go on the wrapper (same as Dawn's StickyHeader element)
     * - .header-wrapper div added for HeaderDrawer compatibility
     *
     * Dawn base.css handles:
     *   .shopify-section-header-sticky { position: sticky; top: 0 }
     *   .shopify-section-header-hidden { top: calc(-1 * var(--header-height)) }
     *   .section-header.animate { transition: top 0.15s ease-out }
     */

    var section = document.querySelector('[data-sqe-header]');
    if (!section) return;

    var stickyType = section.getAttribute('data-sticky');

    /*
     * Target the section wrapper with .section-header class.
     * This is the SAME element Dawn's StickyHeader targets:
     *   this.header = document.querySelector('.section-header');
     * The "class": "section-header" in our schema puts this class
     * on the Shopify section wrapper (#shopify-section-sqe-header).
     */
    var header = document.querySelector('.section-header');
    if (!header) return;

    var isAlwaysSticky = (stickyType === 'always' || stickyType === 'reduce-logo-size');

    /* === SET CSS VARIABLE (same as Dawn) === */
    function setHeaderHeight() {
      document.documentElement.style.setProperty(
        '--header-height',
        header.offsetHeight + 'px'
      );
    }
    setHeaderHeight();
    window.matchMedia('(max-width: 990px)').addEventListener('change', setHeaderHeight);

    /* === CLEAN UP previous scroll handler (survives section re-render) === */
    if (header._sqeScrollHandler) {
      window.removeEventListener('scroll', header._sqeScrollHandler);
      header._sqeScrollHandler = null;
    }

    /* === CLEAN SLATE: remove stale classes from previous render === */
    header.classList.remove(
      'shopify-section-header-sticky',
      'shopify-section-header-hidden',
      'animate',
      'scrolled-past-header'
    );

    /* === STICKY: "always" mode === */
    if (isAlwaysSticky) {
      header.classList.add('shopify-section-header-sticky');
    }

    /* === STICKY: "on-scroll-up" mode (matches Dawn's StickyHeader logic) === */
    if (stickyType === 'on-scroll-up') {
      var currentScrollTop = 0;
      var preventReveal = false;
      var headerBounds = {};

      /* Get accurate header bounds */
      var io = new IntersectionObserver(function(entries) {
        headerBounds = entries[0].intersectionRect;
        io.disconnect();
      });
      io.observe(header);

      var scrollHandler = function() {
        var scrollTop = window.pageYOffset || document.documentElement.scrollTop;

        if (scrollTop > currentScrollTop && scrollTop > (headerBounds.bottom || header.offsetHeight)) {
          /* Scrolling DOWN past header → hide */
          header.classList.add('scrolled-past-header');
          if (!header._sqePreventHide) {
            header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
          }
        } else if (scrollTop < currentScrollTop && scrollTop > (headerBounds.bottom || header.offsetHeight)) {
          /* Scrolling UP → reveal */
          header.classList.add('scrolled-past-header');
          if (!preventReveal) {
            header.classList.add('shopify-section-header-sticky', 'animate');
            header.classList.remove('shopify-section-header-hidden');
          } else {
            clearTimeout(header._sqeScrollTimeout);
            header._sqeScrollTimeout = setTimeout(function() {
              preventReveal = false;
            }, 66);
            header.classList.add('shopify-section-header-hidden', 'shopify-section-header-sticky');
          }
        } else if (scrollTop <= (headerBounds.top || 0)) {
          /* Back at top → reset */
          header.classList.remove(
            'shopify-section-header-sticky',
            'shopify-section-header-hidden',
            'animate',
            'scrolled-past-header'
          );
        }

        currentScrollTop = scrollTop;
      };

      /* Store reference for cleanup on next re-render */
      header._sqeScrollHandler = scrollHandler;
      window.addEventListener('scroll', scrollHandler, { passive: true });
    }

    /* "none" → classes already removed above, nothing else needed */

    /* === INJECT CTA INTO MOBILE DRAWER === */
    var drawerUtility = section.querySelector('.menu-drawer__utility-links');
    if (drawerUtility && !drawerUtility.querySelector('.sqe-drawer-cta')) {
      var ctaShow = {{ show_cta | json }};
      var ctaText = {{ cta_text | json }};
      var ctaLink = {{ cta_link | json }};
      if (ctaShow && ctaText) {
        var ctaEl = document.createElement('a');
        ctaEl.href = ctaLink || '#';
        ctaEl.className = 'sqe-drawer-cta';
        ctaEl.textContent = ctaText;
        drawerUtility.insertBefore(ctaEl, drawerUtility.firstChild);
      }
    }

    /* === SEARCH TOGGLE === */
    var searchToggle = section.querySelector('[data-sqe-search-toggle]');
    var searchBar = section.querySelector('[data-sqe-search-bar]');
    var searchClose = section.querySelector('[data-sqe-search-close]');
    var searchInput = searchBar ? searchBar.querySelector('input[type="search"]') : null;

    if (searchToggle && searchBar) {
      searchToggle.addEventListener('click', function() {
        searchBar.classList.add('sqe-search-open');
        if (searchInput) searchInput.focus();
      });
    }
    if (searchClose && searchBar) {
      searchClose.addEventListener('click', function() {
        searchBar.classList.remove('sqe-search-open');
      });
    }
  })();
</script>

<script type="application/ld+json">
  {
    "@context": "http://schema.org",
    "@type": "Organization",
    "name": {{ shop.name | json }},
    {% if settings.logo %}
      "logo": {{ settings.logo | image_url: width: 500 | prepend: "https:" | json }},
    {% endif %}
    "sameAs": [
      {{ settings.social_twitter_link | json }},
      {{ settings.social_facebook_link | json }},
      {{ settings.social_pinterest_link | json }},
      {{ settings.social_instagram_link | json }},
      {{ settings.social_tiktok_link | json }},
      {{ settings.social_tumblr_link | json }},
      {{ settings.social_snapchat_link | json }},
      {{ settings.social_youtube_link | json }},
      {{ settings.social_vimeo_link | json }}
    ],
    "url": {{ request.origin | append: page.url | json }}
  }
</script>

{%- if request.page_type == 'index' -%}
  {% assign potential_action_target = request.origin | append: routes.search_url | append: '?q={search_term_string}' %}
  <script type="application/ld+json">
    {
      "@context": "http://schema.org",
      "@type": "WebSite",
      "name": {{ shop.name | json }},
      "potentialAction": {
        "@type": "SearchAction",
        "target": {{ potential_action_target | json }},
        "query-input": "required name=search_term_string"
      },
      "url": {{ request.origin | append: page.url | json }}
    }
  </script>
{%- endif -%}

