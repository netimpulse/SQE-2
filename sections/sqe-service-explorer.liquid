{% comment %}
  SQE Service Explorer - Interactive Service Category Explorer
  A premium service discovery experience with animated transitions
  and dynamic content panels.
{% endcomment %}

<div class="sqe-service-explorer" data-section-id="{{ section.id }}">
  <div class="service-explorer-container">
    <!-- Left Sidebar: Service Categories -->
    <div class="service-categories">
      <div class="categories-header">
        <h2>{{ section.settings.header_title }}</h2>
        <p class="categories-subtitle">{{ section.settings.header_subtitle }}</p>
      </div>

      <div class="categories-list">
        {% for block in section.blocks %}
          {% if block.type == 'service' %}
            <div
              class="category-item"
              data-service-id="service-{{ forloop.index }}"
              {% if forloop.first %}data-active="true"{% endif %}
            >
              <div class="category-number">
                {% if forloop.index < 10 %}0{% endif %}{{ forloop.index }}
              </div>
              <div class="category-content">
                <h3 class="category-title">{{ block.settings.service_title }}</h3>
                <p class="category-excerpt">{{ block.settings.service_excerpt }}</p>
              </div>
              <div class="category-accent-bar"></div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    </div>

    <!-- Right Panel: Service Details -->
    <div class="service-details-panel">
      {% for block in section.blocks %}
        {% if block.type == 'service' %}
          <div
            class="service-detail"
            id="service-{{ forloop.index }}"
            data-service-id="service-{{ forloop.index }}"
            {% if forloop.first %}data-active="true"{% endif %}
            style="--service-color: {{ block.settings.accent_color }}"
          >
            <div class="detail-content">
              <div class="detail-header">
                <h2 class="detail-title">{{ block.settings.service_title }}</h2>
                <div class="title-underline"></div>
              </div>

              <p class="detail-description">{{ block.settings.service_description }}</p>

              <div class="detail-benefits">
                <h4 class="benefits-title">Key Benefits</h4>
                <ul class="benefits-list">
                  {% assign benefits = block.settings.benefits | split: '|' %}
                  {% for benefit in benefits %}
                    {% if benefit != blank %}
                      <li class="benefit-item">
                        <span class="benefit-check">✓</span>
                        <span class="benefit-text">{{ benefit | strip }}</span>
                      </li>
                    {% endif %}
                  {% endfor %}
                </ul>
              </div>

              <div class="detail-stats">
                {% if block.settings.stat_label_1 != blank %}
                  <div class="stat-item">
                    <span class="stat-icon">📊</span>
                    <span class="stat-label">{{ block.settings.stat_label_1 }}</span>
                    <span class="stat-value">{{ block.settings.stat_value_1 }}</span>
                  </div>
                {% endif %}
                {% if block.settings.stat_label_2 != blank %}
                  <div class="stat-item">
                    <span class="stat-icon">⚡</span>
                    <span class="stat-label">{{ block.settings.stat_label_2 }}</span>
                    <span class="stat-value">{{ block.settings.stat_value_2 }}</span>
                  </div>
                {% endif %}
                {% if block.settings.stat_label_3 != blank %}
                  <div class="stat-item">
                    <span class="stat-icon">🎯</span>
                    <span class="stat-label">{{ block.settings.stat_label_3 }}</span>
                    <span class="stat-value">{{ block.settings.stat_value_3 }}</span>
                  </div>
                {% endif %}
              </div>

              <div class="detail-actions">
                <button class="cta-button cta-primary" data-service="{{ block.settings.service_title }}">
                  Request a Quote
                </button>
                <button class="cta-button cta-secondary" data-service="{{ block.settings.service_title }}">
                  Learn More →
                </button>
              </div>
            </div>

            <div class="detail-visual">
              {% if block.settings.service_image %}
                <img
                  src="{{ block.settings.service_image | image_url: width: 600 }}"
                  alt="{{ block.settings.service_title }}"
                  class="service-image"
                >
              {% else %}
                <div class="service-image-placeholder"></div>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</div>

<style>
  .sqe-service-explorer {
    width: 100%;
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px 0;
    background: linear-gradient(135deg, {{ section.settings.bg_color_1 }}, {{ section.settings.bg_color_2 }});
    font-family: 'Inter', sans-serif;
    overflow: hidden;
  }

  .service-explorer-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 0 20px;
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 60px;
    align-items: stretch;
    min-height: 600px;
  }

  /* CATEGORIES SIDEBAR */
  .service-categories {
    display: flex;
    flex-direction: column;
    padding: 40px 0;
  }

  .categories-header h2 {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0 0 10px 0;
    line-height: 1.2;
  }

  .categories-subtitle {
    font-size: 14px;
    color: #666;
    margin: 0 0 40px 0;
    line-height: 1.6;
  }

  .categories-list {
    display: flex;
    flex-direction: column;
    gap: 0;
    flex: 1;
  }

  .category-item {
    position: relative;
    padding: 20px 0;
    padding-left: 60px;
    cursor: pointer;
    border-left: 3px solid transparent;
    transition: all 0.35s cubic-bezier(0.34, 1.56, 0.64, 1);
    display: flex;
    align-items: center;
    gap: 15px;
  }

  .category-item:hover {
    transform: translateX(8px);
  }

  .category-item[data-active="true"] {
    border-left-color: #F2B705;
  }

  .category-item[data-active="true"] .category-title {
    color: #1F3A5F;
    font-weight: 700;
  }

  .category-item[data-active="true"] .category-accent-bar {
    opacity: 1;
    width: 4px;
  }

  .category-number {
    position: absolute;
    left: 0;
    font-size: 18px;
    font-weight: 700;
    color: #F2B705;
    font-family: 'Source Sans 3', sans-serif;
    letter-spacing: 2px;
  }

  .category-content {
    flex: 1;
  }

  .category-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 16px;
    font-weight: 600;
    color: #333;
    margin: 0 0 6px 0;
    transition: all 0.35s ease;
  }

  .category-excerpt {
    font-size: 12px;
    color: #999;
    margin: 0;
    line-height: 1.4;
    transition: all 0.35s ease;
  }

  .category-accent-bar {
    position: absolute;
    right: -15px;
    top: 50%;
    transform: translateY(-50%);
    height: 40px;
    width: 0;
    background: linear-gradient(to right, #F2B705, transparent);
    opacity: 0;
    transition: all 0.35s ease;
  }

  /* DETAILS PANEL */
  .service-details-panel {
    position: relative;
    padding: 40px;
    background: white;
    border-radius: 12px;
    box-shadow: 0 20px 60px rgba(31, 58, 95, 0.12);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .service-detail {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0;
    pointer-events: none;
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
    transform: translateY(20px);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    padding: 40px;
    border-radius: 12px;
  }

  .service-detail[data-active="true"] {
    opacity: 1;
    pointer-events: auto;
    transform: translateY(0);
    z-index: 10;
  }

  .service-detail::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: linear-gradient(135deg, rgba(31, 58, 95, 0.02), rgba(242, 183, 5, 0.03));
    border-radius: 12px;
    z-index: -1;
  }

  .detail-content {
    position: relative;
    z-index: 2;
  }

  .detail-header {
    margin-bottom: 30px;
  }

  .detail-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0 0 15px 0;
    line-height: 1.1;
  }

  .title-underline {
    width: 60px;
    height: 4px;
    background: #F2B705;
    border-radius: 2px;
    animation: expandWidth 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  @keyframes expandWidth {
    from {
      width: 0;
    }
    to {
      width: 60px;
    }
  }

  .detail-description {
    font-size: 16px;
    color: #555;
    line-height: 1.8;
    margin: 0 0 30px 0;
  }

  .benefits-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 14px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0 0 15px 0;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  .benefits-list {
    list-style: none;
    margin: 0 0 30px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .benefit-item {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 14px;
    color: #666;
    animation: slideInLeft 0.6s ease backwards;
  }

  .benefit-item:nth-child(1) { animation-delay: 0.1s; }
  .benefit-item:nth-child(2) { animation-delay: 0.15s; }
  .benefit-item:nth-child(3) { animation-delay: 0.2s; }
  .benefit-item:nth-child(4) { animation-delay: 0.25s; }

  @keyframes slideInLeft {
    from {
      opacity: 0;
      transform: translateX(-20px);
    }
    to {
      opacity: 1;
      transform: translateX(0);
    }
  }

  .benefit-check {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 24px;
    height: 24px;
    background: #F2B705;
    color: white;
    border-radius: 50%;
    font-size: 12px;
    font-weight: 700;
    flex-shrink: 0;
    animation: popIn 0.4s cubic-bezier(0.34, 1.56, 0.64, 1) backwards;
  }

  .benefit-item:nth-child(1) .benefit-check { animation-delay: 0.15s; }
  .benefit-item:nth-child(2) .benefit-check { animation-delay: 0.2s; }
  .benefit-item:nth-child(3) .benefit-check { animation-delay: 0.25s; }
  .benefit-item:nth-child(4) .benefit-check { animation-delay: 0.3s; }

  @keyframes popIn {
    from {
      transform: scale(0);
    }
    to {
      transform: scale(1);
    }
  }

  .detail-stats {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 20px;
    margin: 30px 0;
    padding: 25px;
    background: rgba(242, 244, 247, 0.8);
    border-radius: 8px;
    border-left: 4px solid #F2B705;
  }

  .stat-item {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }

  .stat-icon {
    font-size: 20px;
  }

  .stat-label {
    font-size: 11px;
    color: #999;
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
  }

  .stat-value {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 20px;
    font-weight: 700;
    color: #1F3A5F;
  }

  .detail-actions {
    display: flex;
    gap: 15px;
    margin-top: 30px;
  }

  .cta-button {
    padding: 14px 30px;
    border: none;
    border-radius: 6px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.35s ease;
    letter-spacing: 0.5px;
  }

  .cta-primary {
    background: #F2B705;
    color: #1F3A5F;
  }

  .cta-primary:hover {
    background: #e09d00;
    transform: translateY(-2px);
    box-shadow: 0 10px 30px rgba(242, 183, 5, 0.3);
  }

  .cta-secondary {
    background: transparent;
    color: #1F3A5F;
    border: 2px solid #1F3A5F;
  }

  .cta-secondary:hover {
    background: #1F3A5F;
    color: white;
  }

  /* DETAIL VISUAL */
  .detail-visual {
    position: relative;
    height: 400px;
    overflow: hidden;
    border-radius: 8px;
  }

  .service-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    animation: zoomIn 0.8s ease;
  }

  @keyframes zoomIn {
    from {
      transform: scale(1.05);
      opacity: 0;
    }
    to {
      transform: scale(1);
      opacity: 1;
    }
  }

  .service-image-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #F2F4F7, #E8EEF7);
    display: flex;
    align-items: center;
    justify-content: center;
    color: #999;
    font-size: 14px;
  }

  /* MOBILE RESPONSIVE */
  @media (max-width: 1024px) {
    .service-explorer-container {
      grid-template-columns: 1fr;
      gap: 30px;
      min-height: auto;
    }

    .service-detail {
      grid-template-columns: 1fr;
    }

    .detail-visual {
      height: 300px;
    }

    .detail-stats {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 640px) {
    .service-explorer-container {
      padding: 0 15px;
      gap: 20px;
    }

    .categories-header h2 {
      font-size: 24px;
    }

    .category-item {
      padding: 16px 0 16px 50px;
    }

    .detail-title {
      font-size: 28px;
    }

    .service-details-panel {
      padding: 20px;
    }

    .service-detail {
      padding: 20px;
    }

    .detail-description {
      font-size: 14px;
    }

    .detail-visual {
      height: 250px;
      margin-top: 20px;
    }

    .detail-actions {
      flex-direction: column;
    }

    .cta-button {
      width: 100%;
      text-align: center;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const explorer = document.querySelector('[data-section-id="{{ section.id }}"]');
    const categoryItems = explorer.querySelectorAll('.category-item');
    const serviceDetails = explorer.querySelectorAll('.service-detail');

    function setActiveService(serviceId) {
      // Update category items
      categoryItems.forEach(item => {
        if (item.dataset.serviceId === serviceId) {
          item.setAttribute('data-active', 'true');
        } else {
          item.removeAttribute('data-active');
        }
      });

      // Update service details
      serviceDetails.forEach(detail => {
        if (detail.dataset.serviceId === serviceId) {
          detail.setAttribute('data-active', 'true');
        } else {
          detail.removeAttribute('data-active');
        }
      });
    }

    // Category click handlers
    categoryItems.forEach(item => {
      item.addEventListener('click', function() {
        setActiveService(this.dataset.serviceId);
      });

      item.addEventListener('mouseenter', function() {
        setActiveService(this.dataset.serviceId);
      });
    });

    // CTA Button handlers
    explorer.querySelectorAll('.cta-button').forEach(button => {
      button.addEventListener('click', function() {
        const serviceName = this.dataset.service;
        console.log('Quote requested for:', serviceName);
        // Add your quote request logic here
      });
    });
  });
</script>

{% schema %}
{
  "name": "SQE Service Explorer",
  "settings": [
    {
      "type": "text",
      "id": "header_title",
      "label": "Section Title",
      "default": "Our Services"
