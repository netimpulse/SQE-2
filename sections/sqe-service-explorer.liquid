{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign accent_color = section.settings.accent_color
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color
-%}

<section
  id="sqe-service-explorer-{{ section.id }}"
  class="sqe-service-explorer"
  style="--sqe-heading-font: {{ h_font }}; --sqe-heading-size: {{ h_size }}px; --sqe-heading-color: {{ h_color }}; --sqe-heading-weight: {{ h_weight }}; --sqe-subheading-font: {{ sh_font }}; --sqe-subheading-size: {{ sh_size }}px; --sqe-subheading-color: {{ sh_color }}; --sqe-accent-color: {{ accent_color }};"
>
  <div class="explorer-container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if heading %}
      <h2 class="explorer-heading">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="explorer-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="explorer-wrapper">
      <div class="service-list">
        {% if section.blocks.size > 0 %}
          {% for block in section.blocks %}
            <div class="service-item" data-service-id="{{ block.id }}">
              <div class="service-number">{{ forloop.index }}</div>
              <h3 class="service-title">{{ block.settings.title }}</h3>
            </div>
          {% endfor %}
        {% else %}
          <div class="service-list-empty">
            <p>No services added yet. Add blocks to get started.</p>
          </div>
        {% endif %}
      </div>

      {% if section.blocks.size > 0 %}
        {% assign first_block = section.blocks.first %}
        <div class="detail-panel" data-service-id="{{ first_block.id }}">
          <div class="detail-content">
            {% if first_block.settings.image %}
              <img
                src="{{ first_block.settings.image | image_url: width: 500 }}"
                alt="{{ first_block.settings.title }}"
                class="detail-image"
                loading="lazy"
              >
            {% else %}
              <div class="detail-image detail-image-placeholder">
                {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
            <h3 class="detail-title">{{ first_block.settings.title }}</h3>
            {% if first_block.settings.description %}
              <p class="detail-description">{{ first_block.settings.description }}</p>
            {% endif %}
            {% if first_block.settings.features %}
              <div class="detail-features">
                <h4>Features</h4>
                <p>{{ first_block.settings.features }}</p>
              </div>
            {% endif %}
            {% if first_block.settings.link_url %}
              <a href="{{ first_block.settings.link_url }}" class="detail-link">
                {{ first_block.settings.link_text | default: 'Learn More' }}
              </a>
            {% endif %}
          </div>
        </div>

        {%- comment -%}
          Hidden panel templates for each service to avoid XSS via innerHTML.
          JavaScript will clone these instead of building HTML strings.
        {%- endcomment -%}
        <div class="detail-templates" style="display: none;">
          {% for block in section.blocks %}
            <template id="service-template-{{ block.id }}">
              {% if block.settings.image %}
                <img
                  src="{{ block.settings.image | image_url: width: 500 }}"
                  alt="{{ block.settings.title }}"
                  class="detail-image"
                  loading="lazy"
                >
              {% else %}
                <div class="detail-image detail-image-placeholder">
                  {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
                </div>
              {% endif %}
              <h3 class="detail-title">{{ block.settings.title }}</h3>
              {% if block.settings.description %}
                <p class="detail-description">{{ block.settings.description }}</p>
              {% endif %}
              {% if block.settings.features %}
                <div class="detail-features">
                  <h4>Features</h4>
                  <p>{{ block.settings.features }}</p>
                </div>
              {% endif %}
              {% if block.settings.link_url %}
                <a href="{{ block.settings.link_url }}" class="detail-link">
                  {{ block.settings.link_text | default: 'Learn More' }}
                </a>
              {% endif %}
            </template>
          {% endfor %}
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #sqe-service-explorer-{{ section.id }} {
    padding: {{ section.settings.padding_top }}px 20px 60px 20px;
    background-color: {{ section.settings.background_color }};
  }

  /* ===== SECTION LABEL (orange pill) - scoped ===== */
  #sqe-service-explorer-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #C75B12;
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  /* ===== CONTAINER & LAYOUT - scoped ===== */
  #sqe-service-explorer-{{ section.id }} .explorer-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  #sqe-service-explorer-{{ section.id }} .explorer-heading {
    font-family: var(--sqe-heading-font);
    font-size: var(--sqe-heading-size);
    color: var(--sqe-heading-color);
    font-weight: var(--sqe-heading-weight);
    margin-bottom: 10px;
    text-align: center;
  }

  #sqe-service-explorer-{{ section.id }} .explorer-subheading {
    font-family: var(--sqe-subheading-font);
    font-size: var(--sqe-subheading-size);
    color: var(--sqe-subheading-color);
    text-align: center;
    margin-bottom: 50px;
  }

  #sqe-service-explorer-{{ section.id }} .explorer-wrapper {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 40px;
  }

  /* ===== SERVICE LIST - scoped ===== */
  #sqe-service-explorer-{{ section.id }} .service-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  #sqe-service-explorer-{{ section.id }} .service-list-empty {
    background: white;
    padding: 40px 20px;
    border-radius: 8px;
    color: #999;
    font-size: 14px;
    text-align: center;
  }

  #sqe-service-explorer-{{ section.id }} .service-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    background: white;
    border-radius: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  #sqe-service-explorer-{{ section.id }} .service-item:hover,
  #sqe-service-explorer-{{ section.id }} .service-item.active {
    border-color: var(--sqe-accent-color);
    background-color: #FFFFFF;
    box-shadow: 0 4px 12px rgba(31, 58, 95, 0.1);
  }

  #sqe-service-explorer-{{ section.id }} .service-number {
    font-size: 20px;
    font-weight: 700;
    color: var(--sqe-accent-color);
    min-width: 30px;
    flex-shrink: 0;
  }

  #sqe-service-explorer-{{ section.id }} .service-title {
    font-size: 16px;
    font-weight: 600;
    color: #1F3A5F;
    margin: 0;
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* ===== DETAIL PANEL - scoped ===== */
  #sqe-service-explorer-{{ section.id }} .detail-panel {
    background: white;
    padding: 40px;
    border-radius: 8px;
    animation: sqeServiceExplorerFadeIn 0.3s ease;
  }

  @keyframes sqeServiceExplorerFadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  #sqe-service-explorer-{{ section.id }} .detail-content {
    width: 100%;
  }

  #sqe-service-explorer-{{ section.id }} .detail-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 30px;
    display: block;
  }

  #sqe-service-explorer-{{ section.id }} .detail-image-placeholder {
    background-color: #F2F4F7;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  #sqe-service-explorer-{{ section.id }} .detail-image-placeholder svg {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.3;
  }

  #sqe-service-explorer-{{ section.id }} .detail-title {
    font-size: 32px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 20px;
    margin-top: 0;
  }

  #sqe-service-explorer-{{ section.id }} .detail-description {
    font-size: 16px;
    color: #333333;
    line-height: 1.6;
    margin-bottom: 25px;
  }

  #sqe-service-explorer-{{ section.id }} .detail-features {
    margin-bottom: 25px;
    padding: 20px;
    background-color: #F2F4F7;
    border-radius: 6px;
  }

  #sqe-service-explorer-{{ section.id }} .detail-features h4 {
    font-size: 14px;
    font-weight: 600;
    color: #1F3A5F;
    margin-bottom: 10px;
    margin-top: 0;
    text-transform: uppercase;
  }

  #sqe-service-explorer-{{ section.id }} .detail-features p {
    font-size: 14px;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }

  #sqe-service-explorer-{{ section.id }} .detail-link {
    display: inline-block;
    padding: 12px 30px;
    background-color: #1F3A5F;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  #sqe-service-explorer-{{ section.id }} .detail-link:hover {
    background-color: #142a45;
  }

  /* ===== RESPONSIVE DESIGN ===== */
  @media (max-width: 768px) {
    #sqe-service-explorer-{{ section.id }} {
      padding: 40px 16px;
    }

    #sqe-service-explorer-{{ section.id }} .explorer-wrapper {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    #sqe-service-explorer-{{ section.id }} .service-list {
      flex-direction: row;
      overflow-x: auto;
      padding-bottom: 10px;
    }

    #sqe-service-explorer-{{ section.id }} .service-item {
      flex: 0 0 150px;
      flex-direction: column;
      text-align: center;
      justify-content: center;
    }

    #sqe-service-explorer-{{ section.id }} .service-title {
      white-space: normal;
    }

    #sqe-service-explorer-{{ section.id }} .detail-panel {
      padding: 20px;
    }

    #sqe-service-explorer-{{ section.id }} .explorer-heading {
      font-size: 32px;
    }

    #sqe-service-explorer-{{ section.id }} .explorer-subheading {
      font-size: 16px;
    }

    #sqe-service-explorer-{{ section.id }} .detail-title {
      font-size: 24px;
    }

    #sqe-service-explorer-{{ section.id }} .detail-image {
      height: 250px;
    }
  }

  @media (max-width: 480px) {
    #sqe-service-explorer-{{ section.id }} {
      padding: 30px 12px;
    }

    #sqe-service-explorer-{{ section.id }} .explorer-heading {
      font-size: 24px;
    }

    #sqe-service-explorer-{{ section.id }} .explorer-subheading {
      font-size: 14px;
    }

    #sqe-service-explorer-{{ section.id }} .service-item {
      padding: 12px 16px;
    }

    #sqe-service-explorer-{{ section.id }} .service-title {
      font-size: 14px;
    }

    #sqe-service-explorer-{{ section.id }} .detail-image {
      height: 200px;
    }

    #sqe-service-explorer-{{ section.id }} .detail-title {
      font-size: 20px;
    }

    #sqe-service-explorer-{{ section.id }} .detail-description {
      font-size: 14px;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var el = document.getElementById('sqe-service-explorer-' + sectionId);
    if (!el) return;

    var serviceItems = el.querySelectorAll('.service-item');
    var detailPanel = el.querySelector('.detail-panel');
    var detailContent = detailPanel ? detailPanel.querySelector('.detail-content') : null;

    if (!detailContent) return;

    // Add click handlers to service items
    serviceItems.forEach(function(item) {
      item.addEventListener('click', function() {
        var serviceId = this.getAttribute('data-service-id');
        var template = el.querySelector('#service-template-' + serviceId);

        if (!template) return;

        // Remove active class from all items
        serviceItems.forEach(function(i) {
          i.classList.remove('active');
        });

        // Add active class to clicked item
        this.classList.add('active');

        // Clone template content and insert into detail panel
        var clone = template.content.cloneNode(true);
        detailContent.innerHTML = '';
        detailContent.appendChild(clone);
      });
    });

    // Activate first service by default
    if (serviceItems.length > 0) {
      serviceItems[0].classList.add('active');
      var firstServiceId = serviceItems[0].getAttribute('data-service-id');
      var firstTemplate = el.querySelector('#service-template-' + firstServiceId);
      if (firstTemplate) {
        var firstClone = firstTemplate.content.cloneNode(true);
        detailContent.innerHTML = '';
        detailContent.appendChild(firstClone);
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Service Explorer",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Services"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Services"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore what we offer"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#F2B705"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F4F7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Features"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Service Image"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Learn More"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Explorer"
    }
  ]
}
{% endschema %}
