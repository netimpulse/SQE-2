          "default": "Lifespan"
        },
        {
          "type": "text",
          "id": "stat_value_2",
          "label": "Stat 2 Value",
          "default": "25+ Years"
        },
        {
          "type": "text",
          "id": "stat_label_3",
          "label": "Stat 3 Label",
          "default": "ROI"
        },
        {
          "type": "text",
          "id": "stat_value_3",
          "label": "Stat 3 Value",
          "default": "7-10 Years"
        },
        {
          "type": "color",
          "id": "accent_color",
          "label": "Accent Color",
          "default": "#F2B705"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Service Explorer",
      "blocks": [
        {
          "type": "service",
          "settings": {
            "service_title": "Solar Installation",
            "service_excerpt": "Complete solar system setup",
            "service_description": "Professional installation of state-of-the-art solar panel systems tailored to your home or business.",
            "benefits": "Expert installation|25-year warranty|Maximum efficiency|Financial incentives eligible",
            "stat_label_1": "Efficiency",
