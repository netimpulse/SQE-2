{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign accent_color = section.settings.accent_color
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color
-%}

<section id="sqe-service-explorer-{{ section.id }}" class="sqe-service-explorer">
  <div class="explorer-container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if heading %}
      <h2 class="explorer-heading" style="font-family:{{ h_font }};font-size:{{ h_size }}px;color:{{ h_color }};font-weight:{{ h_weight }};">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="explorer-subheading" style="font-family:{{ sh_font }};font-size:{{ sh_size }}px;color:{{ sh_color }};">{{ subheading }}</p>
    {% endif %}

    <div class="explorer-wrapper">
      <div class="service-list">
        {% for block in section.blocks %}
          <div class="service-item" data-service-id="{{ block.id }}" data-service-title="{{ block.settings.title | escape }}" data-service-description="{{ block.settings.description | escape }}" data-service-features="{{ block.settings.features | escape }}" data-service-link="{{ block.settings.link_url | escape }}" data-service-link-text="{{ block.settings.link_text | escape }}" {% if block.settings.image %}data-service-image="{{ block.settings.image | img_url: '500x400' }}"{% endif %}>
            <div class="service-number">{{ forloop.index }}</div>
            <h3 class="service-title">{{ block.settings.title }}</h3>
          </div>
        {% endfor %}
      </div>

      {% if section.blocks.size > 0 %}
        {% assign first_block = section.blocks.first %}
        <div class="detail-panel" data-service-id="{{ first_block.id }}">
          <div class="detail-content">
            {% if first_block.settings.image %}
              <img src="{{ first_block.settings.image | img_url: '500x400' }}" alt="{{ first_block.settings.title }}" class="detail-image">
            {% endif %}
            <h3 class="detail-title">{{ first_block.settings.title }}</h3>
            {% if first_block.settings.description %}
              <p class="detail-description">{{ first_block.settings.description }}</p>
            {% endif %}
            {% if first_block.settings.features %}
              <div class="detail-features">
                <h4>Features</h4>
                <p>{{ first_block.settings.features }}</p>
              </div>
            {% endif %}
            {% if first_block.settings.link_url %}
              <a href="{{ first_block.settings.link_url }}" class="detail-link" style="color: {{ accent_color }};">
                {{ first_block.settings.link_text | default: 'Learn More' }}
              </a>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>
  </div>
</section>

<style>
  #sqe-service-explorer-{{ section.id }} {
    padding: 60px 20px;
    background-color: #F2F4F7;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-service-explorer-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: #C75B12; background: rgba(199,91,18,.1);
    padding: 4px 14px; border-radius: 20px; margin-bottom: 12px;
  }

  .explorer-container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .explorer-heading {
    font-size: 48px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
    text-align: center;
  }

  .explorer-subheading {
    font-size: 18px;
    color: #333333;
    text-align: center;
    margin-bottom: 50px;
  }

  .explorer-wrapper {
    display: grid;
    grid-template-columns: 350px 1fr;
    gap: 40px;
  }

  .service-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .service-item {
    display: flex;
    align-items: center;
    gap: 15px;
    padding: 15px 20px;
    background: white;
    border-radius: 8px;
    cursor: pointer;
    border: 2px solid transparent;
    transition: all 0.3s ease;
  }

  .service-item:hover,
  .service-item.active {
    border-color: {{ section.settings.accent_color | default: '#F2B705' }};
    background-color: #FFFFFF;
    box-shadow: 0 4px 12px rgba(31, 58, 95, 0.1);
  }

  .service-number {
    font-size: 20px;
    font-weight: 700;
    color: {{ section.settings.accent_color | default: '#F2B705' }};
    min-width: 30px;
  }

  .service-title {
    font-size: 16px;
    font-weight: 600;
    color: #1F3A5F;
    margin: 0;
  }

  .detail-panel {
    background: white;
    padding: 40px;
    border-radius: 8px;
    animation: fadeIn 0.3s ease;
  }

  @keyframes fadeIn {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  .detail-image {
    width: 100%;
    height: 300px;
    object-fit: cover;
    border-radius: 8px;
    margin-bottom: 30px;
  }

  .detail-title {
    font-size: 32px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 20px;
  }

  .detail-description {
    font-size: 16px;
    color: #333333;
    line-height: 1.6;
    margin-bottom: 25px;
  }

  .detail-features {
    margin-bottom: 25px;
    padding: 20px;
    background-color: #F2F4F7;
    border-radius: 6px;
  }

  .detail-features h4 {
    font-size: 14px;
    font-weight: 600;
    color: #1F3A5F;
    margin-bottom: 10px;
    text-transform: uppercase;
  }

  .detail-features p {
    font-size: 14px;
    color: #666;
    margin: 0;
    line-height: 1.5;
  }

  .detail-link {
    display: inline-block;
    padding: 12px 30px;
    background-color: #1F3A5F;
    color: white;
    text-decoration: none;
    border-radius: 6px;
    font-weight: 600;
    transition: background-color 0.3s ease;
  }

  .detail-link:hover {
    background-color: #142a45;
  }

  @media (max-width: 768px) {
    #sqe-service-explorer-{{ section.id }} {
      padding: 40px 16px;
    }

    .explorer-wrapper {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .service-list {
      flex-direction: row;
      overflow-x: auto;
      padding-bottom: 10px;
    }

    .service-item {
      flex: 0 0 150px;
      flex-direction: column;
      text-align: center;
      justify-content: center;
    }

    .detail-panel {
      padding: 20px;
    }

    .explorer-heading {
      font-size: 32px;
    }

    .explorer-subheading {
      font-size: 16px;
    }

    .detail-title {
      font-size: 24px;
    }
  }

  @media (max-width: 480px) {
    #sqe-service-explorer-{{ section.id }} {
      padding: 30px 12px;
    }

    .explorer-heading {
      font-size: 24px;
    }

    .explorer-subheading {
      font-size: 14px;
    }

    .service-item {
      padding: 12px 16px;
    }

    .service-title {
      font-size: 14px;
    }

    .detail-image {
      height: 200px;
    }

    .detail-title {
      font-size: 20px;
    }

    .detail-description {
      font-size: 14px;
    }
  }
</style>

<script>
  (function() {
    var el = document.getElementById('sqe-service-explorer-' + '{{ section.id }}');
    if (!el) return;

    var serviceItems = el.querySelectorAll('.service-item');
    var detailPanel = el.querySelector('.detail-panel');

    serviceItems.forEach(function(item) {
      item.addEventListener('click', function() {
        serviceItems.forEach(function(i) { i.classList.remove('active'); });
        this.classList.add('active');

        var title = this.getAttribute('data-service-title');
        var desc = this.getAttribute('data-service-description');
        var features = this.getAttribute('data-service-features');
        var link = this.getAttribute('data-service-link');
        var linkText = this.getAttribute('data-service-link-text');
        var img = this.getAttribute('data-service-image');

        var html = '';
        if (img) {
          html += '<img src="' + img + '" alt="' + title + '" class="detail-image">';
        }
        html += '<h3 class="detail-title">' + title + '</h3>';
        if (desc) {
          html += '<p class="detail-description">' + desc + '</p>';
        }
        if (features) {
          html += '<div class="detail-features"><h4>Features</h4><p>' + features + '</p></div>';
        }
        if (link) {
          var accentColor = '{{ section.settings.accent_color | default: "#F2B705" }}';
          html += '<a href="' + link + '" class="detail-link" style="color: ' + accentColor + ';">' + (linkText || 'Learn More') + '</a>';
        }

        detailPanel.innerHTML = html;
      });
    });

    if (serviceItems.length > 0) {
      serviceItems[0].classList.add('active');
    }
  })();
</script>

{% schema %}
{
  "name": "Service Explorer",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Services"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Services"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Explore what we offer"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#F2B705"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#333333"
    }
  ],
  "blocks": [
    {
      "type": "service",
      "name": "Service",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "textarea",
          "id": "features",
          "label": "Features"
        },
        {
          "type": "image_picker",
          "id": "image",
          "label": "Service Image"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Learn More"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Service Explorer"
    }
  ]
}
{% endschema %}
