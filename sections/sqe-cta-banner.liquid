{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_font_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign d_font = section.settings.description_font
  assign d_size = section.settings.description_font_size
  assign d_color = section.settings.description_color
-%}

<style>
  #sqe-cta-banner-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    background-image: {% if section.settings.background_image %}url('{{ section.settings.background_image | image_url: width: 1920 }}'){% endif %};
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_x }}px;
    position: relative;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-cta-banner-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: #C75B12; background: rgba(199,91,18,.1);
    padding: 4px 14px; border-radius: 20px; margin-bottom: 12px;
  }

  {% if section.settings.show_overlay %}
    .sqe-cta-banner::before {
      content: '';
      position: absolute;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background-color: rgba({{ section.settings.overlay_color | color_to_rgb }}, {{ section.settings.overlay_opacity }});
      z-index: 1;
    }
  {% endif %}

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__content {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1200px;
    padding: 0 20px;
    text-align: {{ section.settings.text_alignment }};
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__heading {
    font-family: {{ h_font }};
    font-size: {{ h_size }}px;
    font-weight: {{ h_weight }};
    color: {{ h_color }};
    margin: 0 0 20px 0;
    line-height: 1.2;
    letter-spacing: -0.5px;
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__description {
    font-family: {{ d_font }};
    font-size: {{ d_size }}px;
    color: {{ d_color }};
    margin: 0 0 40px 0;
    line-height: 1.6;
    max-width: 800px;
    {% if section.settings.text_alignment == 'center' %}
      margin-left: auto;
      margin-right: auto;
    {% endif %}
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__buttons {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: {{ section.settings.text_alignment }};
    {% if section.settings.text_alignment == 'center' %}
      justify-content: center;
    {% elsif section.settings.text_alignment == 'right' %}
      justify-content: flex-end;
    {% else %}
      justify-content: flex-start;
    {% endif %}
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button {
    display: inline-block;
    padding: {{ section.settings.button_padding_y }}px {{ section.settings.button_padding_x }}px;
    border-radius: {{ section.settings.button_border_radius }}px;
    text-decoration: none;
    font-family: 'Inter', sans-serif;
    font-weight: 600;
    font-size: 16px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button--primary {
    background-color: {{ section.settings.button_primary_bg }};
    color: {{ section.settings.button_primary_text }};
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button--primary:hover {
    background-color: {{ section.settings.button_primary_bg_hover }};
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button--secondary {
    background-color: {{ section.settings.button_secondary_bg }};
    color: {{ section.settings.button_secondary_text }};
    border: 2px solid {{ section.settings.button_secondary_border }};
  }

  #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button--secondary:hover {
    background-color: {{ section.settings.button_secondary_bg_hover }};
    border-color: {{ section.settings.button_secondary_border }};
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.1);
  }

  @media (max-width: 768px) {
    #sqe-cta-banner-{{ section.id }} {
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_x }}px {{ section.settings.mobile_padding_bottom }}px {{ section.settings.mobile_padding_x }}px;
      min-height: auto;
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__heading {
      font-size: {{ section.settings.mobile_heading_font_size }}px;
      margin-bottom: 15px;
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__description {
      font-size: {{ section.settings.mobile_description_font_size }}px;
      margin-bottom: 30px;
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__buttons {
      flex-direction: column;
      {% if section.settings.text_alignment != 'center' %}
        align-items: stretch;
      {% endif %}
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button {
      text-align: center;
    }

    {% if section.settings.mobile_full_width_buttons %}
      #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__buttons {
        flex-direction: column;
      }

      #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button {
        width: 100%;
      }
    {% endif %}
  }

  @media (max-width: 480px) {
    #sqe-cta-banner-{{ section.id }} {
      padding: {{ section.settings.mobile_padding_top | minus: 10 }}px {{ section.settings.mobile_padding_x | minus: 5 }}px {{ section.settings.mobile_padding_bottom | minus: 10 }}px {{ section.settings.mobile_padding_x | minus: 5 }}px;
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__heading {
      font-size: {{ section.settings.mobile_heading_font_size | minus: 3 }}px;
      margin-bottom: 12px;
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__description {
      font-size: {{ section.settings.mobile_description_font_size | minus: 2 }}px;
      margin-bottom: 24px;
    }

    #sqe-cta-banner-{{ section.id }} .sqe-cta-banner__button {
      padding: {{ section.settings.button_padding_y | minus: 3 }}px {{ section.settings.button_padding_x | minus: 8 }}px;
      font-size: 14px;
    }
  }
</style>

<div id="sqe-cta-banner-{{ section.id }}" class="sqe-cta-banner">
  <div class="sqe-cta-banner__content">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if section.settings.heading %}
      <h2 class="sqe-cta-banner__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    {% if section.settings.description %}
      <p class="sqe-cta-banner__description">{{ section.settings.description }}</p>
    {% endif %}

    {% if section.settings.button_1_text or section.settings.button_2_text %}
      <div class="sqe-cta-banner__buttons">
        {% if section.settings.button_1_text %}
          <a href="{{ section.settings.button_1_url }}" class="sqe-cta-banner__button sqe-cta-banner__button--primary">
            {{ section.settings.button_1_text }}
          </a>
        {% endif %}

        {% if section.settings.button_2_text %}
          <a href="{{ section.settings.button_2_url }}" class="sqe-cta-banner__button sqe-cta-banner__button--secondary">
            {{ section.settings.button_2_text }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>
</div>

{% schema %}
{
  "name": "SQE CTA Banner",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Call to Action"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Level up your solar potential"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>Get expert guidance from our team of UK solar PV engineers. We provide quality assurance and consultancy services for residential and commercial solar projects.</p>"
    },
    {
      "type": "header",
      "content": "Button 1"
    },
    {
      "type": "text",
      "id": "button_1_text",
      "label": "Button Text",
      "default": "Get Started"
    },
    {
      "type": "url",
      "id": "button_1_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Button 2"
    },
    {
      "type": "text",
      "id": "button_2_text",
      "label": "Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "button_2_url",
      "label": "Button Link"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#1F3A5F"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image"
    },
    {
      "type": "checkbox",
      "id": "show_overlay",
      "label": "Show Overlay",
      "default": true
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#000000"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "label": "Overlay Opacity",
      "min": 0,
      "max": 1,
      "step": 0.1,
      "default": 0.3
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top (Desktop)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Padding Bottom (Desktop)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_x",
      "label": "Padding Left/Right (Desktop)",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_top",
      "label": "Padding Top (Mobile)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_bottom",
      "label": "Padding Bottom (Mobile)",
      "min": 20,
      "max": 200,
      "step": 10,
      "default": 40
    },
    {
      "type": "range",
      "id": "mobile_padding_x",
      "label": "Padding Left/Right (Mobile)",
      "min": 0,
      "max": 100,
      "step": 10,
      "default": 20
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Minimum Height (Desktop)",
      "min": 200,
      "max": 600,
      "step": 50,
      "default": 400
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Description Typography"
    },
    {
      "type": "select",
      "id": "description_font",
      "label": "Description font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (Desktop)",
      "min": 24,
      "max": 72,
      "step": 2,
      "default": 48
    },
    {
      "type": "range",
      "id": "mobile_heading_font_size",
      "label": "Heading Font Size (Mobile)",
      "min": 18,
      "max": 48,
      "step": 2,
      "default": 28
    },
    {
      "type": "range",
      "id": "description_font_size",
      "label": "Description Font Size (Desktop)",
      "min": 14,
      "max": 28,
      "step": 1,
      "default": 18
    },
    {
      "type": "range",
      "id": "mobile_description_font_size",
      "label": "Description Font Size (Mobile)",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 14
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Button Styling"
    },
    {
      "type": "range",
      "id": "button_padding_y",
      "label": "Button Padding (Top/Bottom)",
      "min": 8,
      "max": 24,
      "step": 2,
      "default": 14
    },
    {
      "type": "range",
      "id": "button_padding_x",
      "label": "Button Padding (Left/Right)",
      "min": 16,
      "max": 48,
      "step": 2,
      "default": 32
    },
    {
      "type": "range",
      "id": "button_border_radius",
      "label": "Button Border Radius",
      "min": 0,
      "max": 50,
      "step": 2,
      "default": 4
    },
    {
      "type": "color",
      "id": "button_primary_bg",
      "label": "Primary Button Background",
      "default": "#F2B705"
    },
    {
      "type": "color",
      "id": "button_primary_bg_hover",
      "label": "Primary Button Background (Hover)",
      "default": "#D99D00"
    },
    {
      "type": "color",
      "id": "button_primary_text",
      "label": "Primary Button Text",
      "default": "#1F3A5F"
    },
    {
      "type": "color",
      "id": "button_secondary_bg",
      "label": "Secondary Button Background",
      "default": "transparent"
    },
    {
      "type": "color",
      "id": "button_secondary_bg_hover",
      "label": "Secondary Button Background (Hover)",
      "default": "rgba(255, 255, 255, 0.1)"
    },
    {
      "type": "color",
      "id": "button_secondary_text",
      "label": "Secondary Button Text",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "button_secondary_border",
      "label": "Secondary Button Border",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Mobile Settings"
    },
    {
      "type": "checkbox",
      "id": "mobile_full_width_buttons",
      "label": "Full Width Buttons on Mobile",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "SQE CTA Banner"
    }
  ]
}
{% endschema %}
