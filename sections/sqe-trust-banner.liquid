{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign show_ticker = section.settings.show_ticker
  assign bg_color = section.settings.background_color
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
-%}

<section id="sqe-trust-banner-{{ section.id }}" class="sqe-trust-banner" style="--sqe-bg-color: {{ bg_color }}; --sqe-heading-font: {{ h_font }}; --sqe-heading-size: {{ h_size }}px; --sqe-heading-color: {{ h_color }}; --sqe-heading-weight: {{ h_weight }}; --sqe-desc-font: {{ section.settings.description_font | default: \"'Inter', sans-serif\" }}; --sqe-desc-size: {{ section.settings.description_size | default: 16 }}px; --sqe-desc-color: {{ section.settings.description_color | default: '#666' }};">
  <div class="sqe-trust-banner__container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-trust-banner__label">{{ label_text }}</span>
    {%- endif -%}
    {% if heading != blank %}
      <h2 class="sqe-trust-banner__heading">{{ heading }}</h2>
    {% else %}
      <h2 class="sqe-trust-banner__heading sqe-trust-banner__heading--empty">Credentials</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="sqe-trust-banner__subheading">{{ subheading }}</p>
    {% else %}
      <p class="sqe-trust-banner__subheading sqe-trust-banner__subheading--empty">Add your credentials</p>
    {% endif %}

    <div class="sqe-trust-banner__grid">
      {% for block in section.blocks %}
        {% if block.type == 'credential' %}
          <div class="sqe-trust-banner__card" {{ block.shopify_attributes }}>
            {% if block.settings.credential_name != blank %}
              <h3 class="sqe-trust-banner__card-name">{{ block.settings.credential_name }}</h3>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="sqe-trust-banner__card-description">{{ block.settings.description }}</p>
            {% endif %}

            {% if block.settings.issuer != blank %}
              <p class="sqe-trust-banner__card-issuer">{{ block.settings.issuer }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if show_ticker %}
      <div class="sqe-trust-banner__ticker">
        <div class="sqe-trust-banner__ticker-track">
          {% for block in section.blocks %}
            {% if block.type == 'credential' %}
              <span class="sqe-trust-banner__ticker-badge">{{ block.settings.credential_name }}</span>
            {% endif %}
          {% endfor %}
          {% for block in section.blocks %}
            {% if block.type == 'credential' %}
              <span class="sqe-trust-banner__ticker-badge">{{ block.settings.credential_name }}</span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #sqe-trust-banner-{{ section.id }} {
    --sqe-label-color: #C75B12;
    --sqe-label-bg: rgba(199, 91, 18, 0.1);
    --sqe-card-bg: #FFFFFF;
    --sqe-card-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    --sqe-card-shadow-hover: 0 8px 16px rgba(0, 0, 0, 0.15);
    --sqe-card-transform: translateY(-4px);
    --sqe-primary-blue: #1F3A5F;
    --sqe-text-light: #999999;
    --sqe-badge-bg: #F2F4F7;
    --sqe-padding-lg: 60px;
    --sqe-padding-h: 20px;
    background-color: var(--sqe-bg-color);
    padding: {{ section.settings.padding_top }}px var(--sqe-padding-h) var(--sqe-padding-lg) var(--sqe-padding-h);
  }

  /* Section label (orange pill) */
  #sqe-trust-banner-{{ section.id }} .sqe-trust-banner__label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sqe-label-color);
    background-color: var(--sqe-label-bg);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    overflow-wrap: break-word;
  }

  .sqe-trust-banner__container {
    max-width: 1200px;
    margin: 0 auto;
    text-align: center;
  }

  .sqe-trust-banner__heading {
    font-family: var(--sqe-heading-font);
    font-size: var(--sqe-heading-size);
    font-weight: var(--sqe-heading-weight);
    color: var(--sqe-heading-color);
    text-align: center;
    margin-bottom: 10px;
    letter-spacing: -0.5px;
    overflow-wrap: break-word;
  }

  .sqe-trust-banner__heading--empty {
    color: #999999;
    opacity: 0.5;
  }

  .sqe-trust-banner__subheading {
    font-family: var(--sqe-desc-font);
    font-size: var(--sqe-desc-size);
    color: var(--sqe-desc-color);
    text-align: center;
    margin-bottom: 40px;
    line-height: 1.6;
    overflow-wrap: break-word;
  }

  .sqe-trust-banner__subheading--empty {
    color: #999999;
    opacity: 0.5;
  }

  .sqe-trust-banner__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }

  .sqe-trust-banner__card {
    background-color: var(--sqe-card-bg);
    padding: 30px;
    border-radius: 8px;
    text-align: center;
    box-shadow: var(--sqe-card-shadow);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sqe-trust-banner__card:hover {
    transform: var(--sqe-card-transform);
    box-shadow: var(--sqe-card-shadow-hover);
  }

  .sqe-trust-banner__card-name {
    font-family: var(--sqe-heading-font);
    font-size: 18px;
    font-weight: 700;
    color: var(--sqe-primary-blue);
    margin-bottom: 10px;
    overflow-wrap: break-word;
  }

  .sqe-trust-banner__card-description {
    font-family: var(--sqe-desc-font);
    font-size: 14px;
    color: #666666;
    line-height: 1.6;
    margin-bottom: 10px;
    overflow-wrap: break-word;
  }

  .sqe-trust-banner__card-issuer {
    font-family: var(--sqe-desc-font);
    font-size: 12px;
    color: var(--sqe-text-light);
    margin: 0;
    overflow-wrap: break-word;
  }

  .sqe-trust-banner__ticker {
    background-color: var(--sqe-card-bg);
    padding: 20px 0;
    border-radius: 8px;
    overflow: hidden;
    margin-top: 40px;
  }

  .sqe-trust-banner__ticker-track {
    display: flex;
    gap: 30px;
    animation: sqe-trust-banner-ticker-scroll 30s linear infinite;
    width: max-content;
  }

  .sqe-trust-banner__ticker-badge {
    display: inline-block;
    background-color: var(--sqe-badge-bg);
    color: var(--sqe-primary-blue);
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
    overflow-wrap: break-word;
  }

  @keyframes sqe-trust-banner-ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    #sqe-trust-banner-{{ section.id }} {
      --sqe-padding-lg: 45px;
      --sqe-padding-h: 16px;
    }

    .sqe-trust-banner__grid {
      grid-template-columns: repeat(2, 1fr);
      gap: 20px;
    }

    .sqe-trust-banner__heading {
      font-size: 28px;
      margin-bottom: 8px;
    }

    .sqe-trust-banner__subheading {
      font-size: 15px;
      margin-bottom: 30px;
    }

    .sqe-trust-banner__card {
      padding: 20px;
    }

    .sqe-trust-banner__ticker-badge {
      padding: 8px 16px;
      font-size: 11px;
    }
  }

  @media (max-width: 480px) {
    #sqe-trust-banner-{{ section.id }} {
      --sqe-padding-lg: 30px;
      --sqe-padding-h: 12px;
    }

    .sqe-trust-banner__grid {
      grid-template-columns: 1fr;
      gap: 15px;
    }

    .sqe-trust-banner__heading {
      font-size: 22px;
      margin-bottom: 6px;
    }

    .sqe-trust-banner__subheading {
      font-size: 14px;
      margin-bottom: 24px;
    }

    .sqe-trust-banner__card {
      padding: 16px;
    }

    .sqe-trust-banner__card-name {
      font-size: 16px;
    }

    .sqe-trust-banner__card-description {
      font-size: 13px;
    }

    .sqe-trust-banner__card-issuer {
      font-size: 11px;
    }

    .sqe-trust-banner__ticker-badge {
      padding: 6px 12px;
      font-size: 10px;
    }
  }
</style>

<script>
  (function() {
    var trustBannerSection = document.getElementById('sqe-trust-banner-' + '{{ section.id }}');
    if (!trustBannerSection) return;

    var cards = trustBannerSection.querySelectorAll('.sqe-trust-banner__card');
    if (cards.length === 0) return;

    cards.forEach(function(card) {
      card.addEventListener('mouseenter', function() {
        this.style.transform = 'var(--sqe-card-transform)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0)';
      });
    });
  })();
</script>

{% schema %}
{
  "name": "SQE Trust Banner",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Vertrauen"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trust & Certifications"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Industry recognized credentials"
    },
    {
      "type": "checkbox",
      "id": "show_ticker",
      "label": "Show Ticker",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 36
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Description Typography"
    },
    {
      "type": "select",
      "id": "description_font",
      "label": "Description font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "text",
          "id": "credential_name",
          "label": "Credential Name",
          "default": "Certification"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Credential details"
        },
        {
          "type": "text",
          "id": "issuer",
          "label": "Issuer",
          "default": "Organization"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Trust Banner",
      "blocks": [
        { "type": "credential" },
        { "type": "credential" },
        { "type": "credential" }
      ]
    }
  ]
}
{% endschema %}
