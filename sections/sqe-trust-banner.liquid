{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign show_ticker = section.settings.show_ticker
  assign bg_color = section.settings.background_color
-%}

<section id="sqe-trust-banner-{{ section.id }}" class="sqe-trust-banner" style="background-color: {{ bg_color }};">
  <div class="sqe-trust-container">
    {% if heading != blank %}
      <h2 class="sqe-trust-heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="sqe-trust-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="sqe-credentials-grid">
      {% for block in section.blocks %}
        {% if block.type == 'credential' %}
          <div class="sqe-credential-card" {{ block.shopify_attributes }}>
            {% if block.settings.credential_name != blank %}
              <h3 class="sqe-credential-name">{{ block.settings.credential_name }}</h3>
            {% endif %}

            {% if block.settings.description != blank %}
              <p class="sqe-credential-description">{{ block.settings.description }}</p>
            {% endif %}

            {% if block.settings.issuer != blank %}
              <p class="sqe-credential-issuer">{{ block.settings.issuer }}</p>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>

    {% if show_ticker %}
      <div class="sqe-ticker-wrapper">
        <div class="sqe-ticker-track">
          {% for block in section.blocks %}
            {% if block.type == 'credential' %}
              <span class="sqe-ticker-badge">{{ block.settings.credential_name }}</span>
            {% endif %}
          {% endfor %}
          {% for block in section.blocks %}
            {% if block.type == 'credential' %}
              <span class="sqe-ticker-badge">{{ block.settings.credential_name }}</span>
            {% endif %}
          {% endfor %}
        </div>
      </div>
    {% endif %}
  </div>
</section>

<style>
  #sqe-trust-banner-{{ section.id }} {
    padding: 60px 20px;
  }

  .sqe-trust-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sqe-trust-heading {
    font-size: 36px;
    font-weight: 700;
    color: #1F3A5F;
    text-align: center;
    margin-bottom: 10px;
  }

  .sqe-trust-subheading {
    font-size: 16px;
    color: #666;
    text-align: center;
    margin-bottom: 40px;
  }

  .sqe-credentials-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 30px;
    margin-bottom: 40px;
  }

  .sqe-credential-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    text-align: center;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sqe-credential-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .sqe-credential-name {
    font-size: 18px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
  }

  .sqe-credential-description {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 10px;
  }

  .sqe-credential-issuer {
    font-size: 12px;
    color: #999;
    margin: 0;
  }

  .sqe-ticker-wrapper {
    background: white;
    padding: 20px 0;
    border-radius: 8px;
    overflow: hidden;
    margin-top: 40px;
  }

  .sqe-ticker-track {
    display: flex;
    gap: 30px;
    animation: sqe-ticker-scroll 30s linear infinite;
    width: max-content;
  }

  .sqe-ticker-badge {
    display: inline-block;
    background: #F2F4F7;
    color: #1F3A5F;
    padding: 10px 20px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    white-space: nowrap;
  }

  @keyframes sqe-ticker-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  @media (max-width: 768px) {
    .sqe-credentials-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .sqe-trust-heading {
      font-size: 28px;
    }
  }

  @media (max-width: 480px) {
    .sqe-credentials-grid {
      grid-template-columns: 1fr;
    }

    .sqe-trust-heading {
      font-size: 24px;
    }
  }
</style>

<script>
  var trustBannerSection = document.getElementById('sqe-trust-banner-' + '{{ section.id }}');
  if (trustBannerSection) {
    var cards = trustBannerSection.querySelectorAll('.sqe-credential-card');
    cards.forEach(function(card) {
      card.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-4px)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0)';
      });
    });
  }
</script>

{% schema %}
{
  "name": "SQE Trust Banner",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Trust & Certifications"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Industry recognized credentials"
    },
    {
      "type": "checkbox",
      "id": "show_ticker",
      "label": "Show Ticker",
      "default": true
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "text",
          "id": "credential_name",
          "label": "Credential Name",
          "default": "Certification"
        },
        {
          "type": "text",
          "id": "description",
          "label": "Description",
          "default": "Credential details"
        },
        {
          "type": "text",
          "id": "issuer",
          "label": "Issuer",
          "default": "Organization"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Trust Banner",
      "blocks": [
        { "type": "credential" },
        { "type": "credential" },
        { "type": "credential" }
      ]
    }
  ]
}
{% endschema %}
