{%- liquid
  assign show_header = section.settings.show_header
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign heading_font = section.settings.heading_font
  assign heading_size = section.settings.heading_size
  assign heading_color = section.settings.heading_color
  assign heading_bold = section.settings.heading_bold
  assign sub_font = section.settings.sub_font
  assign sub_size = section.settings.sub_size
  assign sub_color = section.settings.sub_color
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text

  assign heading_weight = '700'
  if heading_bold == false
    assign heading_weight = '400'
  endif
-%}

<style>
  :root {
    --sqe-primary-gold: #F2B705;
    --sqe-primary-orange: #C75B12;
    --sqe-dark-bg: #0a1929;
    --sqe-dark-accent: #1F3A5F;
    --sqe-dark-light: #0f2a47;
    --sqe-white-primary: rgba(255, 255, 255, 0.95);
    --sqe-white-border: rgba(255, 255, 255, 0.2);
    --sqe-white-hover: rgba(255, 255, 255, 0.4);
    --sqe-card-shadow: 0 20px 40px rgba(31, 58, 95, 0.1);
    --sqe-card-shadow-hover: 0 30px 60px rgba(31, 58, 95, 0.2);
    --sqe-label-bg: rgba(199, 91, 18, 0.15);
    --sqe-gray-text: #999;
    --sqe-transition: 0.4s ease;
  }

  /* ===== CONTAINER ===== */
  #sqe-stats-{{ section.id }} {
    --sqe-heading-font: {{ heading_font }};
    --sqe-heading-size: {{ heading_size }}px;
    --sqe-heading-color: {{ heading_color }};
    --sqe-heading-weight: {{ heading_weight }};
    --sqe-sub-font: {{ sub_font }};
    --sqe-sub-size: {{ sub_size }}px;
    --sqe-sub-color: {{ sub_color }};

    padding: 100px 20px;
    background: linear-gradient(135deg, var(--sqe-dark-bg) 0%, var(--sqe-dark-accent) 50%, var(--sqe-dark-light) 100%);
    position: relative;
    overflow: hidden;
    font-family: 'Inter', sans-serif;
  }

  #sqe-stats-{{ section.id }} .sqe-stats-bg {
    position: absolute;
    inset: 0;
    overflow: hidden;
    z-index: 0;
  }

  #sqe-stats-{{ section.id }} .sqe-bg-shape {
    position: absolute;
    border-radius: 50%;
    opacity: 0.08;
    mix-blend-mode: screen;
  }

  #sqe-stats-{{ section.id }} .sqe-bg-s1 {
    width: 600px;
    height: 600px;
    background: radial-gradient(circle, var(--sqe-primary-gold) 0%, transparent 70%);
    top: -300px;
    left: -300px;
    animation: sqe-float1-{{ section.id }} 20s ease-in-out infinite;
  }

  #sqe-stats-{{ section.id }} .sqe-bg-s2 {
    width: 500px;
    height: 500px;
    background: radial-gradient(circle, var(--sqe-primary-orange) 0%, transparent 70%);
    bottom: -250px;
    right: -250px;
    animation: sqe-float2-{{ section.id }} 25s ease-in-out infinite;
  }

  @keyframes sqe-float1-{{ section.id }} {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-30px, 100px) scale(0.95); }
  }

  @keyframes sqe-float2-{{ section.id }} {
    0%, 100% { transform: translate(0, 0) scale(1); }
    50% { transform: translate(-50px, 50px) scale(1.08); }
  }

  /* Grid pattern */
  #sqe-stats-{{ section.id }} .sqe-grid-pat {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0.04;
    pointer-events: none;
    background-image:
      linear-gradient(0deg, transparent 24%, rgba(242, 183, 5, 0.5) 25%, rgba(242, 183, 5, 0.5) 26%, transparent 27%, transparent 74%, rgba(242, 183, 5, 0.5) 75%, rgba(242, 183, 5, 0.5) 76%, transparent 77%),
      linear-gradient(90deg, transparent 24%, rgba(242, 183, 5, 0.5) 25%, rgba(242, 183, 5, 0.5) 26%, transparent 27%, transparent 74%, rgba(242, 183, 5, 0.5) 75%, rgba(242, 183, 5, 0.5) 76%, transparent 77%);
    background-size: 100px 100px;
  }

  /* ===== SECTION LABEL ===== */
  #sqe-stats-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sqe-primary-orange);
    background: var(--sqe-label-bg);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
    overflow-wrap: break-word;
  }

  /* ===== HEADER ===== */
  #sqe-stats-{{ section.id }} .sqe-stats-inner {
    max-width: 1200px;
    margin: 0 auto;
    position: relative;
    z-index: 1;
  }

  #sqe-stats-{{ section.id }} .sqe-stats-hdr {
    text-align: center;
    margin-bottom: 80px;
  }

  #sqe-stats-{{ section.id }} .sqe-stats-hdr h2 {
    font-family: var(--sqe-heading-font);
    font-size: var(--sqe-heading-size);
    font-weight: var(--sqe-heading-weight);
    color: var(--sqe-heading-color);
    margin: 0 0 16px;
    letter-spacing: -0.8px;
    line-height: 1.2;
    overflow-wrap: break-word;
  }

  #sqe-stats-{{ section.id }} .sqe-stats-hdr p {
    font-family: var(--sqe-sub-font);
    font-size: var(--sqe-sub-size);
    color: var(--sqe-sub-color);
    margin: 0 auto;
    max-width: 600px;
    overflow-wrap: break-word;
  }

  /* ===== STATS GRID ===== */
  #sqe-stats-{{ section.id }} .sqe-stats-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
    gap: 30px;
  }

  /* Cards: VISIBLE by default (no opacity:0 that hides them if JS fails) */
  #sqe-stats-{{ section.id }} .sqe-stat-card {
    background: var(--sqe-white-primary);
    backdrop-filter: blur(20px);
    border: 1px solid var(--sqe-white-border);
    border-radius: 16px;
    padding: 40px 30px;
    text-align: center;
    overflow: hidden;
    box-shadow: var(--sqe-card-shadow);
    position: relative;
    transition: transform var(--sqe-transition), box-shadow var(--sqe-transition);
  }

  #sqe-stats-{{ section.id }} .sqe-stat-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 4px;
    background: linear-gradient(90deg, var(--sqe-primary-gold) 0%, var(--sqe-primary-orange) 100%);
  }

  #sqe-stats-{{ section.id }} .sqe-stat-card:hover {
    transform: translateY(-8px);
    box-shadow: var(--sqe-card-shadow-hover);
    border-color: var(--sqe-white-hover);
  }

  /* When JS is ready, hide cards for entrance animation */
  #sqe-stats-{{ section.id }}.sqe-js-ready .sqe-stat-card {
    opacity: 0;
    transform: translateY(40px);
    transition: all 0.6s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  #sqe-stats-{{ section.id }}.sqe-js-ready .sqe-stat-card.visible {
    opacity: 1;
    transform: translateY(0);
  }

  #sqe-stats-{{ section.id }}.sqe-js-ready .sqe-stat-card.visible:hover {
    transform: translateY(-8px);
  }

  /* Icon */
  #sqe-stats-{{ section.id }} .sqe-stat-icon {
    width: 70px;
    height: 70px;
    margin: 0 auto 25px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: linear-gradient(135deg, var(--sqe-primary-gold), var(--sqe-primary-orange));
    border-radius: 14px;
    font-size: 32px;
    color: #fff;
    font-weight: 700;
    flex-shrink: 0;
  }

  /* Number */
  #sqe-stats-{{ section.id }} .sqe-stat-number {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 48px;
    font-weight: 700;
    color: var(--sqe-dark-accent);
    margin: 0 0 8px;
    display: flex;
    align-items: baseline;
    justify-content: center;
    gap: 8px;
    flex-wrap: wrap;
  }

  #sqe-stats-{{ section.id }} .sqe-stat-counter {
    display: inline-block;
    min-width: 60px;
    overflow-wrap: break-word;
  }

  #sqe-stats-{{ section.id }} .sqe-stat-suffix {
    font-size: 32px;
    color: var(--sqe-primary-gold);
    font-weight: 600;
    overflow-wrap: break-word;
  }

  /* Label */
  #sqe-stats-{{ section.id }} .sqe-stat-label {
    font-size: 14px;
    color: var(--sqe-gray-text);
    text-transform: uppercase;
    letter-spacing: 1px;
    font-weight: 600;
    margin: 0;
    overflow-wrap: break-word;
    min-height: 20px;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    #sqe-stats-{{ section.id }} {
      padding: 60px 16px;
    }

    #sqe-stats-{{ section.id }} .sqe-stats-hdr h2 {
      font-size: 28px;
    }

    #sqe-stats-{{ section.id }} .sqe-stats-hdr p {
      font-size: 15px;
    }

    #sqe-stats-{{ section.id }} .sqe-stats-grid {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }

    #sqe-stats-{{ section.id }} .sqe-stat-card {
      padding: 24px 16px;
    }

    #sqe-stats-{{ section.id }} .sqe-stat-icon {
      width: 56px;
      height: 56px;
      font-size: 24px;
    }

    #sqe-stats-{{ section.id }} .sqe-stat-number {
      font-size: 36px;
    }

    #sqe-stats-{{ section.id }} .sqe-stat-suffix {
      font-size: 22px;
    }

    #sqe-stats-{{ section.id }} .sqe-bg-shape {
      display: none;
    }
  }

  @media (max-width: 480px) {
    #sqe-stats-{{ section.id }} .sqe-stats-grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }
  }
</style>

<div id="sqe-stats-{{ section.id }}">
  <div class="sqe-stats-bg">
    <div class="sqe-bg-shape sqe-bg-s1"></div>
    <div class="sqe-bg-shape sqe-bg-s2"></div>
    <div class="sqe-grid-pat"></div>
  </div>

  <div class="sqe-stats-inner">
    {%- if show_header -%}
      <div class="sqe-stats-hdr">
        {%- if show_label and label_text != blank -%}
          <span class="sqe-section-label">{{ label_text }}</span>
        {%- endif -%}
        <h2>{{ heading }}</h2>
        {%- if subheading != blank -%}
          <p>{{ subheading }}</p>
        {%- endif -%}
      </div>
    {%- endif -%}

    <div class="sqe-stats-grid">
      {%- if section.blocks.size > 0 -%}
        {%- for block in section.blocks -%}
          <div class="sqe-stat-card" {{ block.shopify_attributes }}>
            {%- if block.settings.icon_type != 'none' -%}
              <div class="sqe-stat-icon">
                {%- case block.settings.icon_type -%}
                  {%- when 'sun' -%}☀️
                  {%- when 'zap' -%}⚡
                  {%- when 'check' -%}✓
                  {%- when 'trending' -%}📈
                  {%- when 'target' -%}🎯
                  {%- when 'shield' -%}🛡️
                {%- endcase -%}
              </div>
            {%- endif -%}

            <div class="sqe-stat-number">
              <span class="sqe-stat-counter" data-target="{{ block.settings.number }}" data-duration="{{ block.settings.animation_duration }}">{{ block.settings.number }}</span>
              {%- if block.settings.suffix != blank -%}
                <span class="sqe-stat-suffix">{{ block.settings.suffix }}</span>
              {%- endif -%}
            </div>

            <p class="sqe-stat-label">{{ block.settings.label | default: 'Stat Label' }}</p>
          </div>
        {%- endfor -%}
      {%- else -%}
        <div class="sqe-stat-card" style="grid-column: 1 / -1; opacity: 0.6;">
          <div class="sqe-stat-icon">🔍</div>
          <div class="sqe-stat-number">
            <span class="sqe-stat-counter">0</span>
          </div>
          <p class="sqe-stat-label">No stats added yet</p>
        </div>
      {%- endif -%}
    </div>
  </div>
</div>

<script>
  (function() {
    var wrap = document.getElementById('sqe-stats-{{ section.id }}');
    if (!wrap) return;

    var cards = wrap.querySelectorAll('.sqe-stat-card');
    var counters = wrap.querySelectorAll('.sqe-stat-counter');
    if (!cards.length) return;

    /* Mark JS-ready: triggers entrance animation via CSS */
    wrap.classList.add('sqe-js-ready');

    /* Reset counter text to 0 (since we show real number by default for no-JS fallback) */
    counters.forEach(function(c) { c.textContent = '0'; });

    var hasAnimated = false;

    function animateCounter(el, target, duration) {
      var end = parseInt(target, 10);
      if (isNaN(end)) {
        el.textContent = target;
        return;
      }
      var inc = end / (duration / 50);
      var cur = 0;
      var timer = setInterval(function() {
        cur += inc;
        if (cur >= end) {
          el.textContent = end;
          clearInterval(timer);
        } else {
          el.textContent = Math.floor(cur);
        }
      }, 50);
    }

    function revealCards() {
      if (hasAnimated) return;
      hasAnimated = true;
      cards.forEach(function(card, i) {
        setTimeout(function() {
          card.classList.add('visible');
          var c = card.querySelector('.sqe-stat-counter');
          if (c && c.dataset.target) {
            animateCounter(c, c.dataset.target, parseInt(c.dataset.duration, 10) || 2000);
          }
        }, i * 150);
      });
    }

    /* Use IntersectionObserver for performance; fallback to immediate reveal */
    if ('IntersectionObserver' in window) {
      var obs = new IntersectionObserver(function(entries) {
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            revealCards();
            obs.disconnect();
          }
        });
      }, { threshold: 0.3 });
      obs.observe(wrap);
    } else {
      revealCards();
    }
  })();
</script>

{% schema %}
{
  "name": "SQE Floating Stats",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show section label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Kennzahlen"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show header",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The SQE Impact"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Proven expertise and measurable results in solar quality assessment"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "sub_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "sub_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "sub_color",
      "label": "Subheading color",
      "default": "#ffffffb3"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat Card",
      "settings": [
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "500"
        },
        {
          "type": "text",
          "id": "suffix",
          "label": "Suffix (+, MW, GW, %)",
          "default": "+"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Projects Inspected"
        },
        {
          "type": "select",
          "id": "icon_type",
          "label": "Icon",
          "options": [
            { "value": "none", "label": "None" },
            { "value": "sun", "label": "Sun" },
            { "value": "zap", "label": "Zap / Energy" },
            { "value": "check", "label": "Checkmark" },
            { "value": "trending", "label": "Trending Up" },
            { "value": "target", "label": "Target" },
            { "value": "shield", "label": "Shield" }
          ],
          "default": "sun"
        },
        {
          "type": "text",
          "id": "animation_duration",
          "label": "Count duration (ms)",
          "default": "2000"
        },
        {
          "type": "header",
          "content": "Card Typography"
        },
        {
          "type": "color",
          "id": "number_color",
          "label": "Number color",
          "default": "#1F3A5F"
        },
        {
          "type": "color",
          "id": "label_color",
          "label": "Label color",
          "default": "#999999"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Floating Stats",
      "blocks": [
        {
          "type": "stat",
          "settings": { "number": "500", "suffix": "+", "label": "Projects Inspected", "icon_type": "sun" }
        },
        {
          "type": "stat",
          "settings": { "number": "2", "suffix": "GW", "label": "Total Capacity Assessed", "icon_type": "zap" }
        },
        {
          "type": "stat",
          "settings": { "number": "98", "suffix": "%", "label": "Client Satisfaction", "icon_type": "check" }
        },
        {
          "type": "stat",
          "settings": { "number": "15", "suffix": "+", "label": "Years Experience", "icon_type": "trending" }
        }
      ]
    }
  ]
}
{% endschema %}