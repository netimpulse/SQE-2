{%- liquid
  assign bg_color = section.settings.background_color
  assign show_header = section.settings.show_header
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign header_sub = section.settings.header_subheading
  assign header_heading = section.settings.header_heading
  assign section_heading = section.settings.section_heading
  assign description = section.settings.description
  assign image = section.settings.image
  assign image_pos = section.settings.image_position
  assign image_style = section.settings.image_style
  assign show_exp = section.settings.show_experience
  assign years = section.settings.years_of_experience
  assign exp_label = section.settings.experience_label
  assign show_stats = section.settings.show_stats
  assign show_orange_bar = section.settings.show_credential_bar

  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif

  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color

  assign desc_font = section.settings.desc_font
  assign desc_size = section.settings.desc_size
  assign desc_color = section.settings.desc_color
  assign cred_title_font = "'Source Sans 3', sans-serif"
  assign cred_title_size = '15'
  assign cred_title_color = '#1F3A5F'
  assign cred_title_weight = '700'
  assign cred_desc_size = '13'
  assign cred_desc_color = '#666'
-%}

<style>
  /* ===== SECTION ===== */
  #sqe-about-{{ section.id }} {
    --bg-color: {{ bg_color }};
    --heading-font: {{ h_font }};
    --heading-size: {{ h_size }}px;
    --heading-color: {{ h_color }};
    --heading-weight: {{ h_weight }};
    --subheading-font: {{ sh_font }};
    --subheading-size: {{ sh_size }}px;
    --subheading-color: {{ sh_color }};
    --desc-font: {{ desc_font }};
    --desc-size: {{ desc_size }}px;
    --desc-color: {{ desc_color }};
    --cred-title-font: {{ cred_title_font }};
    --cred-title-size: {{ cred_title_size }}px;
    --cred-title-color: {{ cred_title_color }};
    --cred-title-weight: {{ cred_title_weight }};
    --cred-desc-size: {{ cred_desc_size }}px;
    --cred-desc-color: {{ cred_desc_color }};

    padding: 60px 20px;
    background-color: var(--bg-color);
  }
  #sqe-about-{{ section.id }} .sqe-about-ctr {
    max-width: 1200px;
    margin: 0 auto;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-about-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #C75B12;
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 10px;
    overflow-wrap: break-word;
  }

  /* ===== HEADER ===== */
  #sqe-about-{{ section.id }} .sqe-about-hdr {
    text-align: center;
    margin-bottom: 50px;
  }
  #sqe-about-{{ section.id }} .sqe-about-hdr-sub {
    font-family: var(--subheading-font);
    font-size: var(--subheading-size);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: var(--subheading-color);
    margin-bottom: 10px;
    overflow-wrap: break-word;
  }
  #sqe-about-{{ section.id }} .sqe-about-hdr h2 {
    font-family: var(--heading-font);
    font-size: var(--heading-size);
    font-weight: var(--heading-weight);
    color: var(--heading-color);
    margin: 0;
    line-height: 1.2;
    overflow-wrap: break-word;
  }

  /* ===== CONTENT GRID ===== */
  #sqe-about-{{ section.id }} .sqe-about-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: center;
    margin-bottom: 50px;
  }
  #sqe-about-{{ section.id }} .sqe-about-grid--rev {
    grid-auto-flow: dense;
  }
  #sqe-about-{{ section.id }} .sqe-about-grid--rev .sqe-about-img-wrap {
    order: 2;
  }
  #sqe-about-{{ section.id }} .sqe-about-grid--rev .sqe-about-text {
    order: 1;
  }

  /* ===== IMAGE ===== */
  #sqe-about-{{ section.id }} .sqe-about-img-wrap {
    position: relative;
    overflow: hidden;
  }
  #sqe-about-{{ section.id }} .sqe-about-img {
    width: 100%;
    height: auto;
    display: block;
    border-radius: 8px;
  }
  #sqe-about-{{ section.id }} .sqe-about-img--bordered {
    border: 8px solid #1F3A5F;
  }
  #sqe-about-{{ section.id }} .sqe-about-img--shadowed {
    box-shadow: 0 10px 40px rgba(31, 58, 95, 0.15);
  }
  #sqe-about-{{ section.id }} .sqe-about-img--both {
    border: 8px solid #1F3A5F;
    box-shadow: 0 10px 40px rgba(31, 58, 95, 0.15);
  }

  /* Placeholder image for missing images */
  #sqe-about-{{ section.id }} .placeholder-svg {
    width: 100%;
    height: auto;
    border-radius: 8px;
  }

  /* Experience badge */
  #sqe-about-{{ section.id }} .sqe-about-exp {
    position: absolute;
    bottom: -20px;
    right: -20px;
    background: #F2B705;
    color: #1F3A5F;
    width: 120px;
    height: 120px;
    border-radius: 50%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    font-family: 'Source Sans 3', sans-serif;
    box-shadow: 0 8px 32px rgba(242, 183, 5, 0.35);
    z-index: 2;
    flex-shrink: 0;
  }
  #sqe-about-{{ section.id }} .sqe-about-exp .num {
    font-size: 40px;
    font-weight: 900;
    line-height: 1;
  }
  #sqe-about-{{ section.id }} .sqe-about-exp .txt {
    font-size: 11px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
  }

  /* ===== TEXT CONTENT ===== */
  #sqe-about-{{ section.id }} .sqe-about-text h2 {
    font-family: var(--heading-font);
    font-size: calc(var(--heading-size) - 6px);
    font-weight: var(--heading-weight);
    color: var(--heading-color);
    margin: 0 0 20px;
    line-height: 1.3;
    overflow-wrap: break-word;
  }
  #sqe-about-{{ section.id }} .sqe-about-desc {
    font-family: var(--desc-font);
    font-size: var(--desc-size);
    line-height: 1.6;
    color: var(--desc-color);
    margin-bottom: 30px;
    overflow-wrap: break-word;
  }
  #sqe-about-{{ section.id }} .sqe-about-desc p {
    margin: 0 0 15px;
  }
  #sqe-about-{{ section.id }} .sqe-about-desc p:last-child {
    margin-bottom: 0;
  }
  #sqe-about-{{ section.id }} .sqe-about-desc strong {
    color: #1F3A5F;
    font-weight: 600;
  }

  /* ===== CREDENTIALS – SINGLE COLUMN ===== */
  #sqe-about-{{ section.id }} .sqe-about-creds {
    display: flex;
    flex-direction: column;
    gap: 16px;
    margin-top: 24px;
  }

  #sqe-about-{{ section.id }} .sqe-about-cred {
    display: flex;
    gap: 14px;
    align-items: flex-start;
    padding: 16px;
    background-color: #F2F4F7;
    border-radius: 10px;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }

  {%- if show_orange_bar -%}
    #sqe-about-{{ section.id }} .sqe-about-cred {
      border-left: 4px solid #F2B705;
    }
  {%- endif -%}

  #sqe-about-{{ section.id }} .sqe-about-cred:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 16px rgba(0, 0, 0, 0.06);
  }

  #sqe-about-{{ section.id }} .sqe-about-cred-icon {
    width: 44px;
    height: 44px;
    min-width: 44px;
    background: rgba(31, 58, 95, 0.07);
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 22px;
    flex-shrink: 0;
  }

  #sqe-about-{{ section.id }} .sqe-about-cred h3 {
    font-family: var(--block-title-font, var(--cred-title-font));
    font-size: var(--block-title-size, var(--cred-title-size));
    font-weight: var(--block-title-weight, var(--cred-title-weight));
    color: var(--block-title-color, var(--cred-title-color));
    margin: 0 0 3px;
    overflow-wrap: break-word;
  }

  #sqe-about-{{ section.id }} .sqe-about-cred p {
    font-family: 'Inter', sans-serif;
    font-size: var(--block-desc-size, var(--cred-desc-size));
    color: var(--block-desc-color, var(--cred-desc-color));
    margin: 0;
    line-height: 1.5;
    overflow-wrap: break-word;
  }

  /* ===== STATS ROW ===== */
  #sqe-about-{{ section.id }} .sqe-about-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 30px;
    margin-top: 50px;
  }
  #sqe-about-{{ section.id }} .sqe-about-stat {
    text-align: center;
    padding: 20px;
  }
  #sqe-about-{{ section.id }} .sqe-about-stat-num {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: #F2B705;
    margin: 0;
    line-height: 1;
    overflow-wrap: break-word;
  }
  #sqe-about-{{ section.id }} .sqe-about-stat-lbl {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #333;
    margin: 10px 0 0;
    font-weight: 500;
    overflow-wrap: break-word;
  }

  /* ===== MOBILE ===== */
  @media (max-width: 768px) {
    #sqe-about-{{ section.id }} .sqe-about-hdr h2 {
      font-size: 28px;
    }
    #sqe-about-{{ section.id }} .sqe-about-grid {
      grid-template-columns: 1fr;
      gap: 30px;
    }
    #sqe-about-{{ section.id }} .sqe-about-grid--rev .sqe-about-img-wrap {
      order: unset;
    }
    #sqe-about-{{ section.id }} .sqe-about-grid--rev .sqe-about-text {
      order: unset;
    }
    #sqe-about-{{ section.id }} .sqe-about-exp {
      width: 90px;
      height: 90px;
      bottom: -10px;
      right: -10px;
    }
    #sqe-about-{{ section.id }} .sqe-about-exp .num {
      font-size: 30px;
    }
    #sqe-about-{{ section.id }} .sqe-about-exp .txt {
      font-size: 9px;
    }
    #sqe-about-{{ section.id }} .sqe-about-text h2 {
      font-size: 24px;
    }
    #sqe-about-{{ section.id }} .sqe-about-stats {
      grid-template-columns: 1fr 1fr;
      gap: 16px;
    }
  }

  @media (max-width: 480px) {
    #sqe-about-{{ section.id }} {
      padding: 40px 16px;
    }
    #sqe-about-{{ section.id }} .sqe-about-stats {
      grid-template-columns: 1fr;
    }
  }
</style>

<div id="sqe-about-{{ section.id }}">
  <div class="sqe-about-ctr">

    {%- if show_header -%}
      <div class="sqe-about-hdr">
        {%- if show_label and label_text != blank -%}
          <span class="sqe-section-label">{{ label_text }}</span>
        {%- endif -%}
        {%- if header_sub != blank -%}
          <p class="sqe-about-hdr-sub">{{ header_sub }}</p>
        {%- endif -%}
        <h2>{{ header_heading }}</h2>
      </div>
    {%- endif -%}

    <div class="sqe-about-grid {% if image_pos == 'right' %}sqe-about-grid--rev{% endif %}">
      <div class="sqe-about-img-wrap">
        {%- if image != blank -%}
          <img
            src="{{ image | image_url: width: 600 }}"
            alt="{{ image.alt | escape }}"
            class="sqe-about-img sqe-about-img--{{ image_style }}"
            loading="lazy"
            width="{{ image.width }}"
            height="{{ image.height }}"
          >
        {%- else -%}
          {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}

        {%- if show_exp -%}
          <div class="sqe-about-exp">
            <span class="num">{{ years }}</span>
            <span class="txt">{{ exp_label }}</span>
          </div>
        {%- endif -%}
      </div>

      <div class="sqe-about-text">
        {%- if show_label and label_text != blank and show_header == false -%}
          <span class="sqe-section-label">{{ label_text }}</span>
        {%- endif -%}

        {%- if section_heading != blank -%}
          <h2>{{ section_heading }}</h2>
        {%- endif -%}

        {%- if description != blank -%}
          <div class="sqe-about-desc">{{ description }}</div>
        {%- endif -%}

        {%- if section.blocks.size > 0 -%}
          <div class="sqe-about-creds">
            {%- for block in section.blocks -%}
              {%- if block.type == 'credential' -%}
                {%- liquid
                  assign bt_font = block.settings.title_font
                  assign bt_size = block.settings.title_size
                  assign bt_color = block.settings.title_color
                  assign bt_bold = block.settings.title_bold
                  assign bt_weight = '700'
                  if bt_bold == false
                    assign bt_weight = '400'
                  endif
                  assign bd_size = block.settings.desc_size
                  assign bd_color = block.settings.desc_color
                -%}
                <div
                  class="sqe-about-cred"
                  style="--block-title-font:{{ bt_font }};--block-title-size:{{ bt_size }}px;--block-title-color:{{ bt_color }};--block-title-weight:{{ bt_weight }};--block-desc-size:{{ bd_size }}px;--block-desc-color:{{ bd_color }};"
                  {{ block.shopify_attributes }}
                >
                  <div class="sqe-about-cred-icon">{{ block.settings.icon }}</div>
                  <div>
                    <h3>{{ block.settings.credential_title }}</h3>
                    <p>{{ block.settings.credential_text }}</p>
                  </div>
                </div>
              {%- endif -%}
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>

    {%- if show_stats -%}
      <div class="sqe-about-stats">
        {%- for i in (1..3) -%}
          {%- assign stat_num = 'stat_' | append: i | append: '_number' -%}
          {%- assign stat_lbl = 'stat_' | append: i | append: '_label' -%}
          {%- if section.settings[stat_num] != blank -%}
            <div class="sqe-about-stat">
              <p class="sqe-about-stat-num">{{ section.settings[stat_num] }}</p>
              <p class="sqe-about-stat-lbl">{{ section.settings[stat_lbl] }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "SQE About Section",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": true
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Über uns"
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "checkbox",
      "id": "show_header",
      "label": "Show section header",
      "default": true
    },
    {
      "type": "text",
      "id": "header_subheading",
      "label": "Header subheading",
      "default": "About Us"
    },
    {
      "type": "text",
      "id": "header_heading",
      "label": "Header heading",
      "default": "Trusted Solar PV Engineering Excellence"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "section_heading",
      "label": "Content heading",
      "default": "Our Expertise"
    },
    {
      "type": "richtext",
      "id": "description",
      "label": "Description",
      "default": "<p>SQE Solar Quality Experts Ltd is a UK-based solar PV engineering consultancy dedicated to delivering excellence in renewable energy solutions.</p>"
    },
    {
      "type": "header",
      "content": "Image"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "select",
      "id": "image_style",
      "label": "Image style",
      "options": [
        { "value": "none", "label": "None" },
        { "value": "bordered", "label": "Bordered" },
        { "value": "shadowed", "label": "Shadowed" },
        { "value": "both", "label": "Bordered & Shadowed" }
      ],
      "default": "both"
    },
    {
      "type": "header",
      "content": "Credentials Bar"
    },
    {
      "type": "checkbox",
      "id": "show_credential_bar",
      "label": "Show orange left bar",
      "default": true,
      "info": "Orange accent line on credential cards"
    },
    {
      "type": "header",
      "content": "Experience Badge"
    },
    {
      "type": "checkbox",
      "id": "show_experience",
      "label": "Show experience badge",
      "default": true
    },
    {
      "type": "text",
      "id": "years_of_experience",
      "label": "Years",
      "default": "15"
    },
    {
      "type": "text",
      "id": "experience_label",
      "label": "Label",
      "default": "Jahre"
    },
    {
      "type": "header",
      "content": "Statistics"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show statistics",
      "default": true
    },
    {
      "type": "text",
      "id": "stat_1_number",
      "label": "Stat 1 Number",
      "default": "500+"
    },
    {
      "type": "text",
      "id": "stat_1_label",
      "label": "Stat 1 Label",
      "default": "Projects Completed"
    },
    {
      "type": "text",
      "id": "stat_2_number",
      "label": "Stat 2 Number",
      "default": "98%"
    },
    {
      "type": "text",
      "id": "stat_2_label",
      "label": "Stat 2 Label",
      "default": "Client Satisfaction"
    },
    {
      "type": "text",
      "id": "stat_3_number",
      "label": "Stat 3 Number",
      "default": "12"
    },
    {
      "type": "text",
      "id": "stat_3_label",
      "label": "Stat 3 Label",
      "default": "Industry Certifications"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 42
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 14
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#C75B12"
    },
    {
      "type": "header",
      "content": "Description Typography"
    },
    {
      "type": "select",
      "id": "desc_font",
      "label": "Description font",
      "options": [
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "desc_size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "color",
      "id": "desc_color",
      "label": "Description color",
      "default": "#333333"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "credential",
      "name": "Credential",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon emoji",
          "default": "✓"
        },
        {
          "type": "text",
          "id": "credential_title",
          "label": "Title",
          "default": "Certified Engineer"
        },
        {
          "type": "textarea",
          "id": "credential_text",
          "label": "Description",
          "default": "All team members hold industry-recognized certifications"
        },
        {
          "type": "header",
          "content": "Block Typography"
        },
        {
          "type": "select",
          "id": "title_font",
          "label": "Title font",
          "options": [
            { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
            { "value": "'Inter', sans-serif", "label": "Inter" },
            { "value": "system-ui, sans-serif", "label": "System" }
          ],
          "default": "'Source Sans 3', sans-serif"
        },
