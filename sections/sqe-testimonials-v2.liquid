{%- liquid
  assign heading = section.settings.heading
  assign background_color = section.settings.background_color
  assign auto_rotate = section.settings.auto_rotate
  assign rotate_speed = section.settings.rotate_speed | default: 5
-%}

<section id="section-{{ section.id }}" class="sqe-testimonials-v2" style="background-color: {{ background_color }};">
  <div class="testimonials-container">
    {% if heading %}
      <h2 class="testimonials-heading">{{ heading }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      {% assign first_block = section.blocks.first %}
      <div class="featured-testimonial" data-testimonial-id="{{ first_block.id }}" data-quote="{{ first_block.settings.quote | escape }}" data-client-name="{{ first_block.settings.client_name | escape }}" data-client-title="{{ first_block.settings.client_title | escape }}" data-company="{{ first_block.settings.company | escape }}" data-rating="{{ first_block.settings.rating }}" {% if first_block.settings.photo %}data-photo="{{ first_block.settings.photo | img_url: '150x150' }}"{% endif %}>
        <div class="quote-content">
          <p class="quote-text">{{ first_block.settings.quote }}</p>
        </div>
        <div class="client-info">
          {% if first_block.settings.photo %}
            <img src="{{ first_block.settings.photo | img_url: '100x100' }}" alt="{{ first_block.settings.client_name }}" class="client-photo">
          {% endif %}
          <div class="client-details">
            <h3 class="client-name">{{ first_block.settings.client_name }}</h3>
            <p class="client-title">{{ first_block.settings.client_title }}</p>
            <p class="client-company">{{ first_block.settings.company }}</p>
          </div>
          {% if first_block.settings.rating %}
            <div class="client-rating">
              {% for i in (1..first_block.settings.rating) %}
                <span class="star">★</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if section.blocks.size > 1 %}
      <div class="testimonial-nav">
        {% for block in section.blocks %}
          <button class="nav-dot" data-slide-index="{{ forloop.index0 }}" data-quote="{{ block.settings.quote | escape }}" data-client-name="{{ block.settings.client_name | escape }}" data-client-title="{{ block.settings.client_title | escape }}" data-company="{{ block.settings.company | escape }}" data-rating="{{ block.settings.rating }}" {% if block.settings.photo %}data-photo="{{ block.settings.photo | img_url: '150x150' }}"{% endif %} aria-label="Testimonial {{ forloop.index }}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #section-{{ section.id }} {
    padding: 60px 20px;
  }

  .testimonials-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .testimonials-heading {
    font-size: 48px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 50px;
    text-align: center;
  }

  .featured-testimonial {
    background: white;
    padding: 50px;
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(31, 58, 95, 0.1);
    transition: all 0.4s ease;
    min-height: 350px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  .quote-content {
    margin-bottom: 30px;
  }

  .quote-text {
    font-size: 28px;
    font-style: italic;
    color: #1F3A5F;
    line-height: 1.8;
    margin: 0;
    position: relative;
    padding-left: 30px;
  }

  .quote-text::before {
    content: '"';
    position: absolute;
    left: 0;
    font-size: 48px;
    color: #F2B705;
    opacity: 0.3;
  }

  .client-info {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 30px;
    border-top: 2px solid #F2F4F7;
  }

  .client-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  .client-details {
    flex: 1;
  }

  .client-name {
    font-size: 18px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0 0 5px 0;
  }

  .client-title {
    font-size: 14px;
    color: #C75B12;
    font-weight: 600;
    margin: 0 0 3px 0;
  }

  .client-company {
    font-size: 13px;
    color: #999;
    margin: 0;
  }

  .client-rating {
    display: flex;
    gap: 5px;
  }

  .star {
    color: #F2B705;
    font-size: 18px;
  }

  .testimonial-nav {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 40px;
  }

  .nav-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #1F3A5F;
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .nav-dot:hover {
    background: #1F3A5F;
  }

  .nav-dot.active {
    background: #1F3A5F;
    width: 30px;
    border-radius: 6px;
  }

  @media (max-width: 768px) {
    .featured-testimonial {
      padding: 30px 20px;
      min-height: auto;
    }
    .quote-text {
      font-size: 20px;
    }
    .testimonials-heading {
      font-size: 32px;
    }
    .client-info {
      flex-direction: column;
      text-align: center;
      border-top: none;
      padding-top: 20px;
    }
    .client-details {
      width: 100%;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var el = document.getElementById('section-' + sectionId);
    var featured = el.querySelector('.featured-testimonial');
    var navDots = el.querySelectorAll('.nav-dot');
    var autoRotate = {{ auto_rotate | json }};
    var rotateSpeed = {{ rotate_speed }};
    var currentIndex = 0;
    var rotateInterval = null;

    function updateTestimonial(index) {
      if (index < 0) index = navDots.length - 1;
      if (index >= navDots.length) index = 0;
      currentIndex = index;

      var dot = navDots[index];
      var quote = dot.getAttribute('data-quote');
      var name = dot.getAttribute('data-client-name');
      var title = dot.getAttribute('data-client-title');
      var company = dot.getAttribute('data-company');
      var rating = dot.getAttribute('data-rating');
      var photo = dot.getAttribute('data-photo');

      navDots.forEach(function(d) { d.classList.remove('active'); });
      dot.classList.add('active');

      var html = '<div class="quote-content"><p class="quote-text">' + quote + '</p></div>';
      html += '<div class="client-info">';
      if (photo) {
        html += '<img src="' + photo + '" alt="' + name + '" class="client-photo">';
      }
      html += '<div class="client-details"><h3 class="client-name">' + name + '</h3>';
      html += '<p class="client-title">' + title + '</p>';
      html += '<p class="client-company">' + company + '</p></div>';
      if (rating) {
        html += '<div class="client-rating">';
        for (var i = 0; i < rating; i++) {
          html += '<span class="star">★</span>';
        }
        html += '</div>';
      }
      html += '</div>';

      featured.innerHTML = html;
    }

    navDots.forEach(function(dot, index) {
      dot.addEventListener('click', function() {
        updateTestimonial(index);
        clearInterval(rotateInterval);
        if (autoRotate) {
          startAutoRotate();
        }
      });
    });

    function autoRotateNext() {
      updateTestimonial(currentIndex + 1);
    }

    function startAutoRotate() {
      rotateInterval = setInterval(autoRotateNext, rotateSpeed * 1000);
    }

    if (navDots.length > 0) {
      navDots[0].classList.add('active');
      if (autoRotate) {
        startAutoRotate();
      }
    }
  })();
</script>

{% schema %}
{
  "name": "Testimonials v2",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto Rotate",
      "default": false
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Rotation Speed",
      "default": 5
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F4F7"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Testimonial Quote"
        },
        {
          "type": "text",
          "id": "client_name",
          "label": "Client Name"
        },
        {
          "type": "text",
          "id": "client_title",
          "label": "Client Title"
        },
        {
          "type": "text",
          "id": "company",
          "label": "Company Name"
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Client Photo"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials v2"
    }
  ]
}
{% endschema %}
