{%- liquid
  assign heading = section.settings.heading
  assign background_color = section.settings.background_color
  assign auto_rotate = section.settings.auto_rotate
  assign rotate_speed = section.settings.rotate_speed | default: 5
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign q_font = section.settings.quote_font
  assign q_size = section.settings.quote_size
  assign q_color = section.settings.quote_color
  assign name_size = section.settings.client_name_size
  assign name_color = section.settings.client_name_color
  assign name_bold = section.settings.client_name_bold
  assign name_weight = '700'
  if name_bold == false
    assign name_weight = '400'
  endif
  assign role_size = section.settings.client_role_size
  assign role_color = section.settings.client_role_color
-%}

<section id="sqe-testi-{{ section.id }}" class="sqe-testimonials-v2" style="background-color: {{ background_color }};">
  <div class="testimonials-container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if heading %}
      <h2 class="testimonials-heading" style="font-family:{{ h_font }};font-size:{{ h_size }}px;color:{{ h_color }};font-weight:{{ h_weight }};">{{ heading }}</h2>
    {% endif %}

    {% if section.blocks.size > 0 %}
      {% assign first_block = section.blocks.first %}
      <div class="featured-testimonial" data-testimonial-id="{{ first_block.id }}" data-quote="{{ first_block.settings.quote | escape }}" data-client-name="{{ first_block.settings.client_name | escape }}" data-client-title="{{ first_block.settings.client_title | escape }}" data-company="{{ first_block.settings.company | escape }}" data-rating="{{ first_block.settings.rating }}" {% if first_block.settings.photo %}data-photo="{{ first_block.settings.photo | img_url: '150x150' }}"{% endif %}>
        <div class="quote-content">
          <p class="quote-text" style="font-family:{{ q_font }};font-size:{{ q_size }}px;color:{{ q_color }};">{{ first_block.settings.quote }}</p>
        </div>
        <div class="client-info">
          {% if first_block.settings.photo %}
            <img src="{{ first_block.settings.photo | img_url: '100x100' }}" alt="{{ first_block.settings.client_name }}" class="client-photo">
          {% endif %}
          <div class="client-details">
            <h3 class="client-name" style="font-size:{{ name_size }}px;color:{{ name_color }};font-weight:{{ name_weight }};">{{ first_block.settings.client_name }}</h3>
            <p class="client-title" style="font-size:{{ role_size }}px;color:{{ role_color }};">{{ first_block.settings.client_title }}</p>
            <p class="client-company" style="font-size:{{ role_size }}px;color:{{ role_color }};">{{ first_block.settings.company }}</p>
          </div>
          {% if first_block.settings.rating %}
            <div class="client-rating">
              {% for i in (1..first_block.settings.rating) %}
                <span class="star">★</span>
              {% endfor %}
            </div>
          {% endif %}
        </div>
      </div>
    {% endif %}

    {% if section.blocks.size > 1 %}
      <div class="testimonial-nav">
        {% for block in section.blocks %}
          <button class="nav-dot" data-slide-index="{{ forloop.index0 }}" data-quote="{{ block.settings.quote | escape }}" data-client-name="{{ block.settings.client_name | escape }}" data-client-title="{{ block.settings.client_title | escape }}" data-company="{{ block.settings.company | escape }}" data-rating="{{ block.settings.rating }}" {% if block.settings.photo %}data-photo="{{ block.settings.photo | img_url: '150x150' }}"{% endif %} aria-label="Testimonial {{ forloop.index }}"></button>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #sqe-testi-{{ section.id }} {
    padding: 60px 20px;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-testi-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #C75B12;
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  #sqe-testi-{{ section.id }} .testimonials-container {
    max-width: 900px;
    margin: 0 auto;
    text-align: center;
  }

  #sqe-testi-{{ section.id }} .testimonials-heading {
    margin-bottom: 50px;
    text-align: center;
  }

  #sqe-testi-{{ section.id }} .featured-testimonial {
    background: white;
    padding: 50px;
    border-radius: 8px;
    box-shadow: 0 4px 12px rgba(31, 58, 95, 0.1);
    transition: all 0.4s ease;
    min-height: 350px;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
  }

  #sqe-testi-{{ section.id }} .quote-content {
    margin-bottom: 30px;
  }

  #sqe-testi-{{ section.id }} .quote-text {
    font-style: italic;
    line-height: 1.8;
    margin: 0;
    position: relative;
    padding-left: 30px;
  }

  #sqe-testi-{{ section.id }} .quote-text::before {
    content: '"';
    position: absolute;
    left: 0;
    font-size: 48px;
    color: #F2B705;
    opacity: 0.3;
  }

  #sqe-testi-{{ section.id }} .client-info {
    display: flex;
    align-items: center;
    gap: 20px;
    padding-top: 30px;
    border-top: 2px solid #F2F4F7;
  }

  #sqe-testi-{{ section.id }} .client-photo {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    object-fit: cover;
    flex-shrink: 0;
  }

  #sqe-testi-{{ section.id }} .client-details {
    flex: 1;
  }

  #sqe-testi-{{ section.id }} .client-name {
    margin: 0 0 5px 0;
  }

  #sqe-testi-{{ section.id }} .client-title {
    font-weight: 600;
    margin: 0 0 3px 0;
  }

  #sqe-testi-{{ section.id }} .client-company {
    margin: 0;
  }

  #sqe-testi-{{ section.id }} .client-rating {
    display: flex;
    gap: 5px;
  }

  #sqe-testi-{{ section.id }} .star {
    color: #F2B705;
    font-size: 18px;
  }

  #sqe-testi-{{ section.id }} .testimonial-nav {
    display: flex;
    justify-content: center;
    gap: 12px;
    margin-top: 40px;
  }

  #sqe-testi-{{ section.id }} .nav-dot {
    width: 12px;
    height: 12px;
    border-radius: 50%;
    border: 2px solid #1F3A5F;
    background: transparent;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  #sqe-testi-{{ section.id }} .nav-dot:hover {
    background: #1F3A5F;
  }

  #sqe-testi-{{ section.id }} .nav-dot.active {
    background: #1F3A5F;
    width: 30px;
    border-radius: 6px;
  }

  /* Tablet Breakpoint (768px) */
  @media (max-width: 768px) {
    #sqe-testi-{{ section.id }} {
      padding: 50px 16px;
    }

    #sqe-testi-{{ section.id }} .testimonials-heading {
      margin-bottom: 40px;
    }

    #sqe-testi-{{ section.id }} .featured-testimonial {
      padding: 30px 20px;
      min-height: auto;
    }

    #sqe-testi-{{ section.id }} .quote-text {
      font-size: 20px !important;
    }

    #sqe-testi-{{ section.id }} .client-info {
      flex-direction: column;
      text-align: center;
      border-top: none;
      padding-top: 20px;
    }

    #sqe-testi-{{ section.id }} .client-details {
      width: 100%;
    }
  }

  /* Mobile Breakpoint (480px) */
  @media (max-width: 480px) {
    #sqe-testi-{{ section.id }} {
      padding: 40px 12px;
    }

    #sqe-testi-{{ section.id }} .testimonials-heading {
      margin-bottom: 30px;
    }

    #sqe-testi-{{ section.id }} .featured-testimonial {
      padding: 20px 16px;
      min-height: auto;
    }

    #sqe-testi-{{ section.id }} .quote-text {
      font-size: 16px !important;
      padding-left: 20px;
    }

    #sqe-testi-{{ section.id }} .quote-text::before {
      font-size: 36px;
    }

    #sqe-testi-{{ section.id }} .client-photo {
      width: 60px;
      height: 60px;
    }

    #sqe-testi-{{ section.id }} .client-name {
      margin: 0 0 4px 0;
    }

    #sqe-testi-{{ section.id }} .client-title {
      margin: 0 0 2px 0;
    }

    #sqe-testi-{{ section.id }} .testimonial-nav {
      margin-top: 30px;
      gap: 8px;
    }
  }
</style>

<script>
  (function() {
    var sectionId = '{{ section.id }}';
    var el = document.getElementById('sqe-testi-' + sectionId);
    var featured = el.querySelector('.featured-testimonial');
    var navDots = el.querySelectorAll('.nav-dot');
    var autoRotate = {{ auto_rotate | json }};
    var rotateSpeed = {{ rotate_speed }};
    var currentIndex = 0;
    var rotateInterval = null;

    function updateTestimonial(index) {
      if (index < 0) index = navDots.length - 1;
      if (index >= navDots.length) index = 0;
      currentIndex = index;

      var dot = navDots[index];
      var quote = dot.getAttribute('data-quote');
      var name = dot.getAttribute('data-client-name');
      var title = dot.getAttribute('data-client-title');
      var company = dot.getAttribute('data-company');
      var rating = dot.getAttribute('data-rating');
      var photo = dot.getAttribute('data-photo');

      navDots.forEach(function(d) { d.classList.remove('active'); });
      dot.classList.add('active');

      var quoteStyle = 'font-family:{{ q_font }};font-size:{{ q_size }}px;color:{{ q_color }};';
      var nameStyle = 'font-size:{{ name_size }}px;color:{{ name_color }};font-weight:{{ name_weight }};';
      var roleStyle = 'font-size:{{ role_size }}px;color:{{ role_color }};';

      var html = '<div class="quote-content"><p class="quote-text" style="' + quoteStyle + '">' + quote + '</p></div>';
      html += '<div class="client-info">';
      if (photo) {
        html += '<img src="' + photo + '" alt="' + name + '" class="client-photo">';
      }
      html += '<div class="client-details"><h3 class="client-name" style="' + nameStyle + '">' + name + '</h3>';
      html += '<p class="client-title" style="' + roleStyle + '">' + title + '</p>';
      html += '<p class="client-company" style="' + roleStyle + '">' + company + '</p></div>';
      if (rating) {
        html += '<div class="client-rating">';
        for (var i = 0; i < rating; i++) {
          html += '<span class="star">★</span>';
        }
        html += '</div>';
      }
      html += '</div>';

      featured.innerHTML = html;
    }

    navDots.forEach(function(dot, index) {
      dot.addEventListener('click', function() {
        updateTestimonial(index);
        clearInterval(rotateInterval);
        if (autoRotate) {
          startAutoRotate();
        }
      });
    });

    function autoRotateNext() {
      updateTestimonial(currentIndex + 1);
    }

    function startAutoRotate() {
      rotateInterval = setInterval(autoRotateNext, rotateSpeed * 1000);
    }

    if (navDots.length > 0) {
      navDots[0].classList.add('active');
      if (autoRotate) {
        startAutoRotate();
      }
    }
  })();
</script>

{% schema %}
{
  "name": "SQE Testimonials",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Testimonials"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "checkbox",
      "id": "auto_rotate",
      "label": "Auto Rotate",
      "default": false
    },
    {
      "type": "range",
      "id": "rotate_speed",
      "min": 3,
      "max": 15,
      "step": 1,
      "unit": "s",
      "label": "Rotation Speed",
      "default": 5
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F4F7"
    },
    {
      "type": "header",
      "content": "Heading"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Quote Text"
    },
    {
      "type": "select",
      "id": "quote_font",
      "label": "Font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "quote_size",
      "min": 16,
      "max": 40,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 28
    },
    {
      "type": "color",
      "id": "quote_color",
      "label": "Color",
      "default": "#1F3A5F"
    },
    {
      "type": "header",
      "content": "Client Name"
    },
    {
      "type": "range",
      "id": "client_name_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 18
    },
    {
      "type": "color",
      "id": "client_name_color",
      "label": "Color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "client_name_bold",
      "label": "Bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Role & Company"
    },
    {
      "type": "range",
      "id": "client_role_size",
      "min": 10,
      "max": 18,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "client_role_color",
      "label": "Color",
      "default": "#C75B12"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Testimonial Quote"
        },
        {
          "type": "text",
          "id": "client_name",
          "label": "Client Name"
        },
        {
          "type": "text",
          "id": "client_title",
          "label": "Client Title"
        },
        {
          "type": "text",
          "id": "company",
          "label": "Company Name"
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Client Photo"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Testimonials v2"
    }
  ]
}
{% endschema %}
