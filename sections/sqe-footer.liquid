{%- liquid
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
  assign accent_color = section.settings.accent_color
  assign logo_size = section.settings.logo_size
  assign copyright_text = section.settings.copyright_text
  assign show_social = section.settings.show_social
-%}

<footer
  id="sqe-footer-{{ section.id }}"
  class="sqe-footer"
  style="--f-bg: {{ bg_color }}; --f-text: {{ text_color }}; --f-accent: {{ accent_color }};"
>
  {%- comment -%} === MAIN ROW: Logo | Nav columns | Contact === {%- endcomment -%}
  <div class="sqe-footer__main">
    <div class="sqe-footer__main-inner">
      {%- comment -%} Brand {%- endcomment -%}
      <div class="sqe-footer__brand">
        {%- if settings.logo != blank -%}
          <a href="{{ routes.root_url }}" class="sqe-footer__logo-link">
            <img
              src="{{ settings.logo | image_url: width: logo_size | times: 2 }}"
              alt="{{ shop.name }}"
              width="{{ logo_size }}"
              loading="lazy"
              class="sqe-footer__logo"
            >
          </a>
        {%- else -%}
          <a href="{{ routes.root_url }}" class="sqe-footer__shop-name">{{ shop.name }}</a>
        {%- endif -%}
        {%- if section.settings.company_tagline != blank -%}
          <p class="sqe-footer__tagline">{{ section.settings.company_tagline }}</p>
        {%- endif -%}
      </div>

      {%- comment -%} Blocks: nav columns + text columns {%- endcomment -%}
      {%- for block in section.blocks -%}
        {%- if block.type == 'link_column' -%}
          <div class="sqe-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.column_title != blank -%}
              <h4 class="sqe-footer__col-title">{{ block.settings.column_title }}</h4>
            {%- endif -%}
            {%- if block.settings.menu != blank -%}
              <ul class="sqe-footer__nav">
                {%- for link in block.settings.menu.links -%}
                  <li><a href="{{ link.url }}" class="sqe-footer__link">{{ link.title }}</a></li>
                {%- endfor -%}
              </ul>
            {%- endif -%}
          </div>
        {%- endif -%}
        {%- if block.type == 'text_column' -%}
          <div class="sqe-footer__col" {{ block.shopify_attributes }}>
            {%- if block.settings.column_title != blank -%}
              <h4 class="sqe-footer__col-title">{{ block.settings.column_title }}</h4>
            {%- endif -%}
            {%- if block.settings.text != blank -%}
              <div class="sqe-footer__text">{{ block.settings.text }}</div>
            {%- endif -%}
          </div>
        {%- endif -%}
      {%- endfor -%}

      {%- comment -%} Social {%- endcomment -%}
      {%- if show_social -%}
        <div class="sqe-footer__col sqe-footer__col--social">
          <h4 class="sqe-footer__col-title">Social</h4>
          <div class="sqe-footer__social">
            {%- if settings.social_facebook_link != blank -%}
              <a href="{{ settings.social_facebook_link }}" class="sqe-footer__soc-link" aria-label="Facebook" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_instagram_link != blank -%}
              <a href="{{ settings.social_instagram_link }}" class="sqe-footer__soc-link" aria-label="Instagram" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1112.63 8 4 4 0 0116 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_twitter_link != blank -%}
              <a href="{{ settings.social_twitter_link }}" class="sqe-footer__soc-link" aria-label="X" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_youtube_link != blank -%}
              <a href="{{ settings.social_youtube_link }}" class="sqe-footer__soc-link" aria-label="YouTube" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M23.498 6.186a3.016 3.016 0 00-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 00.502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 002.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 002.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_tiktok_link != blank -%}
              <a href="{{ settings.social_tiktok_link }}" class="sqe-footer__soc-link" aria-label="TikTok" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.46V13.2a8.16 8.16 0 005.58 2.2V12a4.85 4.85 0 01-3.77-1.56V6.69h3.77z"/></svg>
              </a>
            {%- endif -%}
            {%- if settings.social_linkedin_link != blank -%}
              <a href="{{ settings.social_linkedin_link }}" class="sqe-footer__soc-link" aria-label="LinkedIn" target="_blank" rel="noopener">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
              </a>
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- comment -%} === BOTTOM BAR: Copyright | Legal Links === {%- endcomment -%}
  <div class="sqe-footer__bottom">
    <div class="sqe-footer__bottom-inner">
      <p class="sqe-footer__copy">&copy; {{ 'now' | date: '%Y' }} {{ copyright_text | default: shop.name }}.</p>

      <nav class="sqe-footer__legal" aria-label="Legal">
        {%- if section.settings.impressum_url != blank -%}
          <a href="{{ section.settings.impressum_url }}" class="sqe-footer__legal-link">Impressum</a>
        {%- endif -%}
        {%- if section.settings.datenschutz_url != blank -%}
          <a href="{{ section.settings.datenschutz_url }}" class="sqe-footer__legal-link">Datenschutz</a>
        {%- endif -%}
        {%- if section.settings.agb_url != blank -%}
          <a href="{{ section.settings.agb_url }}" class="sqe-footer__legal-link">AGB</a>
        {%- endif -%}
        {%- if section.settings.widerruf_url != blank -%}
          <a href="{{ section.settings.widerruf_url }}" class="sqe-footer__legal-link">Widerruf</a>
        {%- endif -%}
        {%- if section.settings.cookie_url != blank -%}
          <a href="{{ section.settings.cookie_url }}" class="sqe-footer__legal-link">Cookie-Richtlinie</a>
        {%- endif -%}
        {%- comment -%} Also show Shopify policies if enabled {%- endcomment -%}
        {%- if section.settings.show_policies -%}
          {%- for policy in shop.policies -%}
            {%- if policy != blank -%}
              <a href="{{ policy.url }}" class="sqe-footer__legal-link">{{ policy.title }}</a>
            {%- endif -%}
          {%- endfor -%}
        {%- endif -%}
      </nav>
    </div>
  </div>
</footer>

<style>
  #sqe-footer-{{ section.id }} {
    font-family: 'Source Sans 3', 'Source Sans Pro', 'Inter', sans-serif;
    color: var(--f-text, #fff);
    line-height: 1.5;
  }

  /* === MAIN SECTION === */
  #sqe-footer-{{ section.id }} .sqe-footer__main {
    background: var(--f-bg, #1F3A5F);
    padding: 36px 0;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__main-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: flex-start;
    gap: 40px;
    flex-wrap: nowrap;
  }

  /* === BRAND === */
  #sqe-footer-{{ section.id }} .sqe-footer__brand {
    flex: 0 0 auto;
    min-width: 0;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__logo {
    display: block;
    height: auto;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__logo-link {
    display: inline-block;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__shop-name {
    font-size: 20px;
    font-weight: 700;
    color: var(--f-text);
    text-decoration: none;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__tagline {
    font-size: 13px;
    opacity: 0.7;
    margin: 8px 0 0;
    max-width: 220px;
  }

  /* === COLUMNS === */
  #sqe-footer-{{ section.id }} .sqe-footer__col {
    flex: 1 1 0;
    min-width: 120px;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__col-title {
    font-size: 13px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    margin: 0 0 12px;
    color: var(--f-text);
  }
  #sqe-footer-{{ section.id }} .sqe-footer__nav {
    list-style: none;
    margin: 0;
    padding: 0;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__nav li {
    margin-bottom: 6px;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__link {
    font-size: 14px;
    color: var(--f-text);
    text-decoration: none;
    opacity: 0.7;
    transition: opacity 0.2s ease;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__link:hover {
    opacity: 1;
    color: var(--f-accent, #F2B705);
  }
  #sqe-footer-{{ section.id }} .sqe-footer__text {
    font-size: 14px;
    opacity: 0.7;
    line-height: 1.5;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__text a {
    color: var(--f-accent, #F2B705);
    text-decoration: none;
  }

  /* === SOCIAL === */
  #sqe-footer-{{ section.id }} .sqe-footer__social {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__soc-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 32px;
    height: 32px;
    border-radius: 50%;
    background: rgba(255,255,255,0.1);
    color: var(--f-text);
    transition: background 0.2s ease, transform 0.2s ease;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__soc-link:hover {
    background: var(--f-accent, #F2B705);
    color: var(--f-bg, #1F3A5F);
    transform: translateY(-2px);
  }

  /* === BOTTOM BAR === */
  #sqe-footer-{{ section.id }} .sqe-footer__bottom {
    background: color-mix(in srgb, var(--f-bg, #1F3A5F) 85%, black);
    padding: 14px 0;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__bottom-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 16px;
    flex-wrap: wrap;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__copy {
    font-size: 12px;
    margin: 0;
    opacity: 0.6;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__legal {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__legal-link {
    font-size: 12px;
    color: var(--f-text);
    text-decoration: none;
    opacity: 0.6;
    transition: opacity 0.2s ease;
  }
  #sqe-footer-{{ section.id }} .sqe-footer__legal-link:hover {
    opacity: 1;
  }

  /* ===== TABLET (max-width: 768px) ===== */
  @media (max-width: 768px) {
    #sqe-footer-{{ section.id }} .sqe-footer__main {
      padding: 28px 0;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__main-inner {
      flex-wrap: wrap;
      gap: 28px;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__brand {
      flex: 1 1 100%;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__col {
      flex: 1 1 calc(50% - 14px);
      min-width: 0;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__col--social {
      flex: 1 1 100%;
    }
  }

  /* ===== MOBILE (max-width: 480px) ===== */
  @media (max-width: 480px) {
    #sqe-footer-{{ section.id }} .sqe-footer__main-inner {
      padding: 0 16px;
      gap: 24px;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__col {
      flex: 1 1 100%;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__bottom-inner {
      flex-direction: column;
      align-items: flex-start;
      padding: 0 16px;
      gap: 10px;
    }
    #sqe-footer-{{ section.id }} .sqe-footer__legal {
      gap: 12px;
    }
  }
</style>

{% schema %}
{
  "name": "SQE Footer",
  "settings": [
    {
      "type": "header",
      "content": "Appearance"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#1F3A5F"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text Color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent Color",
      "default": "#F2B705"
    },
    {
      "type": "range",
      "id": "logo_size",
      "min": 40,
      "max": 200,
      "step": 10,
      "unit": "px",
      "label": "Logo Size",
      "default": 100
    },
    {
      "type": "header",
      "content": "Brand"
    },
    {
      "type": "text",
      "id": "company_tagline",
      "label": "Tagline",
      "default": "Solar PV Quality Experts"
    },
    {
      "type": "text",
      "id": "copyright_text",
      "label": "Copyright Name",
      "default": "Solar Quality Experts"
    },
    {
      "type": "checkbox",
      "id": "show_social",
      "label": "Show Social Icons",
      "default": true
    },
    {
      "type": "header",
      "content": "Legal Pages"
    },
    {
      "type": "url",
      "id": "impressum_url",
      "label": "Impressum"
    },
    {
      "type": "url",
      "id": "datenschutz_url",
      "label": "Datenschutzerklärung"
    },
    {
      "type": "url",
      "id": "agb_url",
      "label": "AGB"
    },
    {
      "type": "url",
      "id": "widerruf_url",
      "label": "Widerrufsbelehrung"
    },
    {
      "type": "url",
      "id": "cookie_url",
      "label": "Cookie-Richtlinie"
    },
    {
      "type": "checkbox",
      "id": "show_policies",
      "label": "Show Shopify Policy Links",
      "default": false,
      "info": "Shows policy pages configured in Shopify Settings > Policies"
    }
  ],
  "blocks": [
    {
      "type": "link_column",
      "name": "Navigation Column",
      "settings": [
        {
          "type": "text",
          "id": "column_title",
          "label": "Column Title",
          "default": "Quick Links"
        },
        {
          "type": "link_list",
          "id": "menu",
          "label": "Menu",
          "default": "footer"
        }
      ]
    },
    {
      "type": "text_column",
      "name": "Text Column",
      "settings": [
        {
          "type": "text",
          "id": "column_title",
          "label": "Column Title",
          "default": "Contact"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Content",
          "default": "<p>info@example.com<br>+44 123 456 7890</p>"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Footer",
      "blocks": [
        {
          "type": "link_column",
          "settings": {
            "column_title": "Services"
          }
        },
        {
          "type": "link_column",
          "settings": {
            "column_title": "Company"
          }
        },
        {
          "type": "text_column",
          "settings": {
            "column_title": "Contact",
            "text": "<p>info@example.com<br>+44 123 456 7890</p>"
          }
        }
      ]
    }
  ]
}
{% endschema %}
