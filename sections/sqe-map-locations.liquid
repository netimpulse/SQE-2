{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign background_color = section.settings.background_color
  assign columns = section.settings.columns | default: 3
-%}

<section id="section-{{ section.id }}" class="sqe-map-locations" style="background-color: {{ background_color }};">
  <div class="locations-container">
    {% if heading %}
      <h2 class="locations-heading">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="locations-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="locations-grid" style="grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));">
      {% for block in section.blocks %}
        <div class="location-card" data-location-id="{{ block.id }}" data-location-name="{{ block.settings.name | escape }}" data-location-description="{{ block.settings.description | escape }}" data-location-region="{{ block.settings.region | escape }}" data-project-count="{{ block.settings.project_count }}">
          <div class="location-header">
            <h3 class="location-name">{{ block.settings.name }}</h3>
            <span class="location-badge">{{ block.settings.region }}</span>
          </div>
          <p class="location-description">{{ block.settings.description }}</p>
          <div class="location-meta">
            <span class="project-count">{{ block.settings.project_count }} Projects</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #section-{{ section.id }} {
    padding: 60px 20px;
  }

  .sqe-map-locations {
    transition: background-color 0.3s ease;
  }

  .locations-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .locations-heading {
    font-size: 48px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
    text-align: center;
  }

  .locations-subheading {
    font-size: 18px;
    color: #333333;
    text-align: center;
    margin-bottom: 50px;
  }

  .locations-grid {
    display: grid;
    gap: 25px;
  }

  .location-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    border-left: 5px solid #1F3A5F;
  }

  .location-card:hover {
    box-shadow: 0 8px 24px rgba(31, 58, 95, 0.15);
    transform: translateY(-8px);
    border-left-color: #F2B705;
  }

  .location-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 15px;
    gap: 15px;
  }

  .location-name {
    font-size: 24px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0;
  }

  .location-badge {
    display: inline-block;
    background-color: #F2F4F7;
    color: #333333;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
  }

  .location-description {
    font-size: 15px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 20px;
  }

  .location-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 15px;
    border-top: 1px solid #F2F4F7;
  }

  .project-count {
    display: inline-block;
    background-color: #1F3A5F;
    color: white;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
  }

  @media (max-width: 768px) {
    .locations-grid {
      grid-template-columns: 1fr;
    }
    .locations-heading {
      font-size: 32px;
    }
    .location-header {
      flex-direction: column;
    }
    .location-card {
      padding: 20px;
    }
  }
</style>

<script>
  (function() {
    var el = document.getElementById('section-' + '{{ section.id }}');
    var cards = el.querySelectorAll('.location-card');

    cards.forEach(function(card) {
      card.addEventListener('mouseenter', function() {
        this.style.borderLeftColor = '#F2B705';
      });
      card.addEventListener('mouseleave', function() {
        this.style.borderLeftColor = '#1F3A5F';
      });
    });
  })();
</script>

{% schema %}
{
  "name": "Map Locations",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Locations"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Where we work"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        {
          "value": "2",
          "label": "2 Columns"
        },
        {
          "value": "3",
          "label": "3 Columns"
        },
        {
          "value": "4",
          "label": "4 Columns"
        }
      ],
      "default": "3"
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Location Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region"
        },
        {
          "type": "number",
          "id": "project_count",
          "label": "Project Count",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Map Locations"
    }
  ]
}
{% endschema %}
