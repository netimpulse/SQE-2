{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign background_color = section.settings.background_color
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color
  assign columns = section.settings.columns | default: 3
-%}

<section id="sqe-map-locations-{{ section.id }}" class="sqe-map-locations" style="--bg-color: {{ background_color }}; --heading-font: {{ h_font }}; --heading-size: {{ h_size }}px; --heading-color: {{ h_color }}; --heading-weight: {{ h_weight }}; --subheading-font: {{ sh_font }}; --subheading-size: {{ sh_size }}px; --subheading-color: {{ sh_color }};">
  <div class="locations-container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if heading %}
      <h2 class="locations-heading">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="locations-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="locations-grid" data-columns="{{ columns }}">
      {% for block in section.blocks %}
        <div class="location-card" data-location-id="{{ block.id }}" data-location-name="{{ block.settings.name | escape }}" data-location-description="{{ block.settings.description | escape }}" data-location-region="{{ block.settings.region | escape }}" data-project-count="{{ block.settings.project_count }}">
          <div class="location-header">
            <h3 class="location-name">{{ block.settings.name }}</h3>
            <span class="location-badge">{{ block.settings.region }}</span>
          </div>
          <p class="location-description">{{ block.settings.description }}</p>
          <div class="location-meta">
            <span class="project-count">{{ block.settings.project_count }} Projects</span>
          </div>
        </div>
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #sqe-map-locations-{{ section.id }} {
    background-color: var(--bg-color);
    padding: {{ section.settings.padding_top }}px 20px 60px 20px;
    transition: background-color 0.3s ease;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-map-locations-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #C75B12;
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  #sqe-map-locations-{{ section.id }} .locations-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  #sqe-map-locations-{{ section.id }} .locations-heading {
    font-family: var(--heading-font);
    font-size: var(--heading-size);
    color: var(--heading-color);
    font-weight: var(--heading-weight);
    margin-bottom: 10px;
    text-align: center;
    overflow-wrap: break-word;
  }

  #sqe-map-locations-{{ section.id }} .locations-subheading {
    font-family: var(--subheading-font);
    font-size: var(--subheading-size);
    color: var(--subheading-color);
    text-align: center;
    margin-bottom: 50px;
    overflow-wrap: break-word;
  }

  #sqe-map-locations-{{ section.id }} .locations-grid {
    display: grid;
    gap: 25px;
  }

  #sqe-map-locations-{{ section.id }} .locations-grid[data-columns="2"] {
    grid-template-columns: repeat(2, 1fr);
  }

  #sqe-map-locations-{{ section.id }} .locations-grid[data-columns="3"] {
    grid-template-columns: repeat(3, 1fr);
  }

  #sqe-map-locations-{{ section.id }} .locations-grid[data-columns="4"] {
    grid-template-columns: repeat(4, 1fr);
  }

  #sqe-map-locations-{{ section.id }} .location-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    border-left: 5px solid #1F3A5F;
  }

  #sqe-map-locations-{{ section.id }} .location-card:hover {
    box-shadow: 0 8px 24px rgba(31, 58, 95, 0.15);
    transform: translateY(-8px);
    border-left-color: #F2B705;
  }

  #sqe-map-locations-{{ section.id }} .location-header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 15px;
    gap: 15px;
  }

  #sqe-map-locations-{{ section.id }} .location-name {
    font-size: 24px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0;
    overflow-wrap: break-word;
  }

  #sqe-map-locations-{{ section.id }} .location-badge {
    display: inline-block;
    background-color: #F2F4F7;
    color: #333333;
    padding: 6px 12px;
    border-radius: 20px;
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    white-space: nowrap;
    overflow-wrap: break-word;
  }

  #sqe-map-locations-{{ section.id }} .location-description {
    font-size: 15px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 20px;
    overflow-wrap: break-word;
  }

  #sqe-map-locations-{{ section.id }} .location-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-top: 15px;
    border-top: 1px solid #F2F4F7;
  }

  #sqe-map-locations-{{ section.id }} .project-count {
    display: inline-block;
    background-color: #1F3A5F;
    color: white;
    padding: 8px 16px;
    border-radius: 6px;
    font-size: 13px;
    font-weight: 600;
    overflow-wrap: break-word;
  }

  @media (max-width: 768px) {
    #sqe-map-locations-{{ section.id }} {
      padding: 40px 16px;
    }

    #sqe-map-locations-{{ section.id }} .locations-grid[data-columns="3"],
    #sqe-map-locations-{{ section.id }} .locations-grid[data-columns="4"] {
      grid-template-columns: repeat(2, 1fr);
    }

    #sqe-map-locations-{{ section.id }} .locations-grid[data-columns="2"] {
      grid-template-columns: 1fr;
    }

    #sqe-map-locations-{{ section.id }} .locations-heading {
      font-size: 32px;
    }

    #sqe-map-locations-{{ section.id }} .locations-subheading {
      font-size: 16px;
    }

    #sqe-map-locations-{{ section.id }} .location-header {
      flex-direction: column;
    }

    #sqe-map-locations-{{ section.id }} .location-card {
      padding: 20px;
    }
  }

  @media (max-width: 480px) {
    #sqe-map-locations-{{ section.id }} {
      padding: 30px 12px;
    }

    #sqe-map-locations-{{ section.id }} .locations-grid {
      grid-template-columns: 1fr !important;
    }

    #sqe-map-locations-{{ section.id }} .locations-heading {
      font-size: 24px;
    }

    #sqe-map-locations-{{ section.id }} .locations-subheading {
      font-size: 14px;
    }

    #sqe-map-locations-{{ section.id }} .location-name {
      font-size: 20px;
    }

    #sqe-map-locations-{{ section.id }} .location-description {
      font-size: 14px;
    }
  }
</style>

{% schema %}
{
  "name": "Map Locations",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Locations"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Locations"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Where we work"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 48
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 18
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading color",
      "default": "#333333"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        {
          "value": "2",
          "label": "2 Columns"
        },
        {
          "value": "3",
          "label": "3 Columns"
        },
        {
          "value": "4",
          "label": "4 Columns"
        }
      ],
      "default": "3"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "location",
      "name": "Location",
      "settings": [
        {
          "type": "text",
          "id": "name",
          "label": "Location Name"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        },
        {
          "type": "text",
          "id": "region",
          "label": "Region"
        },
        {
          "type": "number",
          "id": "project_count",
          "label": "Project Count",
          "default": 0
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Map Locations"
    }
  ]
}
{% endschema %}
