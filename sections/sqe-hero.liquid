{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign primary_button_text = section.settings.primary_button_text
  assign primary_button_link = section.settings.primary_button_link
  assign secondary_button_text = section.settings.secondary_button_text
  assign secondary_button_link = section.settings.secondary_button_link
  assign background_image = section.settings.background_image
  assign overlay_color = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity
  assign text_alignment = section.settings.text_alignment
  assign section_height = section.settings.section_height
  assign show_stats = section.settings.show_stats
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text

  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif

  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color

  assign stat_font = section.settings.stat_blocks_font
  assign stat_num_size = section.settings.stat_number_size
  assign stat_text_size = section.settings.stat_text_size
  assign stat_num_color = section.settings.stat_number_color
  assign stat_text_color = section.settings.stat_text_color
-%}

<section
  id="sqe-hero-{{ section.id }}"
  class="sqe-hero sqe-hero--{{ section_height }}"
  style="
    --text-alignment: {{ text_alignment }};
    --heading-font: {{ h_font }};
    --heading-size: {{ h_size }}px;
    --heading-weight: {{ h_weight }};
    --heading-color: {{ h_color }};
    --subheading-font: {{ sh_font }};
    --subheading-size: {{ sh_size }}px;
    --subheading-color: {{ sh_color }};
    --stat-font: {{ stat_font }};
    --stat-num-size: {{ stat_num_size }}px;
    --stat-text-size: {{ stat_text_size }}px;
    --stat-num-color: {{ stat_num_color }};
    --stat-text-color: {{ stat_text_color }};
    --overlay-color: {{ overlay_color }};
    --overlay-opacity: {{ overlay_opacity | times: 0.01 }};
  "
>
  <div class="sqe-hero__background">
    {%- if background_image -%}
      <img
        src="{{ background_image | image_url: width: 1920 }}"
        srcset="
          {{ background_image | image_url: width: 750 }} 750w,
          {{ background_image | image_url: width: 1024 }} 1024w,
          {{ background_image | image_url: width: 1536 }} 1536w,
          {{ background_image | image_url: width: 1920 }} 1920w
        "
        sizes="100vw"
        alt="SQE Solar Quality Experts hero background"
        class="sqe-hero__image"
        loading="lazy"
      >
    {%- else -%}
      <div class="sqe-hero__placeholder">
        {{ 'image' | placeholder_svg_tag: 'placeholder-svg' }}
      </div>
    {%- endif -%}
    <div class="sqe-hero__overlay"></div>
  </div>

  <div class="sqe-hero__content">
    <div class="sqe-hero__text-block">
      {%- if show_label and label_text != blank -%}
        <span class="sqe-section-label">{{ label_text }}</span>
      {%- endif -%}
      {%- if heading -%}
        <h1 class="sqe-hero__heading">{{ heading }}</h1>
      {%- endif -%}

      {%- if subheading -%}
        <p class="sqe-hero__subheading">{{ subheading }}</p>
      {%- endif -%}

      {%- if primary_button_text or secondary_button_text -%}
        <div class="sqe-hero__buttons">
          {%- if primary_button_text -%}
            <a href="{{ primary_button_link }}" class="sqe-hero__button sqe-hero__button--primary">
              {{ primary_button_text }}
            </a>
          {%- endif -%}

          {%- if secondary_button_text -%}
            <a href="{{ secondary_button_link }}" class="sqe-hero__button sqe-hero__button--secondary">
              {{ secondary_button_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if show_stats -%}
    <div class="sqe-hero__stats">
      <div class="sqe-hero__stats-container">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="sqe-hero__stat-item" {{ block.shopify_attributes }}>
              <div class="sqe-hero__stat-number">{{ block.settings.stat_number }}</div>
              <div class="sqe-hero__stat-text">{{ block.settings.stat_text }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  #sqe-hero-{{ section.id }} {
    /* ===== Color Palette ===== */
    --sqe-primary-blue: #1F3A5F;
    --sqe-yellow: #F2B705;
    --sqe-light-grey: #F2F4F7;
    --sqe-dark-grey: #333333;
    --sqe-orange: #C75B12;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-hero-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #C75B12;
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: 12px;
  }

  #sqe-hero-{{ section.id }}.sqe-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  #sqe-hero-{{ section.id }}.sqe-hero--small {
    min-height: 400px;
  }

  #sqe-hero-{{ section.id }}.sqe-hero--medium {
    min-height: 600px;
  }

  #sqe-hero-{{ section.id }}.sqe-hero--large {
    min-height: 800px;
  }

  #sqe-hero-{{ section.id }}.sqe-hero--full {
    min-height: 100vh;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__placeholder {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--sqe-primary-blue), var(--sqe-light-grey));
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(255, 255, 255, 0.5);
  }

  #sqe-hero-{{ section.id }} .sqe-hero__placeholder svg,
  #sqe-hero-{{ section.id }} .sqe-hero__placeholder .placeholder-svg {
    width: 120px;
    height: 120px;
    object-fit: contain;
    opacity: 0.15;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--overlay-color, var(--sqe-primary-blue));
    opacity: var(--overlay-opacity, 0.6);
    z-index: 2;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    box-sizing: border-box;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__text-block {
    max-width: 900px;
    width: 100%;
    text-align: var(--text-alignment, center);
  }

  #sqe-hero-{{ section.id }} .sqe-hero__heading {
    font-family: var(--heading-font);
    font-size: var(--heading-size);
    font-weight: var(--heading-weight);
    color: var(--heading-color);
    line-height: 1.2;
    margin: 0 0 20px 0;
    letter-spacing: -0.5px;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__subheading {
    font-family: var(--subheading-font);
    font-size: var(--subheading-size);
    color: var(--subheading-color);
    line-height: 1.6;
    margin: 0 0 40px 0;
    font-weight: 400;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: var(--text-alignment, center);
  }

  #sqe-hero-{{ section.id }} .sqe-hero__button {
    display: inline-block;
    padding: 16px 32px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__button--primary {
    background-color: var(--sqe-yellow);
    color: var(--sqe-primary-blue);
  }

  #sqe-hero-{{ section.id }} .sqe-hero__button--primary:hover {
    background-color: #e0a604;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(242, 183, 5, 0.4);
  }

  #sqe-hero-{{ section.id }} .sqe-hero__button--secondary {
    background-color: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__button--secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.2);
  }

  #sqe-hero-{{ section.id }} .sqe-hero__stats {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 4;
    background: rgba(31, 58, 95, 0.95);
    backdrop-filter: blur(8px);
    padding: 30px 20px;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__stats-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__stat-item {
    text-align: center;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__stat-number {
    font-family: var(--stat-font);
    font-size: var(--stat-num-size);
    color: var(--stat-num-color);
    line-height: 1;
    margin-bottom: 8px;
    font-weight: 700;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #sqe-hero-{{ section.id }} .sqe-hero__stat-text {
    font-family: var(--stat-font);
    font-size: var(--stat-text-size);
    color: var(--stat-text-color);
    font-weight: 500;
    letter-spacing: 0.5px;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  /* ===== Shopify section wrapper – ensure full-width ===== */
  #shopify-section-{{ section.id }} {
    margin: 0 !important;
    padding: 0 !important;
    max-width: none !important;
    width: 100% !important;
  }

  /* ===== MOBILE RESPONSIVE (768px) ===== */
  @media (max-width: 768px) {
    #sqe-hero-{{ section.id }}.sqe-hero {
      width: 100%;
    }

    #sqe-hero-{{ section.id }}.sqe-hero--small {
      min-height: 350px;
    }

    #sqe-hero-{{ section.id }}.sqe-hero--medium {
      min-height: 450px;
    }

    #sqe-hero-{{ section.id }}.sqe-hero--large {
      min-height: 600px;
    }

    #sqe-hero-{{ section.id }}.sqe-hero--full {
      min-height: 85vh;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__content {
      padding: 60px 24px 40px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__heading {
      font-size: clamp(28px, 7vw, var(--heading-size));
      margin-bottom: 16px;
      line-height: 1.15;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__subheading {
      font-size: clamp(15px, 4.5vw, var(--subheading-size));
      margin-bottom: 32px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__buttons {
      flex-direction: column;
      gap: 12px;
      padding: 0 8px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__button {
      width: 100%;
      text-align: center;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__stats-container {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__stat-number {
      font-size: clamp(28px, 7vw, 36px);
    }

    #sqe-hero-{{ section.id }} .sqe-hero__stat-text {
      font-size: clamp(12px, 3vw, 14px);
    }
  }

  /* ===== MOBILE RESPONSIVE (480px) ===== */
  @media (max-width: 480px) {
    #sqe-hero-{{ section.id }} .sqe-hero__content {
      padding: 50px 20px 30px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__heading {
      font-size: clamp(24px, 7vw, 36px);
      margin-bottom: 12px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__subheading {
      font-size: clamp(14px, 4vw, 17px);
      margin-bottom: 24px;
      line-height: 1.5;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__button {
      padding: 14px 24px;
      font-size: 15px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__stat-item {
      padding: 0 8px;
    }

    #sqe-hero-{{ section.id }} .sqe-hero__stats {
      padding: 20px 16px;
    }
  }
</style>

{% schema %}
{
  "name": "SQE Hero",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Hero"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engineering Excellence in Solar PV Quality Assurance",
      "info": "Main hero heading text"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Trusted by leading solar installers and integrators across the UK for independent quality inspection and technical consulting services.",
      "info": "Secondary heading text"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Use a solar farm drone image for best results"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#1F3A5F"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        {
          "value": "small",
          "label": "Small (400px)"
        },
        {
          "value": "medium",
          "label": "Medium (600px)"
        },
        {
          "value": "large",
          "label": "Large (800px)"
        },
        {
          "value": "full",
          "label": "Full Height (100vh)"
        }
      ],
      "default": "large"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Request a Consultation"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Stats Bar",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Font",
      "options": [
        {
          "value": "'Source Sans 3', sans-serif",
          "label": "Source Sans 3"
        },
        {
          "value": "'Inter', sans-serif",
          "label": "Inter"
        },
        {
          "value": "system-ui, sans-serif",
          "label": "System"
        }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 32,
      "max": 96,
      "step": 2,
      "unit": "px",
      "label": "Size",
      "default": 56
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Color",
      "default": "#ffffff"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Bold (700 weight)",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Font",
      "options": [
        {
          "value": "'Source Sans 3', sans-serif",
          "label": "Source Sans 3"
        },
        {
          "value": "'Inter', sans-serif",
          "label": "Inter"
        },
        {
          "value": "system-ui, sans-serif",
          "label": "System"
        }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "min": 14,
      "max": 32,
      "step": 1,
      "unit": "px",
      "label": "Size",
      "default": 20
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Color",
      "default": "rgba(255, 255, 255, 0.9)"
    },
    {
      "type": "header",
      "content": "Stat Blocks Typography"
    },
    {
      "type": "select",
      "id": "stat_blocks_font",
      "label": "Font",
      "options": [
        {
          "value": "'Source Sans 3', sans-serif",
          "label": "Source Sans 3"
        },
        {
          "value": "'Inter', sans-serif",
          "label": "Inter"
        },
        {
          "value": "system-ui, sans-serif",
          "label": "System"
        }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "stat_number_size",
      "min": 24,
      "max": 64,
      "step": 2,
      "unit": "px",
      "label": "Number Size",
      "default": 32
    },
    {
      "type": "range",
      "id": "stat_text_size",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "label": "Text Size",
      "default": 14
    },
    {
      "type": "color",
      "id": "stat_number_color",
      "label": "Number Color",
      "default": "#F2B705"
    },
    {
      "type": "color",
      "id": "stat_text_color",
      "label": "Text Color",
      "default": "rgba(255, 255, 255, 0.85)"
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Number",
          "default": "15+",
          "info": "e.g., '15+', '500+', 'UK-Wide'"
        },
        {
          "type": "text",
          "id": "stat_text",
          "label": "Stat Label",
          "default": "Years Experience",
          "info": "Description of the statistic"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Hero",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_number": "15+",
            "stat_text": "Years Experience"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "500+",
            "stat_text": "Projects Completed"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "UK-Wide",
            "stat_text": "Coverage"
          }
        }
      ]
    }
  ]
}
{% endschema %}
