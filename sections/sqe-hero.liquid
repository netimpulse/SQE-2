{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign primary_button_text = section.settings.primary_button_text
  assign primary_button_link = section.settings.primary_button_link
  assign secondary_button_text = section.settings.secondary_button_text
  assign secondary_button_link = section.settings.secondary_button_link
  assign background_image = section.settings.background_image
  assign overlay_color = section.settings.overlay_color
  assign overlay_opacity = section.settings.overlay_opacity
  assign text_alignment = section.settings.text_alignment
  assign section_height = section.settings.section_height
  assign show_stats = section.settings.show_stats
  assign heading_color = section.settings.heading_color
  assign subheading_color = section.settings.subheading_color
  assign heading_size = section.settings.heading_size
  assign subheading_size = section.settings.subheading_size
-%}

<section class="sqe-hero sqe-hero--{{ section_height }}" style="--text-alignment: {{ text_alignment }};">
  <div class="sqe-hero__background">
    {%- if background_image -%}
      <img
        src="{{ background_image | image_url: width: 1920 }}"
        alt="SQE Solar Quality Experts hero background"
        class="sqe-hero__image"
        loading="lazy"
      >
    {%- else -%}
      <div class="sqe-hero__placeholder">Solar Farm Image</div>
    {%- endif -%}
    <div class="sqe-hero__overlay" style="--overlay-color: {{ overlay_color }}; --overlay-opacity: {{ overlay_opacity | times: 0.01 }};"></div>
  </div>

  <div class="sqe-hero__content">
    <div class="sqe-hero__text-block">
      {%- if heading -%}
        <h1 class="sqe-hero__heading" style="--heading-color: {{ heading_color }}; --heading-size: {{ heading_size }};">
          {{ heading }}
        </h1>
      {%- endif -%}

      {%- if subheading -%}
        <p class="sqe-hero__subheading" style="--subheading-color: {{ subheading_color }}; --subheading-size: {{ subheading_size }};">
          {{ subheading }}
        </p>
      {%- endif -%}

      {%- if primary_button_text or secondary_button_text -%}
        <div class="sqe-hero__buttons">
          {%- if primary_button_text -%}
            <a href="{{ primary_button_link }}" class="sqe-hero__button sqe-hero__button--primary">
              {{ primary_button_text }}
            </a>
          {%- endif -%}

          {%- if secondary_button_text -%}
            <a href="{{ secondary_button_link }}" class="sqe-hero__button sqe-hero__button--secondary">
              {{ secondary_button_text }}
            </a>
          {%- endif -%}
        </div>
      {%- endif -%}
    </div>
  </div>

  {%- if show_stats -%}
    <div class="sqe-hero__stats">
      <div class="sqe-hero__stats-container">
        {%- for block in section.blocks -%}
          {%- if block.type == 'stat' -%}
            <div class="sqe-hero__stat-item" {{ block.shopify_attributes }}>
              <div class="sqe-hero__stat-number">{{ block.settings.stat_number }}</div>
              <div class="sqe-hero__stat-text">{{ block.settings.stat_text }}</div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  {%- endif -%}
</section>

<style>
  :root {
    --sqe-primary-blue: #1F3A5F;
    --sqe-yellow: #F2B705;
    --sqe-light-grey: #F2F4F7;
    --sqe-dark-grey: #333333;
    --sqe-orange: #C75B12;
  }

  .sqe-hero {
    position: relative;
    width: 100%;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
  }

  .sqe-hero--small {
    min-height: 400px;
  }

  .sqe-hero--medium {
    min-height: 600px;
  }

  .sqe-hero--large {
    min-height: 800px;
  }

  .sqe-hero--full {
    min-height: 100vh;
  }

  .sqe-hero__background {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 1;
  }

  .sqe-hero__image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .sqe-hero__placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, var(--sqe-primary-blue), var(--sqe-light-grey));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 24px;
    color: rgba(255, 255, 255, 0.5);
    font-weight: 500;
  }

  .sqe-hero__overlay {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-color: var(--overlay-color, var(--sqe-primary-blue));
    opacity: var(--overlay-opacity, 0.6);
    z-index: 2;
  }

  .sqe-hero__content {
    position: relative;
    z-index: 3;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px 20px;
    box-sizing: border-box;
  }

  .sqe-hero__text-block {
    max-width: 900px;
    width: 100%;
    text-align: var(--text-alignment, center);
  }

  .sqe-hero__heading {
    font-family: 'Source Sans 3', sans-serif;
    font-size: var(--heading-size, 56px);
    font-weight: 700;
    line-height: 1.2;
    margin: 0 0 20px 0;
    color: var(--heading-color, #ffffff);
    letter-spacing: -0.5px;
  }

  .sqe-hero__subheading {
    font-family: 'Inter', sans-serif;
    font-size: var(--subheading-size, 20px);
    font-weight: 400;
    line-height: 1.6;
    margin: 0 0 40px 0;
    color: var(--subheading-color, rgba(255, 255, 255, 0.9));
  }

  .sqe-hero__buttons {
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    justify-content: var(--text-alignment, center);
  }

  .sqe-hero__button {
    display: inline-block;
    padding: 16px 32px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    text-decoration: none;
    border-radius: 4px;
    transition: all 0.3s ease;
    border: 2px solid transparent;
    cursor: pointer;
  }

  .sqe-hero__button--primary {
    background-color: var(--sqe-yellow);
    color: var(--sqe-primary-blue);
  }

  .sqe-hero__button--primary:hover {
    background-color: #e0a604;
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(242, 183, 5, 0.4);
  }

  .sqe-hero__button--secondary {
    background-color: transparent;
    color: #ffffff;
    border-color: #ffffff;
  }

  .sqe-hero__button--secondary:hover {
    background-color: rgba(255, 255, 255, 0.1);
    transform: translateY(-2px);
    box-shadow: 0 4px 12px rgba(255, 255, 255, 0.2);
  }

  .sqe-hero__stats {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    z-index: 4;
    background: rgba(31, 58, 95, 0.95);
    backdrop-filter: blur(8px);
    padding: 30px 20px;
  }

  .sqe-hero__stats-container {
    max-width: 1200px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: 40px;
  }

  .sqe-hero__stat-item {
    text-align: center;
  }

  .sqe-hero__stat-number {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 32px;
    font-weight: 700;
    color: var(--sqe-yellow);
    line-height: 1;
    margin-bottom: 8px;
  }

  .sqe-hero__stat-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
    letter-spacing: 0.5px;
  }

  /* Mobile Responsive */
  @media (max-width: 768px) {
    .sqe-hero--small {
      min-height: 300px;
    }

    .sqe-hero--medium {
      min-height: 400px;
    }

    .sqe-hero--large {
      min-height: 600px;
    }

    .sqe-hero--full {
      min-height: 80vh;
    }

    .sqe-hero__heading {
      font-size: clamp(32px, 8vw, var(--heading-size, 56px));
      margin-bottom: 16px;
    }

    .sqe-hero__subheading {
      font-size: clamp(16px, 5vw, var(--subheading-size, 20px));
      margin-bottom: 32px;
    }

    .sqe-hero__buttons {
      flex-direction: column;
      gap: 12px;
    }

    .sqe-hero__button {
      width: 100%;
      text-align: center;
    }

    .sqe-hero__stats-container {
      grid-template-columns: 1fr;
      gap: 20px;
    }

    .sqe-hero__stat-number {
      font-size: 28px;
    }

    .sqe-hero__stat-text {
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    .sqe-hero__content {
      padding: 30px 16px;
    }

    .sqe-hero__heading {
      font-size: clamp(24px, 7vw, 40px);
      margin-bottom: 12px;
    }

    .sqe-hero__subheading {
      font-size: clamp(14px, 4vw, 18px);
      margin-bottom: 24px;
    }

    .sqe-hero__button {
      padding: 14px 24px;
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "SQE Hero",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Engineering Excellence in Solar PV Quality Assurance",
      "info": "Main hero heading text"
    },
    {
      "type": "select",
      "id": "heading_size",
      "label": "Heading Size",
      "options": [
        {
          "value": "40px",
          "label": "Small"
        },
        {
          "value": "56px",
          "label": "Medium"
        },
        {
          "value": "72px",
          "label": "Large"
        },
        {
          "value": "90px",
          "label": "Extra Large"
        }
      ],
      "default": "56px"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#ffffff"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Trusted by leading solar installers and integrators across the UK for independent quality inspection and technical consulting services.",
      "info": "Secondary heading text"
    },
    {
      "type": "select",
      "id": "subheading_size",
      "label": "Subheading Size",
      "options": [
        {
          "value": "16px",
          "label": "Small"
        },
        {
          "value": "20px",
          "label": "Medium"
        },
        {
          "value": "24px",
          "label": "Large"
        }
      ],
      "default": "20px"
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "rgba(255, 255, 255, 0.9)"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background Image",
      "info": "Use a solar farm drone image for best results"
    },
    {
      "type": "color",
      "id": "overlay_color",
      "label": "Overlay Color",
      "default": "#1F3A5F"
    },
    {
      "type": "range",
      "id": "overlay_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Overlay Opacity",
      "default": 60
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "select",
      "id": "section_height",
      "label": "Section Height",
      "options": [
        {
          "value": "small",
          "label": "Small (400px)"
        },
        {
          "value": "medium",
          "label": "Medium (600px)"
        },
        {
          "value": "large",
          "label": "Large (800px)"
        },
        {
          "value": "full",
          "label": "Full Height (100vh)"
        }
      ],
      "default": "large"
    },
    {
      "type": "text",
      "id": "primary_button_text",
      "label": "Primary Button Text",
      "default": "Request a Consultation"
    },
    {
      "type": "url",
      "id": "primary_button_link",
      "label": "Primary Button Link"
    },
    {
      "type": "text",
      "id": "secondary_button_text",
      "label": "Secondary Button Text",
      "default": "Learn More"
    },
    {
      "type": "url",
      "id": "secondary_button_link",
      "label": "Secondary Button Link"
    },
    {
      "type": "checkbox",
      "id": "show_stats",
      "label": "Show Stats Bar",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "stat",
      "name": "Stat",
      "settings": [
        {
          "type": "text",
          "id": "stat_number",
          "label": "Stat Number",
          "default": "15+",
          "info": "e.g., '15+', '500+', 'UK-Wide'"
        },
        {
          "type": "text",
          "id": "stat_text",
          "label": "Stat Label",
          "default": "Years Experience",
          "info": "Description of the statistic"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Hero",
      "blocks": [
        {
          "type": "stat",
          "settings": {
            "stat_number": "15+",
            "stat_text": "Years Experience"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "500+",
            "stat_text": "Projects Completed"
          }
        },
        {
          "type": "stat",
          "settings": {
            "stat_number": "UK-Wide",
            "stat_text": "Coverage"
          }
        }
      ]
    }
  ]
}
{% endschema %}
