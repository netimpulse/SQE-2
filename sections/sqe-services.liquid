{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign columns = section.settings.columns
  assign bg_color = section.settings.background_color
  assign card_style = section.settings.card_style
-%}

<section id="sqe-services-{{ section.id }}" class="sqe-services" style="background-color: {{ bg_color }};">
  <div class="sqe-services-container">
    {% if heading != blank %}
      <h2 class="sqe-services-heading">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="sqe-services-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="sqe-services-grid" data-columns="{{ columns }}" data-style="{{ card_style }}">
      {% for block in section.blocks %}
        {% if block.type == 'service_card' %}
          <div class="sqe-service-card" {{ block.shopify_attributes }}>
            {% if block.settings.icon != blank %}
              <div class="sqe-service-icon">
                <img
                  src="{{ block.settings.icon | image_url: width: 80 }}"
                  alt="{{ block.settings.title }}"
                  loading="lazy"
                >
              </div>
            {% endif %}

            <div class="sqe-service-content">
              {% if block.settings.title != blank %}
                <h3 class="sqe-service-title">{{ block.settings.title }}</h3>
              {% endif %}

              {% if block.settings.description != blank %}
                <p class="sqe-service-description">{{ block.settings.description }}</p>
              {% endif %}

              {% if block.settings.link_text != blank and block.settings.link_url != blank %}
                <a href="{{ block.settings.link_url }}" class="sqe-service-link">{{ block.settings.link_text }}</a>
              {% endif %}
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</section>

<style>
  #sqe-services-{{ section.id }} {
    padding: 60px 20px;
  }

  .sqe-services-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sqe-services-heading {
    font-size: 36px;
    font-weight: 700;
    color: #1F3A5F;
    text-align: center;
    margin-bottom: 10px;
  }

  .sqe-services-subheading {
    font-size: 16px;
    color: #666;
    text-align: center;
    margin-bottom: 40px;
  }

  .sqe-services-grid {
    display: grid;
    gap: 30px;
    margin-top: 40px;
  }

  .sqe-services-grid[data-columns="2"] {
    grid-template-columns: repeat(2, 1fr);
  }

  .sqe-services-grid[data-columns="3"] {
    grid-template-columns: repeat(3, 1fr);
  }

  .sqe-services-grid[data-columns="4"] {
    grid-template-columns: repeat(4, 1fr);
  }

  .sqe-service-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    height: 100%;
    transition: all 0.3s ease;
  }

  .sqe-services-grid[data-style="bordered"] .sqe-service-card {
    border: 2px solid #E8E8E8;
  }

  .sqe-services-grid[data-style="bordered"] .sqe-service-card:hover {
    border-color: #1F3A5F;
  }

  .sqe-services-grid[data-style="shadow"] .sqe-service-card {
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
  }

  .sqe-services-grid[data-style="shadow"] .sqe-service-card:hover {
    box-shadow: 0 8px 20px rgba(0, 0, 0, 0.15);
  }

  .sqe-service-card:hover {
    transform: translateY(-4px);
  }

  .sqe-service-icon {
    width: 80px;
    height: 80px;
    background-color: #F2F4F7;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: 20px;
  }

  .sqe-service-icon img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .sqe-service-content {
    flex-grow: 1;
  }

  .sqe-service-title {
    font-size: 20px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 12px;
  }

  .sqe-service-description {
    font-size: 14px;
    color: #666;
    line-height: 1.6;
    margin-bottom: 15px;
  }

  .sqe-service-link {
    color: #1F3A5F;
    text-decoration: none;
    font-weight: 600;
    font-size: 14px;
    display: inline-block;
  }

  .sqe-service-link:hover {
    color: #C75B12;
  }

  @media (max-width: 768px) {
    .sqe-services-grid[data-columns="3"],
    .sqe-services-grid[data-columns="4"] {
      grid-template-columns: repeat(2, 1fr);
    }

    .sqe-services-grid[data-columns="2"] {
      grid-template-columns: 1fr;
    }
  }

  @media (max-width: 480px) {
    .sqe-services-grid {
      grid-template-columns: 1fr !important;
    }

    .sqe-services-heading {
      font-size: 24px;
    }
  }
</style>

<script>
  var servicesSection = document.getElementById('sqe-services-' + '{{ section.id }}');
  if (servicesSection) {
    var cards = servicesSection.querySelectorAll('.sqe-service-card');
    cards.forEach(function(card) {
      card.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-4px)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0)';
      });
    });
  }
</script>

{% schema %}
{
  "name": "SQE Services",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Services"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Professional solutions for your needs"
    },
    {
      "type": "select",
      "id": "columns",
      "label": "Columns",
      "options": [
        { "value": "2", "label": "2" },
        { "value": "3", "label": "3" },
        { "value": "4", "label": "4" }
      ],
      "default": "3"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    },
    {
      "type": "select",
      "id": "card_style",
      "label": "Card Style",
      "options": [
        { "value": "bordered", "label": "Bordered" },
        { "value": "shadow", "label": "Shadow" }
      ],
      "default": "shadow"
    }
  ],
  "blocks": [
    {
      "type": "service_card",
      "name": "Service Card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Service Title"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description",
          "default": "Brief service description"
        },
        {
          "type": "text",
          "id": "link_text",
          "label": "Link Text",
          "default": "Learn More"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Services",
      "blocks": [
        { "type": "service_card" },
        { "type": "service_card" },
        { "type": "service_card" }
      ]
    }
  ]
}
{% endschema %}
