{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign background_color = section.settings.background_color
-%}

<section id="section-{{ section.id }}" class="sqe-project-showcase" style="background-color: {{ background_color }};">
  <div class="showcase-container">
    {% if heading %}
      <h2 class="showcase-heading">{{ heading }}</h2>
    {% endif %}
    {% if subheading %}
      <p class="showcase-subheading">{{ subheading }}</p>
    {% endif %}

    <div class="showcase-main">
      {% if section.blocks.size > 0 %}
        {% assign first_block = section.blocks.first %}
        <div class="featured-project" data-project-id="{{ first_block.id }}">
          {% if first_block.settings.image %}
            <img src="{{ first_block.settings.image | img_url: '800x600' }}" alt="{{ first_block.settings.title }}" class="featured-image">
          {% endif %}
          <div class="featured-info">
            <h3 class="project-title">{{ first_block.settings.title }}</h3>
            {% if first_block.settings.location %}
              <p class="project-meta"><strong>Location:</strong> {{ first_block.settings.location }}</p>
            {% endif %}
            {% if first_block.settings.capacity %}
              <p class="project-meta"><strong>Capacity:</strong> {{ first_block.settings.capacity }}</p>
            {% endif %}
            {% if first_block.settings.project_type %}
              <p class="project-meta"><strong>Type:</strong> {{ first_block.settings.project_type }}</p>
            {% endif %}
            {% if first_block.settings.year %}
              <p class="project-meta"><strong>Year:</strong> {{ first_block.settings.year }}</p>
            {% endif %}
            {% if first_block.settings.description %}
              <p class="project-description">{{ first_block.settings.description }}</p>
            {% endif %}
          </div>
        </div>
      {% endif %}
    </div>

    {% if section.blocks.size > 1 %}
      <div class="thumbnail-strip">
        {% for block in section.blocks %}
          <div class="thumbnail-item" data-project-id="{{ block.id }}" data-project-title="{{ block.settings.title | escape }}" data-project-location="{{ block.settings.location | escape }}" data-project-capacity="{{ block.settings.capacity | escape }}" data-project-type="{{ block.settings.project_type | escape }}" data-project-year="{{ block.settings.year | escape }}" data-project-description="{{ block.settings.description | escape }}" {% if block.settings.image %}data-project-image="{{ block.settings.image | img_url: '800x600' }}"{% endif %}>
            {% if block.settings.image %}
              <img src="{{ block.settings.image | img_url: '150x150' }}" alt="{{ block.settings.title }}" class="thumbnail-image">
            {% endif %}
            <p class="thumbnail-title">{{ block.settings.title }}</p>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #section-{{ section.id }} {
    padding: 60px 20px;
  }

  .sqe-project-showcase {
    transition: background-color 0.3s ease;
  }

  .showcase-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .showcase-heading {
    font-size: 48px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 10px;
    text-align: center;
  }

  .showcase-subheading {
    font-size: 18px;
    color: #333333;
    text-align: center;
    margin-bottom: 50px;
  }

  .showcase-main {
    margin-bottom: 40px;
  }

  .featured-project {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    background: white;
    padding: 30px;
    border-radius: 8px;
  }

  .featured-image {
    width: 100%;
    height: auto;
    border-radius: 8px;
    object-fit: cover;
  }

  .featured-info {
    padding: 20px 0;
  }

  .project-title {
    font-size: 36px;
    font-weight: 700;
    color: #1F3A5F;
    margin-bottom: 20px;
  }

  .project-meta {
    font-size: 14px;
    color: #666;
    margin-bottom: 10px;
  }

  .project-description {
    font-size: 16px;
    color: #333333;
    line-height: 1.6;
    margin-top: 20px;
  }

  .thumbnail-strip {
    display: flex;
    gap: 15px;
    overflow-x: auto;
    padding-bottom: 10px;
  }

  .thumbnail-item {
    flex: 0 0 150px;
    text-align: center;
    cursor: pointer;
    border: 3px solid transparent;
    border-radius: 8px;
    padding: 10px;
    transition: all 0.3s ease;
  }

  .thumbnail-item:hover,
  .thumbnail-item.active {
    border-color: #F2B705;
    background-color: #F2F4F7;
  }

  .thumbnail-image {
    width: 100%;
    height: 120px;
    object-fit: cover;
    border-radius: 6px;
    margin-bottom: 10px;
  }

  .thumbnail-title {
    font-size: 13px;
    font-weight: 600;
    color: #333333;
  }

  @media (max-width: 768px) {
    .featured-project {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 20px;
    }
    .showcase-heading {
      font-size: 32px;
    }
    .project-title {
      font-size: 24px;
    }
  }
</style>

<script>
  (function() {
    var el = document.getElementById('section-' + '{{ section.id }}');
    var thumbnails = el.querySelectorAll('.thumbnail-item');
    var featured = el.querySelector('.featured-project');

    thumbnails.forEach(function(thumb) {
      thumb.addEventListener('click', function() {
        thumbnails.forEach(function(t) { t.classList.remove('active'); });
        this.classList.add('active');

        var title = this.getAttribute('data-project-title');
        var location = this.getAttribute('data-project-location');
        var capacity = this.getAttribute('data-project-capacity');
        var type = this.getAttribute('data-project-type');
        var year = this.getAttribute('data-project-year');
        var desc = this.getAttribute('data-project-description');
        var img = this.getAttribute('data-project-image');

        var html = '<div class="featured-info"><h3 class="project-title">' + title + '</h3>';
        if (location) html += '<p class="project-meta"><strong>Location:</strong> ' + location + '</p>';
        if (capacity) html += '<p class="project-meta"><strong>Capacity:</strong> ' + capacity + '</p>';
        if (type) html += '<p class="project-meta"><strong>Type:</strong> ' + type + '</p>';
        if (year) html += '<p class="project-meta"><strong>Year:</strong> ' + year + '</p>';
        if (desc) html += '<p class="project-description">' + desc + '</p>';
        html += '</div>';

        featured.innerHTML = '';
        if (img) {
          var imgEl = document.createElement('img');
          imgEl.src = img;
          imgEl.alt = title;
          imgEl.className = 'featured-image';
          featured.appendChild(imgEl);
        }
        featured.innerHTML += html;
      });
    });

    if (thumbnails.length > 0) {
      thumbnails[0].classList.add('active');
    }
  })();
</script>

{% schema %}
{
  "name": "Project Showcase",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Featured Projects"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Browse our latest work"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "project",
      "name": "Project",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Project Image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Project Title"
        },
        {
          "type": "text",
          "id": "location",
          "label": "Location"
        },
        {
          "type": "text",
          "id": "capacity",
          "label": "Capacity"
        },
        {
          "type": "text",
          "id": "project_type",
          "label": "Project Type"
        },
        {
          "type": "text",
          "id": "year",
          "label": "Year"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Description"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Project Showcase"
    }
  ]
}
{% endschema %}
