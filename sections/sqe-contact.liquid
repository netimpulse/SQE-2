{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_font_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign sh_font = section.settings.subheading_font
  assign sh_size = section.settings.subheading_size
  assign sh_color = section.settings.subheading_color
-%}

<style>
  #sqe-contact-{{ section.id }} {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_x }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_x }}px;
  }

  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-contact-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: #C75B12; background: rgba(199,91,18,.1);
    padding: 4px 14px; border-radius: 20px; margin-bottom: 12px;
  }

  #sqe-contact-{{ section.id }} .sqe-contact__container {
    max-width: 1200px;
    margin: 0 auto;
  }

  #sqe-contact-{{ section.id }} .sqe-contact__heading {
    font-family: {{ h_font }};
    font-size: {{ h_size }}px;
    font-weight: {{ h_weight }};
    color: {{ h_color }};
    margin: 0 0 50px 0;
    text-align: {{ section.settings.heading_alignment }};
    line-height: 1.2;
  }

  .sqe-contact__wrapper {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 50px;
    align-items: start;
  }

  .sqe-contact__info-section {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }

  .sqe-contact__info-block {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }

  .sqe-contact__info-label {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 1px;
    color: {{ section.settings.label_color }};
  }

  .sqe-contact__info-value {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: {{ section.settings.info_text_color }};
    line-height: 1.6;
  }

  .sqe-contact__info-value a {
    color: {{ section.settings.link_color }};
    text-decoration: none;
    transition: color 0.3s ease;
  }

  .sqe-contact__info-value a:hover {
    color: {{ section.settings.link_hover_color }};
    text-decoration: underline;
  }

  .sqe-contact__map {
    margin-top: 40px;
    border-radius: {{ section.settings.map_border_radius }}px;
    overflow: hidden;
    height: 300px;
  }

  .sqe-contact__map iframe {
    width: 100%;
    height: 100%;
    border: none;
  }

  .sqe-contact__socials {
    display: flex;
    gap: 20px;
    margin-top: 40px;
  }

  .sqe-contact__social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background-color: {{ section.settings.social_bg_color }};
    color: {{ section.settings.social_text_color }};
    border-radius: 50%;
    text-decoration: none;
    transition: all 0.3s ease;
    font-size: 18px;
  }

  .sqe-contact__social-link:hover {
    background-color: {{ section.settings.social_bg_hover_color }};
    transform: translateY(-2px);
  }

  .sqe-contact__form-section {
    display: flex;
    flex-direction: column;
    gap: 20px;
  }

  .sqe-contact__form-group {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .sqe-contact__form-label {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: {{ section.settings.form_label_color }};
  }

  .sqe-contact__form-input,
  .sqe-contact__form-textarea {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    padding: 12px 16px;
    border: 1px solid {{ section.settings.form_border_color }};
    border-radius: {{ section.settings.form_border_radius }}px;
    background-color: {{ section.settings.form_bg_color }};
    color: {{ section.settings.form_text_color }};
    transition: all 0.3s ease;
  }

  .sqe-contact__form-input:focus,
  .sqe-contact__form-textarea:focus {
    outline: none;
    border-color: {{ section.settings.form_focus_border_color }};
    background-color: {{ section.settings.form_focus_bg_color }};
    box-shadow: 0 0 0 3px rgba(31, 58, 95, 0.1);
  }

  .sqe-contact__form-textarea {
    resize: vertical;
    min-height: 150px;
    font-family: 'Inter', sans-serif;
  }

  .sqe-contact__form-button {
    align-self: flex-start;
    padding: {{ section.settings.form_button_padding_y }}px {{ section.settings.form_button_padding_x }}px;
    background-color: {{ section.settings.form_button_bg }};
    color: {{ section.settings.form_button_text }};
    border: none;
    border-radius: {{ section.settings.form_button_border_radius }}px;
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    text-decoration: none;
    display: inline-block;
  }

  .sqe-contact__form-button:hover {
    background-color: {{ section.settings.form_button_bg_hover }};
    transform: translateY(-2px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .sqe-contact__form-note {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: {{ section.settings.form_note_color }};
    margin-top: 10px;
  }

  @media (max-width: 768px) {
    .sqe-contact {
      padding: {{ section.settings.mobile_padding_top }}px {{ section.settings.mobile_padding_x }}px {{ section.settings.mobile_padding_bottom }}px {{ section.settings.mobile_padding_x }}px;
    }

    #sqe-contact-{{ section.id }} .sqe-contact__heading {
      font-size: {{ section.settings.mobile_heading_font_size }}px;
      margin-bottom: 40px;
    }

    .sqe-contact__wrapper {
      grid-template-columns: 1fr;
      gap: 40px;
    }

    .sqe-contact__form-button {
      width: 100%;
      align-self: stretch;
      text-align: center;
    }
  }

  @media (max-width: 480px) {
    #sqe-contact-{{ section.id }} {
      padding: 30px 16px;
    }

    #sqe-contact-{{ section.id }} .sqe-contact__heading {
      font-size: {{ section.settings.mobile_heading_font_size | minus: 6 }}px;
    }

    .sqe-contact__form-button {
      font-size: 14px;
    }
  }
</style>

<div id="sqe-contact-{{ section.id }}" class="sqe-contact">
  <div class="sqe-contact__container">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    {% if section.settings.heading %}
      <h2 class="sqe-contact__heading">{{ section.settings.heading }}</h2>
    {% endif %}

    <div class="sqe-contact__wrapper">
      <!-- Contact Information Section -->
      <div class="sqe-contact__info-section">
        <!-- Address Block -->
        {% if section.settings.show_address %}
          <div class="sqe-contact__info-block">
            <div class="sqe-contact__info-label">Address</div>
            <div class="sqe-contact__info-value">
              {{ section.settings.address_line_1 }}<br>
              {{ section.settings.address_line_2 }}<br>
              {{ section.settings.address_line_3 }}<br>
              {{ section.settings.address_line_4 }}
            </div>
          </div>
        {% endif %}

        <!-- Phone Block -->
        {% if section.settings.show_phone %}
          <div class="sqe-contact__info-block">
            <div class="sqe-contact__info-label">Phone</div>
            <div class="sqe-contact__info-value">
              <a href="tel:{{ section.settings.phone | remove: ' ' | remove: '-' | remove: '(' | remove: ')' }}">
                {{ section.settings.phone }}
              </a>
            </div>
          </div>
        {% endif %}

        <!-- Email Block -->
        {% if section.settings.show_email %}
          <div class="sqe-contact__info-block">
            <div class="sqe-contact__info-label">Email</div>
            <div class="sqe-contact__info-value">
              <a href="mailto:{{ section.settings.email }}">
                {{ section.settings.email }}
              </a>
            </div>
          </div>
        {% endif %}

        <!-- Map Embed -->
        {% if section.settings.show_map and section.settings.map_embed %}
          <div class="sqe-contact__map">
            {{ section.settings.map_embed }}
          </div>
        {% endif %}

        <!-- Social Media Links -->
        {% if section.settings.show_socials %}
          <div class="sqe-contact__socials">
            {% if section.settings.facebook_url %}
              <a href="{{ section.settings.facebook_url }}" class="sqe-contact__social-link" title="Facebook" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.twitter_url %}
              <a href="{{ section.settings.twitter_url }}" class="sqe-contact__social-link" title="Twitter" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M23.953 4.57a10 10 0 002.856 2.905 10 10 0 01-2.997.8 4.993 4.993 0 002.191-2.757 9.98 9.98 0 01-3.127 1.195 4.993 4.993 0 00-8.526 4.547 14.148 14.148 0 01-10.28-5.287 4.993 4.993 0 001.547 6.659 4.993 4.993 0 01-2.262-.57v.062a4.993 4.993 0 003.995 4.9 4.993 4.993 0 01-2.253.085 4.993 4.993 0 004.663 3.476A10.01 10.01 0 010 19.033a14.148 14.148 0 007.666 2.247"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.linkedin_url %}
              <a href="{{ section.settings.linkedin_url }}" class="sqe-contact__social-link" title="LinkedIn" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.475-2.236-1.986-2.236-1.081 0-1.722.722-2.004 1.418-.103.249-.129.597-.129.946v5.441h-3.554s.05-8.807 0-9.719h3.554v1.375c.427-.659 1.191-1.595 2.897-1.595 2.117 0 3.704 1.384 3.704 4.362v5.577zM5.337 8.855c-1.144 0-1.915-.762-1.915-1.715 0-.953.77-1.715 1.959-1.715 1.188 0 1.915.762 1.915 1.715 0 .953-.728 1.715-1.959 1.715zm1.959 11.597H3.322V9.268h3.974v11.184zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                </svg>
              </a>
            {% endif %}
            {% if section.settings.instagram_url %}
              <a href="{{ section.settings.instagram_url }}" class="sqe-contact__social-link" title="Instagram" target="_blank" rel="noopener noreferrer">
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M12.315 2c2.43 0 2.784.013 3.808.06 1.064.049 1.793.217 2.427.465a4.9 4.9 0 011.772 1.153 4.902 4.902 0 011.153 1.772c.248.634.416 1.363.465 2.427.048 1.067.06 1.407.06 4.123v.08c0 2.643-.012 2.987-.06 4.043-.049 1.064-.218 1.791-.465 2.427a4.902 4.902 0 01-1.153 1.772 4.9 4.9 0 01-1.772 1.153c-.634.247-1.363.416-2.427.465-1.067.048-1.407.06-4.123.06h-.08c-2.643 0-2.987-.012-4.043-.06-1.064-.049-1.793-.218-2.427-.465a4.902 4.902 0 01-1.772-1.153 4.902 4.902 0 01-1.153-1.772c-.248-.634-.416-1.363-.465-2.427-.047-1.024-.06-1.379-.06-3.808v-.63c0-2.43.013-2.784.06-3.808.049-1.064.217-1.793.465-2.427a4.902 4.902 0 011.153-1.772A4.902 4.902 0 015.45 2.525c.634-.248 1.363-.416 2.427-.465C8.901 2.013 9.256 2 11.685 2h.63zm-.081 1.802h-.468c-2.456 0-2.784.011-3.807.058-.975.045-1.504.207-1.857.344-.467.182-.8.398-1.15.748-.35.35-.566.683-.748 1.15-.137.353-.3.882-.344 1.857-.047 1.023-.058 1.351-.058 3.807v.468c0 2.456.011 2.784.058 3.807.045.975.207 1.504.344 1.857.182.466.399.8.748 1.15.35.35.683.566 1.15.748.353.137.882.3 1.857.344 1.054.048 1.37.058 4.041.058h.08c2.597 0 2.917-.01 3.96-.058.976-.045 1.505-.207 1.858-.344.466-.182.8-.398 1.15-.748.35-.35.566-.683.748-1.15.137-.353.3-.882.344-1.857.048-1.055.058-1.37.058-4.041v-.08c0-2.597-.01-2.917-.058-3.96-.045-.976-.207-1.505-.344-1.858a3.097 3.097 0 00-.748-1.15 3.098 3.098 0 00-1.15-.748c-.353-.137-.882-.3-1.857-.344-1.023-.047-1.351-.058-3.807-.058zM12 6.865a5.135 5.135 0 110 10.27 5.135 5.135 0 010-10.27zm0 1.802a3.333 3.333 0 100 6.666 3.333 3.333 0 000-6.666zm5.338-3.205a1.2 1.2 0 110 2.4 1.2 1.2 0 010-2.4z"/>
                </svg>
              </a>
            {% endif %}
          </div>
        {% endif %}
      </div>

      <!-- Contact Form Section -->
      <div class="sqe-contact__form-section">
        <form method="POST" action="#" class="sqe-contact__form">
          <!-- Name Field -->
          {% if section.settings.show_name_field %}
            <div class="sqe-contact__form-group">
              <label for="contact-name" class="sqe-contact__form-label">
                Name
                {% if section.settings.name_required %}<span style="color: red;">*</span>{% endif %}
              </label>
              <input
                type="text"
                id="contact-name"
                name="name"
                class="sqe-contact__form-input"
                placeholder="Your name"
                {% if section.settings.name_required %}required{% endif %}
              >
            </div>
          {% endif %}

          <!-- Email Field -->
          {% if section.settings.show_email_field %}
            <div class="sqe-contact__form-group">
              <label for="contact-email" class="sqe-contact__form-label">
                Email
                {% if section.settings.email_required %}<span style="color: red;">*</span>{% endif %}
              </label>
              <input
                type="email"
                id="contact-email"
                name="email"
                class="sqe-contact__form-input"
                placeholder="your@email.com"
                {% if section.settings.email_required %}required{% endif %}
              >
            </div>
          {% endif %}

          <!-- Phone Field -->
          {% if section.settings.show_phone_field %}
            <div class="sqe-contact__form-group">
              <label for="contact-phone" class="sqe-contact__form-label">
                Phone
                {% if section.settings.phone_required %}<span style="color: red;">*</span>{% endif %}
              </label>
              <input
                type="tel"
                id="contact-phone"
                name="phone"
                class="sqe-contact__form-input"
                placeholder="+44 (0)..."
                {% if section.settings.phone_required %}required{% endif %}
              >
            </div>
          {% endif %}

          <!-- Company Field -->
          {% if section.settings.show_company_field %}
            <div class="sqe-contact__form-group">
              <label for="contact-company" class="sqe-contact__form-label">
                Company
                {% if section.settings.company_required %}<span style="color: red;">*</span>{% endif %}
              </label>
              <input
                type="text"
                id="contact-company"
                name="company"
                class="sqe-contact__form-input"
                placeholder="Your company"
                {% if section.settings.company_required %}required{% endif %}
              >
            </div>
          {% endif %}

          <!-- Message Field -->
          {% if section.settings.show_message_field %}
            <div class="sqe-contact__form-group">
              <label for="contact-message" class="sqe-contact__form-label">
                Message
                {% if section.settings.message_required %}<span style="color: red;">*</span>{% endif %}
              </label>
              <textarea
                id="contact-message"
                name="message"
                class="sqe-contact__form-textarea"
                placeholder="Tell us more about your project..."
                {% if section.settings.message_required %}required{% endif %}
              ></textarea>
            </div>
          {% endif %}

          <button type="submit" class="sqe-contact__form-button">
            {{ section.settings.button_text }}
          </button>

          {% if section.settings.show_privacy_note %}
            <p class="sqe-contact__form-note">
              {{ section.settings.privacy_note_text }}
            </p>
          {% endif %}
        </form>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "SQE Contact",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Contact"
    },
    {
      "type": "header",
      "content": "General"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Section Heading",
      "default": "Get in Touch"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "select",
      "id": "heading_alignment",
      "label": "Heading Alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F4F7"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "range",
      "id": "heading_font_size",
      "label": "Heading Font Size (Desktop)",
      "min": 24,
      "max": 60,
      "step": 2,
      "default": 42
    },
    {
      "type": "range",
      "id": "mobile_heading_font_size",
      "label": "Heading Font Size (Mobile)",
      "min": 18,
      "max": 36,
      "step": 2,
      "default": 28
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading Color",
      "default": "#1F3A5F"
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "subheading_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "subheading_size",
      "label": "Subheading Size",
      "min": 12,
      "max": 20,
      "step": 1,
      "default": 16
    },
    {
      "type": "color",
      "id": "subheading_color",
      "label": "Subheading Color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Contact Information"
    },
    {
      "type": "checkbox",
      "id": "show_address",
      "label": "Show Address",
      "default": true
    },
    {
      "type": "text",
      "id": "address_line_1",
      "label": "Address Line 1",
      "default": "Bridge House"
    },
    {
      "type": "text",
      "id": "address_line_2",
      "label": "Address Line 2",
      "default": "Old Grantham Road"
    },
    {
      "type": "text",
      "id": "address_line_3",
      "label": "Address Line 3",
      "default": "Whatton, Nottingham NG13 9FG"
    },
    {
      "type": "text",
      "id": "address_line_4",
      "label": "Address Line 4",
      "default": "United Kingdom"
    },
    {
      "type": "checkbox",
      "id": "show_phone",
      "label": "Show Phone",
      "default": true
    },
    {
      "type": "text",
      "id": "phone",
      "label": "Phone Number",
      "default": "+44 (0) 1949 000000"
    },
    {
      "type": "checkbox",
      "id": "show_email",
      "label": "Show Email",
      "default": true
    },
    {
      "type": "text",
      "id": "email",
      "label": "Email Address",
      "default": "info@sqesolar.co.uk"
    },
    {
      "type": "header",
      "content": "Map"
    },
    {
      "type": "checkbox",
      "id": "show_map",
      "label": "Show Map",
      "default": true
    },
    {
      "type": "textarea",
      "id": "map_embed",
      "label": "Map Embed Code (Google Maps iframe)",
      "default": "<iframe src=\"https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2409.8566821649994!2d-0.8369999!3d52.84166!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2zNTLCsDUwJzM2LjAiTiAwwrA1MCcwOC41Ilc!5e0!3m2!1sen!2suk!4v0\" width=\"100%\" height=\"300\" style=\"border:0;\" allowfullscreen=\"\" loading=\"lazy\"></iframe>"
    },
    {
      "type": "range",
      "id": "map_border_radius",
      "label": "Map Border Radius",
