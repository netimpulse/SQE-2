{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign d_font = section.settings.description_font
  assign d_size = section.settings.description_size
  assign d_color = section.settings.description_color
  assign step_title_color = section.settings.step_title_color
  assign step_description_color = section.settings.step_description_color
  assign timeline_label_color = section.settings.timeline_label_color
  assign active_dot_color = section.settings.active_dot_color
-%}

<style>
  #sqe-process-section-{{ section.id }} {
    --sqe-color-primary: #1F3A5F;
    --sqe-color-accent: #F2B705;
    --sqe-color-border: #E8ECEF;
    --sqe-color-text-muted: #999;
    --sqe-color-text-dark: #666;
    --sqe-color-label: #C75B12;
    --sqe-color-label-bg: rgba(199, 91, 18, 0.1);
    --sqe-color-white: white;
    --sqe-step-title-color: {{ step_title_color }};
    --sqe-step-description-color: {{ step_description_color }};
    --sqe-timeline-label-color: {{ timeline_label_color }};
    --sqe-active-dot-color: {{ active_dot_color }};
    --sqe-shadow-sm: 0 4px 15px rgba(31, 58, 95, 0.08);
    --sqe-shadow-md: 0 8px 25px rgba(242, 183, 5, 0.3);
    --sqe-shadow-lg: 0 20px 60px rgba(31, 58, 95, 0.12);
    --sqe-transition: 0.3s ease;
    --sqe-transition-cubic: 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    --sqe-spacing-xs: 12px;
    --sqe-spacing-sm: 20px;
    --sqe-spacing-md: 40px;
    --sqe-spacing-lg: 60px;
    --sqe-radius-sm: 12px;
    --sqe-radius-md: 16px;
  }

  #sqe-process-section-{{ section.id }} .sqe-process-section {
    padding: {{ section.settings.padding_top }}px 20px var(--sqe-spacing-lg) 20px;
    background: {{ section.settings.background_color }};
    font-family: 'Inter', sans-serif;
  }

  #sqe-process-section-{{ section.id }} .sqe-process-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  #sqe-process-section-{{ section.id }} .sqe-process-header {
    text-align: center;
    margin-bottom: var(--sqe-spacing-lg);
  }

  #sqe-process-section-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--sqe-color-label);
    background: var(--sqe-color-label-bg);
    padding: 4px 14px;
    border-radius: 20px;
    margin-bottom: var(--sqe-spacing-xs);
    word-break: break-word;
    overflow-wrap: break-word;
  }

  #sqe-process-section-{{ section.id }} .sqe-process-header h2 {
    font-family: {{ h_font }};
    font-size: {{ h_size }}px;
    font-weight: {{ h_weight }};
    color: {{ h_color }};
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  #sqe-process-section-{{ section.id }} .sqe-process-header p {
    font-family: {{ d_font }};
    font-size: {{ d_size }}px;
    color: {{ d_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.6;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  /* ===== TIMELINE (Desktop & Mobile) ===== */
  #sqe-process-section-{{ section.id }} .sqe-timeline-wrapper {
    position: relative;
    padding: var(--sqe-spacing-md) 0;
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-track {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 50px;
    padding: 0 var(--sqe-spacing-md);
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-track::before {
    content: '';
    position: absolute;
    top: 30px;
    left: var(--sqe-spacing-md);
    right: var(--sqe-spacing-md);
    height: 3px;
    background: var(--sqe-color-border);
    z-index: 0;
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-track.animated::before {
    background: linear-gradient(
      to right,
      var(--sqe-color-primary) 0%,
      var(--sqe-color-primary) var(--progress),
      var(--sqe-color-border) var(--progress),
      var(--sqe-color-border) 100%
    );
    transition: background var(--sqe-transition);
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-step {
    position: relative;
    flex: 1;
    text-align: center;
    cursor: pointer;
    z-index: 2;
    transition: transform var(--sqe-transition);
    padding: 0 15px;
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-step:hover {
    transform: translateY(-8px);
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-dot {
    width: 60px;
    height: 60px;
    margin: 0 auto var(--sqe-spacing-sm) auto;
    border-radius: 50%;
    background: var(--sqe-color-white);
    border: 3px solid var(--sqe-color-border);
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 18px;
    color: var(--sqe-color-text-muted);
    position: relative;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: var(--sqe-shadow-sm);
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-step.active .sqe-timeline-dot {
    width: 72px;
    height: 72px;
    background: var(--sqe-active-dot-color);
    border-color: var(--sqe-active-dot-color);
    color: var(--sqe-color-primary);
    box-shadow: 0 8px 25px color-mix(in srgb, var(--sqe-active-dot-color) 30%, transparent);
    animation: sqe-pulse-dot-{{ section.id }} 2s infinite;
  }

  @keyframes sqe-pulse-dot-{{ section.id }} {
    0%, 100% {
      box-shadow: 0 8px 25px color-mix(in srgb, var(--sqe-active-dot-color) 30%, transparent);
    }
    50% {
      box-shadow: 0 8px 35px color-mix(in srgb, var(--sqe-active-dot-color) 50%, transparent);
    }
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-dot.completed {
    background: var(--sqe-color-primary);
    border-color: var(--sqe-color-primary);
    color: var(--sqe-color-white);
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-label {
    font-size: 14px;
    color: var(--sqe-timeline-label-color);
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all var(--sqe-transition);
    line-height: 1.4;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  #sqe-process-section-{{ section.id }} .sqe-timeline-step.active .sqe-timeline-label {
    color: var(--sqe-color-primary);
    font-weight: 600;
  }

  /* ===== DETAIL PANEL ===== */
  #sqe-process-section-{{ section.id }} .sqe-detail-panel-wrapper {
    position: relative;
    height: 400px;
    margin-top: 50px;
    border-radius: var(--sqe-radius-md);
    overflow: hidden;
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-panel {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--sqe-color-white);
    border-radius: var(--sqe-radius-md);
    padding: var(--sqe-spacing-md);
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--sqe-spacing-md);
    align-items: center;
    opacity: 0;
    transform: translateX(60px);
    pointer-events: none;
    transition: all var(--sqe-transition-cubic);
    box-shadow: var(--sqe-shadow-lg);
    border: 1px solid rgba(242, 183, 5, 0.1);
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-panel.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-content h3 {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: var(--sqe-step-title-color);
    margin: 0 0 16px 0;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-content p {
    font-size: 15px;
    color: var(--sqe-step-description-color);
    line-height: 1.6;
    margin: 0;
    word-break: break-word;
    overflow-wrap: break-word;
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-image {
    position: relative;
    height: 100%;
    min-height: 300px;
    border-radius: var(--sqe-radius-sm);
    overflow: hidden;
    background: linear-gradient(135deg, var(--sqe-color-primary) 0%, var(--sqe-color-accent) 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--sqe-color-white);
    font-weight: 600;
    font-size: 14px;
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform var(--sqe-transition-cubic);
  }

  #sqe-process-section-{{ section.id }} .sqe-detail-panel.active .sqe-detail-image img {
    transform: scale(1.05);
  }

  /* ===== MOBILE TIMELINE (768px & below) ===== */
  @media (max-width: 768px) {
    #sqe-process-section-{{ section.id }} .sqe-process-section {
      padding: 40px 16px;
    }

    #sqe-process-section-{{ section.id }} .sqe-process-header h2 {
      font-size: 28px;
    }

    #sqe-process-section-{{ section.id }} .sqe-process-header p {
      font-size: 15px;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-track {
      flex-direction: column;
      padding: 0;
      align-items: stretch;
      margin-bottom: 0;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-track::before {
      position: absolute;
      top: 0;
      left: 29px;
      right: auto;
      width: 3px;
      height: 100%;
      background: var(--sqe-color-border);
      transition: all var(--sqe-transition);
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-track.animated::before {
      background: linear-gradient(
        to bottom,
        var(--sqe-color-primary) 0%,
        var(--sqe-color-primary) var(--progress),
        var(--sqe-color-border) var(--progress),
        var(--sqe-color-border) 100%
      );
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-step {
      flex: none;
      padding: 0 0 20px 90px;
      text-align: left;
      position: relative;
      margin-bottom: 36px;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-dot {
      position: absolute;
      left: 0;
      top: 0;
      width: 60px;
      height: 60px;
      margin: 0;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-track::before {
      left: 30px;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-panel {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 25px;
      height: auto;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-image {
      min-height: 200px;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-panel-wrapper {
      height: auto;
      margin-top: 30px;
    }
  }

  /* ===== MOBILE TIMELINE (480px & below) ===== */
  @media (max-width: 480px) {
    #sqe-process-section-{{ section.id }} .sqe-process-section {
      padding: 30px 12px;
    }

    #sqe-process-section-{{ section.id }} .sqe-process-header {
      margin-bottom: 40px;
    }

    #sqe-process-section-{{ section.id }} .sqe-process-header h2 {
      font-size: 24px;
      margin-bottom: 10px;
    }

    #sqe-process-section-{{ section.id }} .sqe-process-header p {
      font-size: 14px;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-wrapper {
      padding: 30px 0;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-step {
      padding: 0 0 16px 76px;
      margin-bottom: 28px;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-dot {
      width: 50px;
      height: 50px;
      font-size: 16px;
      left: 0;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-track::before {
      left: 25px;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-step.active .sqe-timeline-dot {
      width: 58px;
      height: 58px;
      left: -4px;
    }

    #sqe-process-section-{{ section.id }} .sqe-timeline-label {
      font-size: 13px;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-panel {
      padding: 20px;
      gap: 15px;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-content h3 {
      font-size: 24px;
      margin-bottom: 12px;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-content p {
      font-size: 14px;
    }

    #sqe-process-section-{{ section.id }} .sqe-detail-image {
      min-height: 150px;
    }
  }
</style>

<script>
  (function() {
    'use strict';

    class SQEInteractiveProcess {
      constructor(container) {
        this.container = container;
        this.sectionId = container.querySelector('[id^="sqe-process-section-"]')?.id;

        if (!this.sectionId) {
          console.warn('SQEInteractiveProcess: Could not find section ID');
          return;
        }

        this.steps = container.querySelectorAll('.sqe-timeline-step');
        this.panels = container.querySelectorAll('.sqe-detail-panel');
        this.track = container.querySelector('.sqe-timeline-track');
        this.activeIndex = 0;

        if (this.steps.length === 0) {
          console.warn('SQEInteractiveProcess: No timeline steps found');
          return;
        }

        this.init();
      }

      init() {
        // Bind step click handlers
        this.steps.forEach((step, index) => {
          step.addEventListener('click', () => this.selectStep(index));
        });

        // Set up scroll animation if enabled
        if (this.track && this.track.classList.contains('animated')) {
          window.addEventListener('scroll', () => this.updateProgress());
        }

        // Initialize with first step
        this.selectStep(0);
      }

      selectStep(index) {
        if (index < 0 || index >= this.steps.length) {
          return;
        }

        this.activeIndex = index;

        // Update step states (active/completed)
        this.steps.forEach((step, i) => {
          if (i < index) {
            step.classList.remove('active');
            step.classList.add('completed');
          } else if (i === index) {
            step.classList.add('active');
            step.classList.remove('completed');
          } else {
            step.classList.remove('active', 'completed');
          }
        });

        // Show/hide detail panels
        this.panels.forEach((panel, i) => {
          panel.classList.toggle('active', i === index);
        });
      }

      updateProgress() {
        if (!this.track) return;

        const trackRect = this.track.getBoundingClientRect();
        const windowHeight = window.innerHeight;
        const trackStart = trackRect.top;
        const trackEnd = trackRect.bottom;

        // Exit early if track is completely off-screen
        if (trackEnd < 0 || trackStart > windowHeight) {
          return;
        }

        const visibleHeight = Math.min(trackEnd, windowHeight) - Math.max(trackStart, 0);
        const progress = Math.max(0, visibleHeight / (windowHeight + trackRect.height)) * 100;

        this.track.style.setProperty('--progress', Math.min(100, progress * 2) + '%');
      }
    }

    // Initialize only the current section instance
    function initializeSQEProcess() {
      const wrapper = document.querySelector('.sqe-process-wrapper');
      if (wrapper) {
        new SQEInteractiveProcess(wrapper);
      }
    }

    // Run when DOM is ready
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', initializeSQEProcess);
    } else {
      initializeSQEProcess();
    }
  })();
</script>

<div class="sqe-process-wrapper">
  <div class="sqe-process-section" id="sqe-process-section-{{ section.id }}">
    <div class="sqe-process-container">
      <div class="sqe-process-header">
        {%- if show_label and label_text != blank -%}
          <span class="sqe-section-label">{{ label_text }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subheading }}</p>
      </div>

      <div class="sqe-timeline-wrapper">
        <div class="sqe-timeline-track {% if section.settings.animate_progress %}animated{% endif %}">
          {% for block in section.blocks %}
            <div class="sqe-timeline-step" {{ block.shopify_attributes }}>
              <div class="sqe-timeline-dot">{{ forloop.index }}</div>
              <div class="sqe-timeline-label">{{ block.settings.step_name }}</div>
            </div>
          {% endfor %}
        </div>

        <div class="sqe-detail-panel-wrapper">
          {% for block in section.blocks %}
            <div class="sqe-detail-panel" {{ block.shopify_attributes }}>
              <div class="sqe-detail-content">
                <h3>{% if block.settings.step_name != blank %}{{ block.settings.step_name }}{% else %}Step {{ forloop.index }}{% endif %}</h3>
                <p>{% if block.settings.step_description != blank %}{{ block.settings.step_description }}{% else %}No description provided.{% endif %}</p>
              </div>
              {% if block.settings.step_image %}
                <div class="sqe-detail-image">
                  {{ block.settings.step_image | image_url: width: 600 | image_tag: alt: block.settings.step_name }}
                </div>
              {% else %}
                <div class="sqe-detail-image">
                  No image
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "SQE Proc-Step",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Process"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "See how we work with clients step by step"
    },
    {
      "type": "checkbox",
      "id": "animate_progress",
      "label": "Animate progress line on scroll",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 32,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 42
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Description Typography"
    },
    {
      "type": "select",
      "id": "description_font",
      "label": "Description font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "step_title_color",
      "label": "Step Title Color",
      "default": "#1F3A5F"
    },
    {
      "type": "color",
      "id": "step_description_color",
      "label": "Step Description Color",
      "default": "#666666"
    },
    {
      "type": "color",
      "id": "timeline_label_color",
      "label": "Timeline Label Color",
      "default": "#999999"
    },
    {
      "type": "color",
      "id": "active_dot_color",
      "label": "Active Dot Color",
      "default": "#F2B705"
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#eef2f7"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Padding Top",
      "min": 0,
      "max": 100,
      "step": 5,
      "default": 60,
      "unit": "px"
    }
  ],
  "blocks": [
    {
      "type": "process_step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "step_name",
          "label": "Step Name",
          "default": "Initial Consultation"
        },
