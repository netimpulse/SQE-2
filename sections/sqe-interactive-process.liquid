{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
  assign d_font = section.settings.description_font
  assign d_size = section.settings.description_size
  assign d_color = section.settings.description_color
-%}

<style>
  /* ===== SECTION LABEL (orange pill) ===== */
  #sqe-process-section-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px; font-weight: 700; letter-spacing: 2px; text-transform: uppercase;
    color: #C75B12; background: rgba(199,91,18,.1);
    padding: 4px 14px; border-radius: 20px; margin-bottom: 12px;
  }

  .sqe-process-section {
    padding: 60px 20px;
    background: linear-gradient(135deg, #f8fafb 0%, #eef2f7 100%);
    font-family: 'Inter', sans-serif;
  }

  .sqe-process-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sqe-process-header {
    text-align: center;
    margin-bottom: 60px;
  }

  .sqe-process-header h2 {
    font-family: {{ h_font }};
    font-size: {{ h_size }}px;
    font-weight: {{ h_weight }};
    color: {{ h_color }};
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .sqe-process-header p {
    font-family: {{ d_font }};
    font-size: {{ d_size }}px;
    color: {{ d_color }};
    margin: 0;
    font-weight: 400;
    line-height: 1.6;
  }

  /* Desktop Timeline */
  .sqe-timeline-wrapper {
    position: relative;
    padding: 40px 0;
  }

  .sqe-timeline-track {
    position: relative;
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 50px;
    padding: 0 40px;
  }

  .sqe-timeline-track::before {
    content: '';
    position: absolute;
    top: 30px;
    left: 40px;
    right: 40px;
    height: 3px;
    background: #E8ECEF;
    z-index: 0;
  }

  .sqe-timeline-track.animated::before {
    background: linear-gradient(to right, #1F3A5F 0%, #1F3A5F var(--progress), #E8ECEF var(--progress), #E8ECEF 100%);
    transition: background 0.3s ease;
  }

  .sqe-timeline-step {
    position: relative;
    flex: 1;
    text-align: center;
    cursor: pointer;
    z-index: 2;
    transition: all 0.3s ease;
    padding: 0 15px;
  }

  .sqe-timeline-step:hover {
    transform: translateY(-8px);
  }

  .sqe-timeline-dot {
    width: 60px;
    height: 60px;
    margin: 0 auto 20px auto;
    border-radius: 50%;
    background: white;
    border: 3px solid #E8ECEF;
    display: flex;
    align-items: center;
    justify-content: center;
    font-weight: bold;
    font-size: 18px;
    color: #999;
    position: relative;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 4px 15px rgba(31, 58, 95, 0.08);
  }

  .sqe-timeline-step.active .sqe-timeline-dot {
    width: 72px;
    height: 72px;
    background: #F2B705;
    border-color: #F2B705;
    color: #1F3A5F;
    box-shadow: 0 8px 25px rgba(242, 183, 5, 0.3);
    animation: pulse-dot 2s infinite;
  }

  @keyframes pulse-dot {
    0% {
      box-shadow: 0 8px 25px rgba(242, 183, 5, 0.3);
    }
    50% {
      box-shadow: 0 8px 35px rgba(242, 183, 5, 0.5);
    }
    100% {
      box-shadow: 0 8px 25px rgba(242, 183, 5, 0.3);
    }
  }

  .sqe-timeline-dot.completed {
    background: #1F3A5F;
    border-color: #1F3A5F;
    color: white;
  }

  .sqe-timeline-label {
    font-size: 14px;
    color: #999;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    line-height: 1.4;
  }

  .sqe-timeline-step.active .sqe-timeline-label {
    color: #1F3A5F;
    font-weight: 600;
  }

  /* Detail Panel */
  .sqe-detail-panel-wrapper {
    position: relative;
    height: 400px;
    margin-top: 50px;
    border-radius: 16px;
    overflow: hidden;
  }

  .sqe-detail-panel {
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    border-radius: 16px;
    padding: 40px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 40px;
    align-items: center;
    opacity: 0;
    transform: translateX(60px);
    pointer-events: none;
    transition: all 0.5s cubic-bezier(0.34, 1.56, 0.64, 1);
    box-shadow: 0 20px 60px rgba(31, 58, 95, 0.12);
    border: 1px solid rgba(242, 183, 5, 0.1);
  }

  .sqe-detail-panel.active {
    opacity: 1;
    transform: translateX(0);
    pointer-events: auto;
  }

  .sqe-detail-content h3 {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 28px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0 0 16px 0;
  }

  .sqe-detail-content p {
    font-size: 15px;
    color: #666;
    line-height: 1.6;
    margin: 0;
  }

  .sqe-detail-image {
    position: relative;
    height: 100%;
    min-height: 300px;
    border-radius: 12px;
    overflow: hidden;
    background: linear-gradient(135deg, #1F3A5F 0%, #F2B705 100%);
  }

  .sqe-detail-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }

  .sqe-detail-panel.active .sqe-detail-image img {
    transform: scale(1.05);
  }

  /* Mobile Timeline */
  @media (max-width: 768px) {
    .sqe-process-section {
      padding: 40px 16px;
    }

    .sqe-process-header h2 {
      font-size: 28px;
    }

    .sqe-process-header p {
      font-size: 15px;
    }

    .sqe-timeline-track {
      flex-direction: column;
      padding: 0;
      align-items: stretch;
      margin-bottom: 0;
    }

    .sqe-timeline-track::before {
      position: absolute;
      top: 0;
      left: 29px;
      right: auto;
      width: 3px;
      height: 100%;
      background: #E8ECEF;
      transition: all 0.3s ease;
    }

    .sqe-timeline-track.animated::before {
      background: linear-gradient(to bottom, #1F3A5F 0%, #1F3A5F var(--progress), #E8ECEF var(--progress), #E8ECEF 100%);
    }

    .sqe-timeline-step {
      flex: none;
      padding: 0 0 40px 80px;
      text-align: left;
      position: relative;
      margin-bottom: 20px;
    }

    .sqe-timeline-dot {
      position: absolute;
      left: -15px;
      top: 0;
      width: 60px;
      height: 60px;
      margin: 0;
    }

    .sqe-detail-panel {
      grid-template-columns: 1fr;
      gap: 20px;
      padding: 25px;
      height: auto;
    }

    .sqe-detail-image {
      min-height: 200px;
    }

    .sqe-detail-panel-wrapper {
      height: auto;
      margin-top: 30px;
    }
  }

  @media (max-width: 480px) {
    .sqe-process-section {
      padding: 30px 12px;
    }

    .sqe-process-header {
      margin-bottom: 40px;
    }

    .sqe-process-header h2 {
      font-size: 24px;
      margin-bottom: 10px;
    }

    .sqe-process-header p {
      font-size: 14px;
    }

    .sqe-timeline-wrapper {
      padding: 30px 0;
    }

    .sqe-timeline-step {
      padding: 0 0 30px 70px;
      margin-bottom: 0;
    }

    .sqe-timeline-dot {
      width: 50px;
      height: 50px;
      font-size: 16px;
    }

    .sqe-timeline-step.active .sqe-timeline-dot {
      width: 60px;
      height: 60px;
    }

    .sqe-timeline-label {
      font-size: 13px;
    }

    .sqe-detail-panel {
      padding: 20px;
      gap: 15px;
    }

    .sqe-detail-content h3 {
      font-size: 24px;
      margin-bottom: 12px;
    }

    .sqe-detail-content p {
      font-size: 14px;
    }

    .sqe-detail-image {
      min-height: 150px;
    }
  }
</style>

<script>
  class SQEInteractiveProcess {
    constructor(container) {
      this.container = container;
      this.steps = container.querySelectorAll('.sqe-timeline-step');
      this.panels = container.querySelectorAll('.sqe-detail-panel');
      this.track = container.querySelector('.sqe-timeline-track');
      this.activeIndex = 0;

      this.init();
    }

    init() {
      this.steps.forEach((step, index) => {
        step.addEventListener('click', () => this.selectStep(index));
      });

      if (this.track.classList.contains('animated')) {
        window.addEventListener('scroll', () => this.updateProgress());
      }

      this.selectStep(0);
    }

    selectStep(index) {
      this.activeIndex = index;

      this.steps.forEach((step, i) => {
        if (i < index) {
          step.classList.remove('active');
          step.classList.add('completed');
        } else if (i === index) {
          step.classList.add('active');
          step.classList.remove('completed');
        } else {
          step.classList.remove('active', 'completed');
        }
      });

      this.panels.forEach((panel, i) => {
        panel.classList.toggle('active', i === index);
      });
    }

    updateProgress() {
      const trackRect = this.track.getBoundingClientRect();
      const windowHeight = window.innerHeight;
      const trackStart = trackRect.top;
      const trackEnd = trackRect.bottom;

      if (trackEnd < 0 || trackStart > windowHeight) {
        return;
      }

      const visibleHeight = Math.min(trackEnd, windowHeight) - Math.max(trackStart, 0);
      const progress = Math.max(0, visibleHeight / (windowHeight + trackRect.height)) * 100;

      this.track.style.setProperty('--progress', Math.min(100, progress * 2) + '%');
    }
  }

  document.querySelectorAll('.sqe-process-wrapper').forEach(wrapper => {
    new SQEInteractiveProcess(wrapper);
  });
</script>

<div class="sqe-process-wrapper">
  <div class="sqe-process-section" id="sqe-process-section-{{ section.id }}">
    <div class="sqe-process-container">
      <div class="sqe-process-header">
        {%- if show_label and label_text != blank -%}
          <span class="sqe-section-label">{{ label_text }}</span>
        {%- endif -%}
        <h2>{{ section.settings.heading }}</h2>
        <p>{{ section.settings.subheading }}</p>
      </div>

      <div class="sqe-timeline-wrapper">
        <div class="sqe-timeline-track {% if section.settings.animate_progress %}animated{% endif %}">
          {% for block in section.blocks %}
            <div class="sqe-timeline-step" {{ block.shopify_attributes }}>
              <div class="sqe-timeline-dot">{{ forloop.index }}</div>
              <div class="sqe-timeline-label">{{ block.settings.step_name }}</div>
            </div>
          {% endfor %}
        </div>

        <div class="sqe-detail-panel-wrapper">
          {% for block in section.blocks %}
            <div class="sqe-detail-panel" {{ block.shopify_attributes }}>
              <div class="sqe-detail-content">
                <h3>{{ block.settings.step_name }}</h3>
                <p>{{ block.settings.step_description }}</p>
              </div>
              {% if block.settings.step_image %}
                <div class="sqe-detail-image">
                  {{ block.settings.step_image | image_url: width: 600 | image_tag }}
                </div>
              {% else %}
                <div class="sqe-detail-image" style="display: flex; align-items: center; justify-content: center; color: white; font-weight: 600;">
                  Image placeholder
                </div>
              {% endif %}
            </div>
          {% endfor %}
        </div>
      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "SQE Proc-Step",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "Process"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Process"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "See how we work with clients step by step"
    },
    {
      "type": "checkbox",
      "id": "animate_progress",
      "label": "Animate progress line on scroll",
      "default": true
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 32,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 42
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Description Typography"
    },
    {
      "type": "select",
      "id": "description_font",
      "label": "Description font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Description size",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Description color",
      "default": "#666666"
    }
  ],
  "blocks": [
    {
      "type": "process_step",
      "name": "Process Step",
      "settings": [
        {
          "type": "text",
          "id": "step_name",
          "label": "Step Name",
          "default": "Initial Consultation"
        },
        {
          "type": "textarea",
          "id": "step_description",
          "label": "Step Description",
          "default": "We understand your specific needs, goals, and current solar setup to create a tailored strategy."
        },
        {
          "type": "image_picker",
          "id": "step_image",
          "label": "Step Image"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Interactive Process",
      "blocks": [
        {
          "type": "process_step",
          "settings": {
            "step_name": "Initial Consultation",
            "step_description": "We understand your specific needs, goals, and current solar setup to create a tailored strategy."
          }
        },
        {
          "type": "process_step",
          "settings": {
            "step_name": "Site Assessment",
            "step_description": "Our expert team conducts a comprehensive on-site evaluation, analyzing roof orientation, shading, and structural integrity."
          }
        },
        {
          "type": "process_step",
          "settings": {
            "step_name": "Technical Analysis",
            "step_description": "We perform detailed modeling using thermal imaging and advanced analytics to identify all potential issues."
          }
        },
        {
          "type": "process_step",
          "settings": {
            "step_name": "Report Delivery",
            "step_description": "You receive a detailed, easy-to-understand report with findings, recommendations, and actionable next steps."
          }
        },
        {
          "type": "process_step",
          "settings": {
            "step_name": "Implementation Support",
            "step_description": "We guide you through implementation, connecting you with trusted partners and ensuring optimal performance."
          }
        }
      ]
    }
  ]
}
{% endschema %}
