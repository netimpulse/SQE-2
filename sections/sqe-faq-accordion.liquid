{% comment %}
  SQE Premium FAQ Accordion Section
  Features: Animated accordion, category filtering, live search, smooth transitions
{% endcomment %}

<div class="sqe-faq-container">
  <div class="sqe-faq-header">
    <h2 class="sqe-faq-title">{{ section.settings.title }}</h2>
    {% if section.settings.subtitle %}
      <p class="sqe-faq-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <!-- Filter Tabs -->
    <div class="sqe-faq-controls">
      <div class="sqe-faq-filters">
        <button class="sqe-filter-btn active" data-filter="all">All Questions</button>
        {% assign categories = '' %}
        {% for block in section.blocks %}
          {% assign category = block.settings.category %}
          {% unless categories contains category %}
            {% assign categories = categories | append: ',' | append: category %}
            <button class="sqe-filter-btn" data-filter="{{ category | downcase | replace: ' ', '-' }}">
              {{ category }}
            </button>
          {% endunless %}
        {% endfor %}
      </div>

      <!-- Search Input -->
      <div class="sqe-faq-search-wrapper">
        <input
          type="text"
          class="sqe-faq-search-input"
          placeholder="Search questions..."
          aria-label="Search FAQ questions"
        >
        <svg class="sqe-search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none">
          <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"/>
          <path d="M14 14l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <!-- Question Counter -->
    <div class="sqe-faq-counter">
      <span class="sqe-counter-text">Showing <strong class="sqe-counter-visible">{{ section.blocks.size }}</strong> of <strong class="sqe-counter-total">{{ section.blocks.size }}</strong> questions</span>
    </div>

    <!-- Accordion Items -->
    <div class="sqe-accordion" role="region" aria-label="FAQ Accordion">
      {% for block in section.blocks %}
        <div
          class="sqe-accordion-item"
          data-category="{{ block.settings.category | downcase | replace: ' ', '-' }}"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          <button
            class="sqe-accordion-header"
            aria-expanded="false"
            aria-controls="panel-{{ forloop.index0 }}"
          >
            <span class="sqe-accordion-title">{{ block.settings.question }}</span>
            <div class="sqe-accordion-icon">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </div>
          </button>

          <div
            class="sqe-accordion-panel"
            id="panel-{{ forloop.index0 }}"
            role="region"
            aria-labelledby="button-{{ forloop.index0 }}"
            hidden
          >
            <div class="sqe-accordion-content">
              <div class="sqe-accordion-left-border"></div>
              <div class="sqe-accordion-text">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  {% else %}
    <div class="sqe-faq-placeholder">
      <p>Add FAQ items to display accordion</p>
    </div>
  {% endif %}
</div>

<style>
  .sqe-faq-container {
    max-width: {{ section.settings.max_width }}px;
    margin: {{ section.settings.margin_top }}px auto {{ section.settings.margin_bottom }}px;
    padding: {{ section.settings.padding_horizontal }}px {{ section.settings.padding_horizontal }}px;
  }

  .sqe-faq-header {
    text-align: {{ section.settings.text_alignment }};
    margin-bottom: 40px;
  }

  .sqe-faq-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: {{ section.settings.title_size }}px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  .sqe-faq-subtitle {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666;
    margin: 0;
    line-height: 1.6;
  }

  .sqe-faq-controls {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 30px;
    padding: 24px;
    background: #F2F4F7;
    border-radius: 12px;
  }

  .sqe-faq-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  .sqe-filter-btn {
    padding: 10px 20px;
    border: 2px solid transparent;
    background: white;
    color: #333333;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    border-radius: 20px;
    cursor: pointer;
    transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
    position: relative;
    overflow: hidden;
  }

  .sqe-filter-btn:hover {
    border-color: #F2B705;
    transform: translateY(-2px);
  }

  .sqe-filter-btn.active {
    background: #1F3A5F;
    color: white;
    border-color: #1F3A5F;
  }

  .sqe-faq-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  .sqe-faq-search-input {
    width: 100%;
    padding: 12px 16px 12px 40px;
    border: 2px solid #ddd;
    background: white;
    border-radius: 8px;
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    transition: all 0.3s ease;
  }

  .sqe-faq-search-input:focus {
    outline: none;
    border-color: #1F3A5F;
    box-shadow: 0 0 0 3px rgba(31, 58, 95, 0.1);
  }

  .sqe-search-icon {
    position: absolute;
    left: 12px;
    color: #999;
    pointer-events: none;
  }

  .sqe-faq-counter {
    text-align: center;
    margin-bottom: 20px;
  }

  .sqe-counter-text {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: #666;
  }

  .sqe-counter-visible,
  .sqe-counter-total {
    color: #1F3A5F;
    font-weight: 600;
  }

  .sqe-accordion {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .sqe-accordion-item {
    border-radius: 8px;
    background: white;
    border: 1px solid #e0e0e0;
    overflow: hidden;
    transition: all 0.3s ease;
  }

  .sqe-accordion-item:hover {
    border-color: #F2B705;
    box-shadow: 0 4px 12px rgba(31, 58, 95, 0.08);
  }

  .sqe-accordion-item.active {
    border-color: #1F3A5F;
  }

  .sqe-accordion-header {
    width: 100%;
    padding: 20px 24px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: #1F3A5F;
    transition: all 0.3s ease;
    text-align: left;
  }

  .sqe-accordion-item.active .sqe-accordion-header {
    background: linear-gradient(135deg, rgba(31, 58, 95, 0.02) 0%, rgba(242, 183, 5, 0.02) 100%);
  }

  .sqe-accordion-title {
    flex: 1;
    line-height: 1.4;
  }

  .sqe-accordion-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .sqe-accordion-item.active .sqe-accordion-icon {
    transform: rotate(180deg);
  }

  .sqe-accordion-icon svg {
    color: #F2B705;
  }

  .sqe-accordion-panel {
    overflow: hidden;
    transition: max-height 0.4s cubic-bezier(0.34, 1.56, 0.64, 1),
                opacity 0.3s ease;
    max-height: 0;
    opacity: 0;
  }

  .sqe-accordion-panel:not([hidden]) {
    max-height: 800px;
    opacity: 1;
  }

  .sqe-accordion-content {
    padding: 0 24px 24px 24px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  .sqe-accordion-left-border {
    width: 4px;
    background: linear-gradient(180deg, #F2B705 0%, #C75B12 100%);
    border-radius: 2px;
    flex-shrink: 0;
    min-height: 20px;
  }

  .sqe-accordion-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: #666;
    line-height: 1.8;
    flex: 1;
  }

  .sqe-accordion-text p {
    margin: 0 0 12px 0;
  }

  .sqe-accordion-text p:last-child {
    margin-bottom: 0;
  }

  .sqe-faq-placeholder {
    text-align: center;
    padding: 60px 20px;
    color: #999;
    font-family: 'Inter', sans-serif;
  }

  .sqe-accordion-item.hidden {
    display: none;
  }

  /* Responsive */
  @media (max-width: 640px) {
    .sqe-faq-container {
      padding: 16px;
    }

    .sqe-faq-title {
      font-size: 24px;
    }

    .sqe-faq-controls {
      flex-direction: column;
      padding: 16px;
    }

    .sqe-faq-filters {
      gap: 8px;
    }

    .sqe-filter-btn {
      padding: 8px 14px;
      font-size: 12px;
    }

    .sqe-accordion-header {
      padding: 16px;
      font-size: 14px;
    }

    .sqe-accordion-content {
      padding: 0 16px 16px 16px;
      gap: 12px;
    }

    .sqe-accordion-left-border {
      width: 3px;
    }

    .sqe-accordion-text {
      font-size: 13px;
    }
  }
</style>

<script>
(function() {
  const container = document.querySelector('.sqe-faq-container');
  if (!container) return;

  const accordion = container.querySelector('.sqe-accordion');
  const items = container.querySelectorAll('.sqe-accordion-item');
  const filterBtns = container.querySelectorAll('.sqe-filter-btn');
  const searchInput = container.querySelector('.sqe-faq-search-input');
  const counterVisible = container.querySelector('.sqe-counter-visible');
  const counterTotal = container.querySelector('.sqe-counter-total');

  let currentFilter = 'all';
  let currentSearch = '';

  // Accordion Toggle
  items.forEach((item, index) => {
    const header = item.querySelector('.sqe-accordion-header');
    const panel = item.querySelector('.sqe-accordion-panel');

    header.addEventListener('click', () => {
      const isActive = item.classList.contains('active');

      if (isActive) {
        item.classList.remove('active');
        header.setAttribute('aria-expanded', 'false');
        panel.setAttribute('hidden', '');
      } else {
        item.classList.add('active');
        header.setAttribute('aria-expanded', 'true');
        panel.removeAttribute('hidden');
      }
    });
  });

  // Filter Function
  function applyFilters() {
    let visibleCount = 0;

    items.forEach(item => {
      const category = item.getAttribute('data-category');
      const question = item.querySelector('.sqe-accordion-title').textContent.toLowerCase();

      const matchesCategory = currentFilter === 'all' || category === currentFilter;
      const matchesSearch = question.includes(currentSearch.toLowerCase());
      const shouldShow = matchesCategory && matchesSearch;

      if (shouldShow) {
        item.classList.remove('hidden');
        visibleCount++;
      } else {
        item.classList.add('hidden');
        item.classList.remove('active');
        item.querySelector('.sqe-accordion-panel').setAttribute('hidden', '');
        item.querySelector('.sqe-accordion-header').setAttribute('aria-expanded', 'false');
      }
    });

    counterVisible.textContent = visibleCount;
  }

  // Filter Button Clicks
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter');
      applyFilters();
    });
  });

  // Search Input
  searchInput?.addEventListener('input', (e) => {
    currentSearch = e.target.value;
    applyFilters();
  });

  // Keyboard Navigation
  items.forEach((item, index) => {
    const header = item.querySelector('.sqe-accordion-header');

    header.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowDown') {
        e.preventDefault();
        const nextHeader = items[index + 1]?.querySelector('.sqe-accordion-header');
        nextHeader?.focus();
      } else if (e.key === 'ArrowUp') {
        e.preventDefault();
        const prevHeader = items[index - 1]?.querySelector('.sqe-accordion-header');
        prevHeader?.focus();
      } else if (e.key === 'Home') {
        e.preventDefault();
        items[0].querySelector('.sqe-accordion-header').focus();
      } else if (e.key === 'End') {
        e.preventDefault();
        items[items.length - 1].querySelector('.sqe-accordion-header').focus();
      }
    });
  });
})();
</script>

{% schema %}
{
  "name": "SQE FAQ Accordion",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Find answers to common questions about our solar inspection services"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size (px)",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1000
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Horizontal Padding (px)",
      "min": 0,
      "max": 60,
      "step": 10,
      "unit": "px",
      "default": 20
    },
    {
      "type": "range",
      "id": "margin_top",
      "label": "Top Margin (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    },
    {
      "type": "range",
      "id": "margin_bottom",
      "label": "Bottom Margin (px)",
      "min": 0,
      "max": 100,
      "step": 10,
      "unit": "px",
      "default": 40
    }
  ],
  "blocks": [
    {
      "type": "faq_item",
      "name": "FAQ Item",
      "settings": [
        {
          "type": "text",
          "id": "question",
          "label": "Question",
          "default": "How does solar panel inspection work?"
        },
        {
          "type": "richtext",
          "id": "answer",
          "label": "Answer",
          "default": "<p>Our expert team uses advanced thermal imaging and electrical testing to identify defects, performance issues, and safety concerns in solar installations.</p>"
        },
        {
          "type": "select",
          "id": "category",
          "label": "Category",
          "options": [
            { "value": "General", "label": "General" },
            { "value": "Technical", "label": "Technical" },
            { "value": "Commercial", "label": "Commercial" },
            { "value": "Process", "label": "Process" }
          ],
          "default": "General"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE FAQ Accordion",
      "blocks": [
        {
          "type": "faq_item",
          "settings": {
            "question": "How does solar panel inspection work?",
            "answer": "<p>Our expert team uses advanced thermal imaging and electrical testing to identify defects, performance issues, and safety concerns in solar installations.</p>",
            "category": "General"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "What is thermal imaging used for?",
            "answer": "<p>Thermal imaging detects temperature variations across panels, revealing hot spots that indicate faulty cells, poor connections, or degradation.</p>",
            "category": "Technical"
          }
        },
        {
          "type": "faq_item",
          "settings": {
            "question": "How long does an inspection take?",
            "answer": "<p>A typical residential inspection takes 2-4 hours depending on system size and accessibility. Commercial systems may require a full day.</p>",
            "category": "Process"
          }
        }
      ]
    }
  ]
}
{% endschema %}