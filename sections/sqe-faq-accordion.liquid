{% comment %}
  SQE Premium FAQ Accordion Section
  Features: Animated accordion, category filtering, live search, smooth transitions
{% endcomment %}

{%- liquid
  assign show_label = section.settings.show_section_label
  assign label_text = section.settings.section_label_text
  assign h_font = section.settings.heading_font
  assign h_size = section.settings.heading_size
  assign h_color = section.settings.heading_color
  assign h_bold = section.settings.heading_bold
  assign h_weight = '700'
  if h_bold == false
    assign h_weight = '400'
  endif
-%}

<div
  id="sqe-faq-{{ section.id }}"
  class="sqe-faq-container"
  style="--h-font: {{ h_font }}; --h-size: {{ h_size }}px; --h-color: {{ h_color }}; --h-weight: {{ h_weight }}; --max-width: {{ section.settings.max_width }}px; --margin-top: {{ section.settings.margin_top }}px; --margin-bottom: {{ section.settings.margin_bottom }}px; --padding-horizontal: {{ section.settings.padding_horizontal }}px; --text-alignment: {{ section.settings.text_alignment }}; --title-size: {{ section.settings.title_size }}px; --description-font: {{ section.settings.description_font | default: "'Inter', sans-serif" }}; --description-size: {{ section.settings.description_size | default: 16 }}px; --description-color: {{ section.settings.description_color | default: '#666' }};"
>
  <div class="sqe-faq-header">
    {%- if show_label and label_text != blank -%}
      <span class="sqe-section-label">{{ label_text }}</span>
    {%- endif -%}
    <h2 class="sqe-faq-title">{{ section.settings.title }}</h2>
    {% if section.settings.subtitle %}
      <p class="sqe-faq-subtitle">{{ section.settings.subtitle }}</p>
    {% endif %}
  </div>

  {% if section.blocks.size > 0 %}
    <div class="sqe-faq-controls">
      <div class="sqe-faq-filters">
        <button class="sqe-filter-btn active" data-filter="all" aria-label="Show all questions">All Questions</button>
        {% assign categories = '' %}
        {% for block in section.blocks %}
          {% assign category = block.settings.category %}
          {% unless categories contains category %}
            {% assign categories = categories | append: ',' | append: category %}
            <button class="sqe-filter-btn" data-filter="{{ category | downcase | replace: ' ', '-' }}" aria-label="Filter by {{ category }}">
              {{ category }}
            </button>
          {% endunless %}
        {% endfor %}
      </div>

      <div class="sqe-faq-search-wrapper">
        <input
          type="text"
          class="sqe-faq-search-input"
          placeholder="Search questions..."
          aria-label="Search FAQ questions"
        >
        <svg class="sqe-search-icon" width="20" height="20" viewBox="0 0 20 20" fill="none" aria-hidden="true">
          <circle cx="8" cy="8" r="6" stroke="currentColor" stroke-width="2"/>
          <path d="M14 14l4 4" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
        </svg>
      </div>
    </div>

    <div class="sqe-faq-counter">
      <span class="sqe-counter-text">Showing <strong class="sqe-counter-visible">{{ section.blocks.size }}</strong> of <strong class="sqe-counter-total">{{ section.blocks.size }}</strong> questions</span>
    </div>

    <div class="sqe-accordion" role="region" aria-label="FAQ Accordion">
      {% for block in section.blocks %}
        <div
          class="sqe-accordion-item"
          data-category="{{ block.settings.category | downcase | replace: ' ', '-' }}"
          data-index="{{ forloop.index0 }}"
          {{ block.shopify_attributes }}
        >
          <button
            class="sqe-accordion-header"
            aria-expanded="false"
            aria-controls="panel-{{ forloop.index0 }}"
            id="button-{{ forloop.index0 }}"
          >
            <span class="sqe-accordion-title">{{ block.settings.question }}</span>
            <div class="sqe-accordion-icon" aria-hidden="true">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <line x1="12" y1="5" x2="12" y2="19"></line>
                <line x1="5" y1="12" x2="19" y2="12"></line>
              </svg>
            </div>
          </button>

          <div
            class="sqe-accordion-panel"
            id="panel-{{ forloop.index0 }}"
            role="region"
            aria-labelledby="button-{{ forloop.index0 }}"
            hidden
          >
            <div class="sqe-accordion-content">
              <div class="sqe-accordion-left-border" aria-hidden="true"></div>
              <div class="sqe-accordion-text">
                {{ block.settings.answer }}
              </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

  {% else %}
    <div class="sqe-faq-placeholder">
      <p>Add FAQ items to your accordion to get started.</p>
    </div>
  {% endif %}
</div>

<style>
  #sqe-faq-{{ section.id }} {
    --color-primary: #1F3A5F;
    --color-accent: #F2B705;
    --color-accent-dark: #C75B12;
    --color-border: #e0e0e0;
    --color-bg-light: #F2F4F7;
    --color-text: #333;
    --color-text-muted: #666;
    --color-text-light: #999;
    --duration-fast: 0.3s;
    --duration-normal: 0.4s;
    --easing-spring: cubic-bezier(0.34, 1.56, 0.64, 1);
    --border-radius: 8px;
    --border-radius-pill: 20px;
  }

  #sqe-faq-{{ section.id }} .sqe-section-label {
    display: inline-block;
    font-size: 11px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--color-accent-dark);
    background: rgba(199, 91, 18, 0.1);
    padding: 4px 14px;
    border-radius: var(--border-radius-pill);
    margin-bottom: 12px;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-container {
    max-width: var(--max-width);
    margin: var(--margin-top) auto var(--margin-bottom);
    padding: {{ section.settings.padding_top }}px var(--padding-horizontal) var(--padding-horizontal) var(--padding-horizontal);
    background-color: {{ section.settings.background_color }};
  }

  #sqe-faq-{{ section.id }} .sqe-faq-header {
    text-align: var(--text-alignment);
    margin-bottom: 40px;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-title {
    font-family: var(--h-font);
    font-size: var(--h-size);
    font-weight: var(--h-weight);
    color: var(--h-color);
    margin: 0 0 12px 0;
    letter-spacing: -0.5px;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-subtitle {
    font-family: var(--description-font);
    font-size: var(--description-size);
    color: var(--description-color);
    margin: 0;
    line-height: 1.6;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-controls {
    display: flex;
    flex-direction: column;
    gap: 20px;
    margin-bottom: 30px;
    padding: 24px;
    background: var(--color-bg-light);
    border-radius: var(--border-radius);
  }

  #sqe-faq-{{ section.id }} .sqe-faq-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 10px;
  }

  #sqe-faq-{{ section.id }} .sqe-filter-btn {
    padding: 10px 20px;
    border: 2px solid transparent;
    background: white;
    color: var(--color-text);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    font-weight: 500;
    border-radius: var(--border-radius-pill);
    cursor: pointer;
    transition: all var(--duration-fast) var(--easing-spring);
    position: relative;
    overflow: hidden;
  }

  #sqe-faq-{{ section.id }} .sqe-filter-btn:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
  }

  #sqe-faq-{{ section.id }} .sqe-filter-btn.active {
    background: var(--color-primary);
    color: white;
    border-color: var(--color-primary);
  }

  #sqe-faq-{{ section.id }} .sqe-faq-search-wrapper {
    position: relative;
    display: flex;
    align-items: center;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-search-input {
    width: 100%;
    padding: 12px 16px 12px 40px;
    border: 2px solid #ddd;
    background: white;
    border-radius: var(--border-radius);
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    transition: all var(--duration-fast) ease;
    overflow-wrap: break-word;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-search-input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(31, 58, 95, 0.1);
  }

  #sqe-faq-{{ section.id }} .sqe-search-icon {
    position: absolute;
    left: 12px;
    color: var(--color-text-light);
    pointer-events: none;
    flex-shrink: 0;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-counter {
    text-align: center;
    margin-bottom: 20px;
  }

  #sqe-faq-{{ section.id }} .sqe-counter-text {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    color: var(--color-text-muted);
  }

  #sqe-faq-{{ section.id }} .sqe-counter-visible,
  #sqe-faq-{{ section.id }} .sqe-counter-total {
    color: var(--color-primary);
    font-weight: 600;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion {
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-item {
    border-radius: var(--border-radius);
    background: white;
    border: 1px solid var(--color-border);
    overflow: hidden;
    transition: all var(--duration-fast) ease;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-item:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 12px rgba(31, 58, 95, 0.08);
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-item.active {
    border-color: var(--color-primary);
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-header {
    width: 100%;
    padding: 20px 24px;
    border: none;
    background: transparent;
    cursor: pointer;
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 16px;
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 600;
    color: var(--color-primary);
    transition: all var(--duration-fast) ease;
    text-align: left;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-header:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-item.active .sqe-accordion-header {
    background: linear-gradient(135deg, rgba(31, 58, 95, 0.02) 0%, rgba(242, 183, 5, 0.02) 100%);
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-title {
    flex: 1;
    line-height: 1.4;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-icon {
    flex-shrink: 0;
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: transform var(--duration-normal) var(--easing-spring);
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-item.active .sqe-accordion-icon {
    transform: rotate(180deg);
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-icon svg {
    color: var(--color-accent);
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-panel {
    overflow: hidden;
    transition: max-height var(--duration-normal) var(--easing-spring),
                opacity var(--duration-fast) ease;
    max-height: 0;
    opacity: 0;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-panel:not([hidden]) {
    max-height: 1000px;
    opacity: 1;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-content {
    padding: 0 24px 24px 24px;
    display: flex;
    gap: 16px;
    align-items: flex-start;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-left-border {
    width: 4px;
    background: linear-gradient(180deg, var(--color-accent) 0%, var(--color-accent-dark) 100%);
    border-radius: 2px;
    flex-shrink: 0;
    min-height: 20px;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-text {
    font-family: 'Inter', sans-serif;
    font-size: 14px;
    color: var(--color-text-muted);
    line-height: 1.8;
    flex: 1;
    overflow-wrap: break-word;
    word-break: break-word;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-text p {
    margin: 0 0 12px 0;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-text p:last-child {
    margin-bottom: 0;
  }

  #sqe-faq-{{ section.id }} .sqe-faq-placeholder {
    text-align: center;
    padding: 60px 20px;
    color: var(--color-text-light);
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    line-height: 1.6;
  }

  #sqe-faq-{{ section.id }} .sqe-accordion-item.hidden {
    display: none;
  }

  @media (max-width: 768px) {
    #sqe-faq-{{ section.id }} .sqe-faq-container {
      padding: 20px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-header {
      margin-bottom: 30px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-title {
      font-size: 28px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-subtitle {
      font-size: 15px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-controls {
      padding: 20px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-filters {
      gap: 8px;
    }

    #sqe-faq-{{ section.id }} .sqe-filter-btn {
      padding: 8px 12px;
      font-size: 13px;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-header {
      padding: 18px 20px;
      font-size: 14px;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-content {
      padding: 0 20px 20px 20px;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-text {
      font-size: 13px;
    }
  }

  @media (max-width: 480px) {
    #sqe-faq-{{ section.id }} .sqe-faq-container {
      padding: 16px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-title {
      font-size: 24px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-controls {
      flex-direction: column;
      padding: 16px;
      gap: 16px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-filters {
      gap: 8px;
    }

    #sqe-faq-{{ section.id }} .sqe-filter-btn {
      padding: 8px 14px;
      font-size: 12px;
      flex: 0 1 auto;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-header {
      padding: 16px;
      font-size: 14px;
      gap: 12px;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-content {
      padding: 0 16px 16px 16px;
      gap: 12px;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-left-border {
      width: 3px;
      min-height: 16px;
    }

    #sqe-faq-{{ section.id }} .sqe-accordion-text {
      font-size: 13px;
    }

    #sqe-faq-{{ section.id }} .sqe-faq-search-input {
      padding: 10px 14px 10px 36px;
      font-size: 13px;
    }
  }
</style>

<script>
(function() {
  const sectionId = 'sqe-faq-{{ section.id }}';
  const container = document.getElementById(sectionId);
  if (!container) return;

  const accordion = container.querySelector('.sqe-accordion');
  const items = container.querySelectorAll('.sqe-accordion-item');
  const filterBtns = container.querySelectorAll('.sqe-filter-btn');
  const searchInput = container.querySelector('.sqe-faq-search-input');
  const counterVisible = container.querySelector('.sqe-counter-visible');
  const counterTotal = container.querySelector('.sqe-counter-total');

  if (!items.length) return;

  let currentFilter = 'all';
  let currentSearch = '';
  let visibleIndices = [];

  // Accordion Toggle
  items.forEach((item) => {
    const header = item.querySelector('.sqe-accordion-header');
    const panel = item.querySelector('.sqe-accordion-panel');

    header.addEventListener('click', () => {
      toggleAccordionItem(item, header, panel);
    });
  });

  function toggleAccordionItem(item, header, panel) {
    const isActive = item.classList.contains('active');

    if (isActive) {
      item.classList.remove('active');
      header.setAttribute('aria-expanded', 'false');
      panel.setAttribute('hidden', '');
    } else {
      item.classList.add('active');
      header.setAttribute('aria-expanded', 'true');
      panel.removeAttribute('hidden');
    }
  }

  // Filter Function
  function applyFilters() {
    let visibleCount = 0;
    visibleIndices = [];

    items.forEach((item, index) => {
      const category = item.getAttribute('data-category');
      const question = item.querySelector('.sqe-accordion-title').textContent.toLowerCase();

      const matchesCategory = currentFilter === 'all' || category === currentFilter;
      const matchesSearch = currentSearch === '' || question.includes(currentSearch.toLowerCase());
      const shouldShow = matchesCategory && matchesSearch;

      if (shouldShow) {
        item.classList.remove('hidden');
        visibleCount++;
        visibleIndices.push(index);
      } else {
        item.classList.add('hidden');
        item.classList.remove('active');
        item.querySelector('.sqe-accordion-panel').setAttribute('hidden', '');
        item.querySelector('.sqe-accordion-header').setAttribute('aria-expanded', 'false');
      }
    });

    if (counterVisible && counterTotal) {
      counterVisible.textContent = visibleCount;
      counterTotal.textContent = items.length;
    }
  }

  // Filter Button Clicks
  filterBtns.forEach(btn => {
    btn.addEventListener('click', () => {
      filterBtns.forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentFilter = btn.getAttribute('data-filter');
      currentSearch = '';
      if (searchInput) searchInput.value = '';
      applyFilters();
    });
  });

  // Search Input
  if (searchInput) {
    searchInput.addEventListener('input', (e) => {
      currentSearch = e.target.value;
      applyFilters();
    });
  }

  // Keyboard Navigation
  items.forEach((item, index) => {
    const header = item.querySelector('.sqe-accordion-header');

    header.addEventListener('keydown', (e) => {
      let targetIndex = -1;

      switch (e.key) {
        case 'ArrowDown':
          e.preventDefault();
          targetIndex = visibleIndices.indexOf(index) + 1;
          if (targetIndex < visibleIndices.length) {
            items[visibleIndices[targetIndex]].querySelector('.sqe-accordion-header').focus();
          }
          break;
        case 'ArrowUp':
          e.preventDefault();
          targetIndex = visibleIndices.indexOf(index) - 1;
          if (targetIndex >= 0) {
            items[visibleIndices[targetIndex]].querySelector('.sqe-accordion-header').focus();
          }
          break;
        case 'Home':
          e.preventDefault();
          if (visibleIndices.length > 0) {
            items[visibleIndices[0]].querySelector('.sqe-accordion-header').focus();
          }
          break;
        case 'End':
          e.preventDefault();
          if (visibleIndices.length > 0) {
            items[visibleIndices[visibleIndices.length - 1]].querySelector('.sqe-accordion-header').focus();
          }
          break;
      }
    });
  });

  // Initialize
  applyFilters();
})();
</script>

{% schema %}
{
  "name": "SQE FAQ Accordion",
  "settings": [
    {
      "type": "header",
      "content": "Section Label"
    },
    {
      "type": "checkbox",
      "id": "show_section_label",
      "label": "Show orange label",
      "default": false
    },
    {
      "type": "text",
      "id": "section_label_text",
      "label": "Label text",
      "default": "FAQ"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "title",
      "label": "Section Title",
      "default": "Frequently Asked Questions"
    },
    {
      "type": "text",
      "id": "subtitle",
      "label": "Section Subtitle",
      "default": "Find answers to common questions about our solar inspection services"
    },
    {
      "type": "header",
      "content": "Heading Typography"
    },
    {
      "type": "select",
      "id": "heading_font",
      "label": "Heading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Source Sans 3', sans-serif"
    },
    {
      "type": "range",
      "id": "heading_size",
      "min": 24,
      "max": 56,
      "step": 2,
      "unit": "px",
      "label": "Heading size",
      "default": 32
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "checkbox",
      "id": "heading_bold",
      "label": "Heading bold",
      "default": true
    },
    {
      "type": "header",
      "content": "Subheading Typography"
    },
    {
      "type": "select",
      "id": "description_font",
      "label": "Subheading font",
      "options": [
        { "value": "'Source Sans 3', sans-serif", "label": "Source Sans 3" },
        { "value": "'Inter', sans-serif", "label": "Inter" },
        { "value": "system-ui, sans-serif", "label": "System" }
      ],
      "default": "'Inter', sans-serif"
    },
    {
      "type": "range",
      "id": "description_size",
      "min": 14,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Subheading size",
      "default": 16
    },
    {
      "type": "color",
      "id": "description_color",
      "label": "Subheading color",
      "default": "#666666"
    },
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "range",
      "id": "title_size",
      "label": "Title Size (px)",
      "min": 24,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 32
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text Alignment",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "center", "label": "Center" },
        { "value": "right", "label": "Right" }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Max Width (px)",
      "min": 800,
      "max": 1400,
      "step": 50,
      "unit": "px",
      "default": 1000
    },
    {
