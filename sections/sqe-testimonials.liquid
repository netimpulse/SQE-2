{% comment %}
SQE Testimonials Section
Displays client testimonials with customizable layout options
{% endcomment %}

<section class="sqe-testimonials" id="sqe-testimonials-{{ section.id }}">
  <div class="testimonials-container">
    {% if section.settings.show_heading %}
      <div class="testimonials-header">
        {% if section.settings.heading %}
          <h2 class="testimonials-title">{{ section.settings.heading }}</h2>
        {% endif %}
        {% if section.settings.subheading %}
          <p class="testimonials-subheading">{{ section.settings.subheading }}</p>
        {% endif %}
      </div>
    {% endif %}

    {% if section.settings.layout == 'slider' %}
      <div class="testimonials-slider">
        <div class="slider-wrapper">
          {% for block in section.blocks %}
            <div class="testimonial-card slider-slide">
              <div class="testimonial-content">
                {% if block.settings.show_rating %}
                  <div class="testimonial-rating">
                    {% for i in (1..block.settings.rating) %}
                      <span class="star filled">★</span>
                    {% endfor %}
                    {% for i in (1..5 | minus: block.settings.rating) %}
                      <span class="star empty">★</span>
                    {% endfor %}
                  </div>
                {% endif %}
                <p class="testimonial-quote">{{ block.settings.quote }}</p>
              </div>
              <div class="testimonial-footer">
                {% if block.settings.client_photo %}
                  <div class="client-photo">
                    {{ block.settings.client_photo | image_url: width: 48 | image_tag: alt: block.settings.client_name }}
                  </div>
                {% endif %}
                <div class="client-info">
                  <p class="client-name">{{ block.settings.client_name }}</p>
                  {% if block.settings.company_name %}
                    <p class="client-company">{{ block.settings.company_name }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endfor %}
        </div>
        <button class="slider-prev" aria-label="Previous">‹</button>
        <button class="slider-next" aria-label="Next">›</button>
        <div class="slider-dots">
          {% for i in (1..section.blocks.size) %}
            <button class="dot {% if i == 1 %}active{% endif %}" data-slide="{{ i | minus: 1 }}" aria-label="Go to slide {{ i }}"></button>
          {% endfor %}
        </div>
      </div>
    {% else %}
      <div class="testimonials-grid" style="grid-template-columns: repeat({{ section.settings.columns }}, 1fr);">
        {% for block in section.blocks %}
          <div class="testimonial-card">
            <div class="testimonial-content">
              {% if block.settings.show_rating %}
                <div class="testimonial-rating">
                  {% for i in (1..block.settings.rating) %}
                    <span class="star filled">★</span>
                  {% endfor %}
                  {% for i in (1..5 | minus: block.settings.rating) %}
                    <span class="star empty">★</span>
                  {% endfor %}
                </div>
              {% endif %}
              <p class="testimonial-quote">{{ block.settings.quote }}</p>
            </div>
            <div class="testimonial-footer">
              {% if block.settings.client_photo %}
                <div class="client-photo">
                  {{ block.settings.client_photo | image_url: width: 48 | image_tag: alt: block.settings.client_name }}
                </div>
              {% endif %}
              <div class="client-info">
                <p class="client-name">{{ block.settings.client_name }}</p>
                {% if block.settings.company_name %}
                  <p class="client-company">{{ block.settings.company_name }}</p>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  .sqe-testimonials {
    padding: {{ section.settings.padding_top }}px {{ section.settings.padding_side }}px {{ section.settings.padding_bottom }}px {{ section.settings.padding_side }}px;
    background-color: {{ section.settings.background_color }};
  }

  .testimonials-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .testimonials-header {
    text-align: center;
    margin-bottom: 48px;
  }

  .testimonials-title {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 42px;
    font-weight: 700;
    color: {{ section.settings.title_color }};
    margin: 0 0 16px 0;
  }

  .testimonials-subheading {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    color: #666;
    margin: 0;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  .testimonials-grid {
    display: grid;
    gap: 32px;
    margin-bottom: 32px;
  }

  .testimonials-slider {
    position: relative;
    margin-bottom: 32px;
  }

  .slider-wrapper {
    display: flex;
    gap: 24px;
    overflow-x: auto;
    scroll-behavior: smooth;
    padding: 16px 0;
  }

  .slider-slide {
    flex: 0 0 calc(100% / {{ section.settings.slider_items_per_view }});
    min-width: 0;
  }

  .testimonial-card {
    background: {{ section.settings.card_background_color }};
    border-radius: {{ section.settings.card_border_radius }}px;
    padding: 32px;
    display: flex;
    flex-direction: column;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: all 0.3s ease;
    border: 1px solid {{ section.settings.card_border_color }};
    height: 100%;
  }

  .testimonial-card:hover {
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.12);
    transform: translateY(-4px);
  }

  .testimonial-content {
    flex-grow: 1;
    margin-bottom: 24px;
  }

  .testimonial-rating {
    display: flex;
    gap: 4px;
    margin-bottom: 16px;
  }

  .star {
    font-size: 18px;
    transition: all 0.2s ease;
  }

  .star.filled {
    color: {{ section.settings.accent_color }};
  }

  .star.empty {
    color: #ddd;
  }

  .testimonial-quote {
    font-family: 'Inter', sans-serif;
    font-size: 16px;
    line-height: 1.6;
    color: {{ section.settings.quote_color }};
    margin: 0;
    font-style: italic;
  }

  .testimonial-footer {
    display: flex;
    gap: 12px;
    align-items: center;
    padding-top: 16px;
    border-top: 1px solid {{ section.settings.card_border_color }};
  }

  .client-photo {
    width: 48px;
    height: 48px;
    border-radius: 50%;
    overflow: hidden;
    flex-shrink: 0;
    background: #f0f0f0;
  }

  .client-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .client-info {
    flex-grow: 1;
  }

  .client-name {
    font-family: 'Source Sans 3', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: {{ section.settings.primary_color }};
    margin: 0 0 2px 0;
  }

  .client-company {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    color: #999;
    margin: 0;
  }

  .slider-prev,
  .slider-next {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    background: {{ section.settings.primary_color }};
    color: white;
    border: none;
    width: 44px;
    height: 44px;
    border-radius: 50%;
    cursor: pointer;
    font-size: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.3s ease;
    z-index: 10;
  }

  .slider-prev:hover,
  .slider-next:hover {
    background: {{ section.settings.accent_color }};
  }

  .slider-prev {
    left: -22px;
  }

  .slider-next {
    right: -22px;
  }

  .slider-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 20px;
  }

  .dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: none;
    background: #ddd;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .dot.active {
    background: {{ section.settings.primary_color }};
    width: 30px;
    border-radius: 5px;
  }

  @media (max-width: 768px) {
    .testimonials-grid {
      grid-template-columns: 1fr;
    }

    .testimonials-title {
      font-size: 32px;
    }

    .testimonial-card {
      padding: 24px;
    }

    .slider-prev,
    .slider-next {
      width: 36px;
      height: 36px;
      font-size: 20px;
    }

    .slider-prev {
      left: -18px;
    }

    .slider-next {
      right: -18px;
    }
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', function() {
    const section = document.getElementById('sqe-testimonials-{{ section.id }}');
    if (!section) return;

    const sliderPrev = section.querySelector('.slider-prev');
    const sliderNext = section.querySelector('.slider-next');
    const sliderWrapper = section.querySelector('.slider-wrapper');
    const dots = section.querySelectorAll('.dot');

    if (sliderPrev && sliderNext && sliderWrapper) {
      const scrollAmount = 400;
      let currentSlide = 0;

      sliderPrev.addEventListener('click', function() {
        sliderWrapper.scrollBy({ left: -scrollAmount, behavior: 'smooth' });
        currentSlide = Math.max(0, currentSlide - 1);
        updateDots();
      });

      sliderNext.addEventListener('click', function() {
        sliderWrapper.scrollBy({ left: scrollAmount, behavior: 'smooth' });
        currentSlide = Math.min(dots.length - 1, currentSlide + 1);
        updateDots();
      });

      dots.forEach((dot, index) => {
        dot.addEventListener('click', function() {
          const slides = section.querySelectorAll('.slider-slide');
          const slideWidth = slides[0].offsetWidth + 24;
          sliderWrapper.scrollTo({ left: index * slideWidth, behavior: 'smooth' });
          currentSlide = index;
          updateDots();
        });
      });

      function updateDots() {
        dots.forEach((dot, index) => {
          if (index === currentSlide) {
            dot.classList.add('active');
          } else {
            dot.classList.remove('active');
          }
        });
      }
    }
  });
</script>

{% schema %}
{
  "name": "Testimonials",
  "settings": [
    {
      "type": "checkbox",
      "id": "show_heading",
      "label": "Show heading",
      "default": true
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Our Clients Say"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Hear from our satisfied customers"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        {
          "value": "grid",
          "label": "Grid"
