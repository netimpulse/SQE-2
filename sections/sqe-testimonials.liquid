    },
    {
      "type": "range",
      "id": "padding_side",
      "min": 0,
      "max": 80,
      "step": 4,
      "label": "Padding sides",
      "default": 20
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "SQE Solar provided exceptional service and expertise. Our solar installation was completed on time and the system has exceeded our expectations."
        },
        {
