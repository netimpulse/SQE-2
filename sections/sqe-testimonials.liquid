{%- liquid
  assign heading = section.settings.heading
  assign subheading = section.settings.subheading
  assign layout = section.settings.layout
  assign bg_color = section.settings.background_color
  assign text_color = section.settings.text_color
-%}

<section id="sqe-testimonials-{{ section.id }}" class="sqe-testimonials" style="background-color: {{ bg_color }};">
  <div class="sqe-testimonials-container">
    {% if heading != blank %}
      <h2 class="sqe-testimonials-heading" style="color: {{ text_color }};">{{ heading }}</h2>
    {% endif %}

    {% if subheading != blank %}
      <p class="sqe-testimonials-subheading">{{ subheading }}</p>
    {% endif %}

    {% if layout == 'slider' %}
      <div class="sqe-testimonials-slider" data-layout="slider">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <div class="sqe-testimonial-card" {{ block.shopify_attributes }}>
              {% if block.settings.quote != blank %}
                <p class="sqe-testimonial-quote">{{ block.settings.quote }}</p>
              {% endif %}

              {% if block.settings.rating != blank %}
                <div class="sqe-testimonial-rating" data-rating="{{ block.settings.rating }}">
                  <span class="star">★</span>
                  <span class="star">★</span>
                  <span class="star">★</span>
                  <span class="star">★</span>
                  <span class="star">★</span>
                </div>
              {% endif %}

              <div class="sqe-testimonial-author">
                {% if block.settings.photo != blank %}
                  <img
                    src="{{ block.settings.photo | image_url: width: 56 }}"
                    alt="{{ block.settings.client_name }}"
                    class="sqe-author-photo"
                    loading="lazy"
                  >
                {% endif %}

                <div class="sqe-author-info">
                  {% if block.settings.client_name != blank %}
                    <p class="sqe-author-name">{{ block.settings.client_name }}</p>
                  {% endif %}

                  {% if block.settings.company != blank %}
                    <p class="sqe-author-company">{{ block.settings.company }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% else %}
      <div class="sqe-testimonials-grid" data-layout="grid">
        {% for block in section.blocks %}
          {% if block.type == 'testimonial' %}
            <div class="sqe-testimonial-card" {{ block.shopify_attributes }}>
              {% if block.settings.quote != blank %}
                <p class="sqe-testimonial-quote">{{ block.settings.quote }}</p>
              {% endif %}

              {% if block.settings.rating != blank %}
                <div class="sqe-testimonial-rating" data-rating="{{ block.settings.rating }}">
                  <span class="star">★</span>
                  <span class="star">★</span>
                  <span class="star">★</span>
                  <span class="star">★</span>
                  <span class="star">★</span>
                </div>
              {% endif %}

              <div class="sqe-testimonial-author">
                {% if block.settings.photo != blank %}
                  <img
                    src="{{ block.settings.photo | image_url: width: 56 }}"
                    alt="{{ block.settings.client_name }}"
                    class="sqe-author-photo"
                    loading="lazy"
                  >
                {% endif %}

                <div class="sqe-author-info">
                  {% if block.settings.client_name != blank %}
                    <p class="sqe-author-name">{{ block.settings.client_name }}</p>
                  {% endif %}

                  {% if block.settings.company != blank %}
                    <p class="sqe-author-company">{{ block.settings.company }}</p>
                  {% endif %}
                </div>
              </div>
            </div>
          {% endif %}
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<style>
  #sqe-testimonials-{{ section.id }} {
    padding: 60px 20px;
  }

  .sqe-testimonials-container {
    max-width: 1200px;
    margin: 0 auto;
  }

  .sqe-testimonials-heading {
    font-size: 36px;
    font-weight: 700;
    text-align: center;
    margin-bottom: 10px;
  }

  .sqe-testimonials-subheading {
    font-size: 16px;
    color: #666;
    text-align: center;
    margin-bottom: 40px;
  }

  .sqe-testimonials-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 30px;
    margin-top: 40px;
  }

  .sqe-testimonials-slider {
    display: flex;
    gap: 30px;
    overflow-x: auto;
    padding: 20px 0;
    scroll-behavior: smooth;
  }

  .sqe-testimonials-slider .sqe-testimonial-card {
    flex: 0 0 calc(100% / 2);
    min-width: 0;
  }

  .sqe-testimonial-card {
    background: white;
    padding: 30px;
    border-radius: 8px;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.1);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .sqe-testimonial-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15);
  }

  .sqe-testimonial-quote {
    font-size: 16px;
    color: #333;
    line-height: 1.6;
    margin-bottom: 20px;
    flex-grow: 1;
  }

  .sqe-testimonial-rating {
    margin-bottom: 20px;
  }

  .sqe-testimonial-rating .star {
    color: #F2B705;
    font-size: 16px;
  }

  .sqe-testimonial-rating[data-rating="1"] .star:nth-child(n+2),
  .sqe-testimonial-rating[data-rating="2"] .star:nth-child(n+3),
  .sqe-testimonial-rating[data-rating="3"] .star:nth-child(n+4),
  .sqe-testimonial-rating[data-rating="4"] .star:nth-child(n+5),
  .sqe-testimonial-rating[data-rating="5"] .star:nth-child(n+6) {
    color: #E8E8E8;
  }

  .sqe-testimonial-author {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .sqe-author-photo {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    object-fit: cover;
  }

  .sqe-author-info {
    flex-grow: 1;
  }

  .sqe-author-name {
    font-size: 14px;
    font-weight: 700;
    color: #1F3A5F;
    margin: 0;
  }

  .sqe-author-company {
    font-size: 12px;
    color: #999;
    margin: 4px 0 0 0;
  }

  @media (max-width: 768px) {
    .sqe-testimonials-grid {
      grid-template-columns: repeat(2, 1fr);
    }

    .sqe-testimonials-slider .sqe-testimonial-card {
      flex: 0 0 100%;
    }
  }

  @media (max-width: 480px) {
    .sqe-testimonials-grid {
      grid-template-columns: 1fr;
    }

    .sqe-testimonials-heading {
      font-size: 24px;
    }
  }
</style>

<script>
  var testimonialsSection = document.getElementById('sqe-testimonials-' + '{{ section.id }}');
  if (testimonialsSection) {
    var cards = testimonialsSection.querySelectorAll('.sqe-testimonial-card');
    cards.forEach(function(card) {
      card.addEventListener('mouseenter', function() {
        this.style.transform = 'translateY(-4px)';
      });
      card.addEventListener('mouseleave', function() {
        this.style.transform = 'translateY(0)';
      });
    });
  }
</script>

{% schema %}
{
  "name": "SQE Testimonials",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Client Testimonials"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "What our clients say"
    },
    {
      "type": "select",
      "id": "layout",
      "label": "Layout",
      "options": [
        { "value": "grid", "label": "Grid" },
        { "value": "slider", "label": "Slider" }
      ],
      "default": "grid"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background Color",
      "default": "#F2F4F7"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading Color",
      "default": "#1F3A5F"
    }
  ],
  "blocks": [
    {
      "type": "testimonial",
      "name": "Testimonial",
      "settings": [
        {
          "type": "textarea",
          "id": "quote",
          "label": "Quote",
          "default": "This is a client testimonial"
        },
        {
          "type": "text",
          "id": "client_name",
          "label": "Client Name",
          "default": "John Doe"
        },
        {
          "type": "text",
          "id": "company",
          "label": "Company",
          "default": "Company Name"
        },
        {
          "type": "range",
          "id": "rating",
          "min": 1,
          "max": 5,
          "step": 1,
          "label": "Rating",
          "default": 5
        },
        {
          "type": "image_picker",
          "id": "photo",
          "label": "Client Photo"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "SQE Testimonials",
      "blocks": [
        { "type": "testimonial" },
        { "type": "testimonial" },
        { "type": "testimonial" }
      ]
    }
  ]
}
{% endschema %}
