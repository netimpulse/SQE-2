        {
          "value": "slider",
          "label": "Slider"
        }
      ],
      "default": "slider"
    },
    {
      "type": "range",
      "id": "columns",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Columns (grid layout)",
      "default": 3
    },
    {
      "type": "range",
      "id": "slider_items_per_view",
      "min": 1,
      "max": 4,
      "step": 1,
      "label": "Items per view (slider layout)",
      "default": 3
    },
    {
      "type": "color",
      "id": "primary_color",
      "label": "Primary color",
      "default": "#1F3A5F"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent color",
      "default": "#F2B705"
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Heading color",
      "default": "#1F3A5F"
    },
    {
      "type": "color",
